                                        <th style="color:black; text-align:right">@tentotal</th>
                                        <th style="color:black; text-align:right">@elevenTotal</th>
                                        <th style="color:black; text-align:right">@twelveTotal</th>
                                        <th style="color:black; text-align:right">@intGrandTotal</th>
                                    </tr>
                                </thead>
                            </table>
