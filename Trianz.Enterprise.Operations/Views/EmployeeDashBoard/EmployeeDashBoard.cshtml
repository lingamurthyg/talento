                                            ctwelveTotal += item.sTwelve;
                                            caTotal += item.sA;
                                            ccTotal += item.sC;
                                            hTotal += item.sH;

                                            <tr style="font-size: 12px;">
                                                <td style="color:black; text-align:left; width:40%">@item.CountryName</td>
                                                <td style="color:black; text-align:right">@item.sZero&nbsp;&nbsp;</td>
                                                <td style="color:black; text-align:right">@item.sA&nbsp;&nbsp;</td>
                                                <td style="color:black; text-align:right">@item.sC&nbsp;&nbsp;</td>
                                                <td style="color:black; text-align:right">@item.sH&nbsp;&nbsp;</td>
                                                <td style="color:black; text-align:right">@item.sOne&nbsp;&nbsp;</td>
                                                <td style="color:black; text-align:right">@item.sTwo&nbsp;&nbsp;</td>
                                                <td style="color:black; text-align:right">@item.sthree&nbsp;&nbsp;</td>
                                                <td style="color:black; text-align:right">@item.sFour&nbsp;&nbsp;</td>
                                                <td style="color:black; text-align:right">@item.sFive&nbsp;&nbsp;</td>
                                                <td style="color:black; text-align:right">@item.sSix&nbsp;&nbsp;</td>
                                                <td style="color:black; text-align:right">@item.sSeven&nbsp;&nbsp;</td>
                                                <td style="color:black; text-align:right">@item.sEight&nbsp;&nbsp;</td>
                                                <td style="color:black; text-align:right">@item.sNine&nbsp;&nbsp;</td>
                                                <td style="color:black; text-align:right">@item.sTen&nbsp;&nbsp;</td>
                                                <td style="color:black; text-align:right">@item.sEleven&nbsp;&nbsp;</td>
                                                <td style="color:black; text-align:right;">@item.sTwelve&nbsp;&nbsp;</td>
                                                <td style="color:black; text-align:right">@CRowTotalCountry&nbsp;&nbsp;</td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                                <thead>
                                      <tr style="background-color: #E1F3FF; color: black; font-size: 12px;">
                                        <th>Grand Total</th>
                                        <th style="color:black; text-align:right">@czeroTotal</th>
                                        <th style="color:black; text-align:right">@caTotal</th>
                                        <th style="color:black; text-align:right">@ccTotal</th>
                                        <th style="color:black; text-align:right">@chTotal</th>
                                        <th style="color:black; text-align:right">@coneTotal</th>
                                        <th style="color:black; text-align:right">@ctwoTotal</th>
                                        <th style="color:black; text-align:right">@cthreeTotal</th>
                                        <th style="color:black; text-align:right">@cfourTotal</th>
                                        <th style="color:black; text-align:right">@cfiveTotal</th>
                                        <th style="color:black; text-align:right">@csixTotal</th>
                                        <th style="color:black; text-align:right">@csevenTotal</th>
                                        <th style="color:black; text-align:right">@ceightTotal</th>
                                        <th style="color:black; text-align:right">@cnineTotal</th>
                                        <th style="color:black; text-align:right">@ctentotal</th>
                                        <th style="color:black; text-align:right">@celevenTotal</th>
                                        <th style="color:black; text-align:right">@ctwelveTotal</th>
                                        <th style="color:black; text-align:right">@CGrandTotalContry</th>

                                    </tr>

                            </table>

                        </div>




                        @{
                            int RowTotalone = 0;
                            int intGrandTotalone = 0;
                            int india =0;
                            int dTotal = 0, ustotal = 0, uktotal = 0, synTotal = 0;
                          
                        }

                        <div class="tab-pane" id="designation-v" role="tabpanel">

                            <table id="divGridContent1" class="table table-striped table-bordered dt-responsive nowrap" cellspacing="0" style="margin-left:7px; width: 80%;">
                                <thead>
                                    <tr style="background-color: #D6DCE3 !important; color: black; font-size: 12px;">

                                        <th style="color:black; text-align:left; width:25%">Designation</th>
                                         <th style="color:black; text-align:right">India</th>
                                        <th style="color:black; text-align:right">Dubai</th>
                                        <th style="color:black; text-align:right">US</th>
                                        <th style="color:black; text-align:right">UK</th>
                                        <th style="color:black; text-align:right">Australia</th>
                                        <th style="color:black; text-align:right;">Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model != null)
                                    {
                                        foreach (var item in Model.EmployeeDesignationlst)
                                        {
                                            RowTotalone = item.US + item.India+item.Sydney+item.Dubai+item.UnitedKingdom;
                                            intGrandTotalone += RowTotalone;

                                            india += item.India;
                                            dTotal += item.Dubai;
                                            ustotal += item.US;
                                            uktotal += item.UnitedKingdom;
                                            synTotal += item.Sydney;


                                    <tr style="font-size: 12px;">
                                        <td style="color: black; text-align:left">@item.Designation</td>
                                        <td style="color:black; text-align:right">@item.India</td>
                                        <td style="color:black; text-align:right">@item.Dubai</td>
                                        <td style="color:black; text-align:right">@item.US</td>
                                        <td style="color:black; text-align:right">@item.UnitedKingdom</td>
                                         <td style="color:black; text-align:right">@item.Sydney</td>
                                        <td style="color:black; text-align:right;">@RowTotalone</td>
                                    </tr>
                                        }
                                    }
                                </tbody>

                                <thead>
                                    <tr style="background-color: #D6DCE3 !important; color: black; font-size: 12px;">
                                        <th style="color:black; text-align:left">Grand Total</th>
                                        <th style="color:black; text-align:right">@india</th>
                                        <th style="color:black; text-align:right">@dTotal</th>
                                        <th style="color:black; text-align:right">@ustotal</th>
                                        <th style="color:black; text-align:right">@uktotal</th>
                                        <th style="color:black; text-align:right">@synTotal</th>
                                        <th style="color:black; text-align:right;">@intGrandTotalone</th>
                                    </tr>
                                </thead>
                            </table>
                        </div>
                    </div>


                        </div>
                    </section>
                </div>
            </form>
        </body>


