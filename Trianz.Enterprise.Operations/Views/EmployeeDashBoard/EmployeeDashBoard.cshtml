                                        <th style="color:black; text-align:center">Grade 9</th>
                                        <th style="color:black; text-align:center">Grade 10</th>
                                        <th style="color:black; text-align:center">Grade 11</th>
                                        <th style="color:black; text-align:center;">Grade 12</th>
                                        <th style="color:black; text-align:center">Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model != null)
                                    {
                                        foreach (var item in Model.EmployeeLocationlst)
                                        {
                                            intRowTotal = item.sA + item.sC + item.sH + item.sZero + item.sOne + item.sTwo + item.sthree + item.sFour + item.sFive + item.sSix + item.sSeven + item.sEight + item.sNine + item.sTen + item.sEleven + item.sTwelve;
                                            intGrandTotal += intRowTotal;
                                            zeroTotal += item.sZero;
                                            oneTotal += item.sOne;
                                            twoTotal += item.sTwo;
                                            threeTotal += item.sthree;
                                            fourTotal += item.sFour;
                                            fiveTotal += item.sFive;
                                            sixTotal += item.sSix;
                                            sevenTotal += item.sSeven;
                                            eightTotal += item.sEight;
                                            nineTotal += item.sNine;
                                            tentotal += item.sTen;
                                            elevenTotal += item.sEleven;
                                            twelveTotal += item.sTwelve;
                                            aTotal += item.sA;
                                            cTotal += item.sC;
                                            hTotal += item.sH;

                                            <tr style="font-size: 12px;">
                                                <td style="color:black; text-align:left; width:40%">@item.location</td>
                                                <td style="color:black; text-align:right">@item.sZero&nbsp;&nbsp;</td>
                                                <td style="color:black; text-align:right">@item.sA&nbsp;&nbsp;</td>
                                                <td style="color:black; text-align:right">@item.sC&nbsp;&nbsp;</td>
                                                <td style="color:black; text-align:right">@item.sH&nbsp;&nbsp;</td>
                                                <td style="color:black; text-align:right">@item.sOne&nbsp;&nbsp;</td>
                                                <td style="color:black; text-align:right">@item.sTwo&nbsp;&nbsp;</td>
                                                <td style="color:black; text-align:right">@item.sthree&nbsp;&nbsp;</td>
                                                <td style="color:black; text-align:right">@item.sFour&nbsp;&nbsp;</td>
                                                <td style="color:black; text-align:right">@item.sFive&nbsp;&nbsp;</td>
                                                <td style="color:black; text-align:right">@item.sSix&nbsp;&nbsp;</td>
                                                <td style="color:black; text-align:right">@item.sSeven&nbsp;&nbsp;</td>
                                                <td style="color:black; text-align:right">@item.sEight&nbsp;&nbsp;</td>
                                                <td style="color:black; text-align:right">@item.sNine&nbsp;&nbsp;</td>
                                                <td style="color:black; text-align:right">@item.sTen&nbsp;&nbsp;</td>
                                                <td style="color:black; text-align:right">@item.sEleven&nbsp;&nbsp;</td>
                                                <td style="color:black; text-align:right;">@item.sTwelve&nbsp;&nbsp;</td>
                                                <td style="color:black; text-align:right">@intRowTotal&nbsp;&nbsp;</td>
                                            </tr>
                                        }
