                            int csevenTotal = 0, ceightTotal = 0, cnineTotal = 0, ctentotal = 0;
                            int celevenTotal = 0, ctwelveTotal = 0, caTotal = 0, ccTotal = 0, chTotal = 0;
                            
                        }
