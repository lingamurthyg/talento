                                    {
                                        foreach (var item in Model.EmployeeCountrieslst)
                                        {
                                            CRowTotalCountry = item.sA + item.sC + item.sH + item.sZero + item.sOne + item.sTwo + item.sthree + item.sFour + item.sFive + item.sSix + item.sSeven + item.sEight + item.sNine + item.sTen + item.sEleven + item.sTwelve;
                                            CGrandTotalContry += CRowTotalCountry;

