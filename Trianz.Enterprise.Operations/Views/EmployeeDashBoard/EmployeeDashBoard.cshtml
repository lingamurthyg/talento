                                        <th style="color:black; text-align:right">@threeTotal</th>
                                        <th style="color:black; text-align:right">@fourTotal</th>
                                        <th style="color:black; text-align:right">@fiveTotal</th>
                                        <th style="color:black; text-align:right">@sixTotal</th>
