                                int sevenTotal = 0, eightTotal = 0, nineTotal = 0, tentotal = 0;
                                int elevenTotal = 0, twelveTotal = 0, aTotal = 0, cTotal = 0, hTotal = 0;
                            }
                            <table id="divGridContent1" class="table table-striped table-bordered dt-responsive nowrap" cellspacing="0" style="width: 100%; margin-left:7px;">
                                <thead>
                                    <tr style="background-color: #D6DCE3 !important; color: black; font-size: 12px;">
                                        <th>Location</th>
                                        <th style="color:black; text-align:center">Grade 0</th>
                                        <th style="color:black; text-align:center">Grade A</th>
                                        <th style="color:black; text-align:center">Grade C</th>
                                        <th style="color:black; text-align:center">Grade H</th>
                                        <th style="color:black; text-align:center">Grade 1</th>
                                        <th style="color:black; text-align:center">Grade 2</th>
                                        <th style="color:black; text-align:center">Grade 3</th>
                                        <th style="color:black; text-align:center">Grade 4</th>
