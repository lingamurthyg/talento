    $("#ExpectedEnd").change(function () {

        var startDate = document.getElementById("ExpectedStart").value;
        var endDate = document.getElementById("ExpectedEnd").value;
        if ((Date.parse(startDate) >= Date.parse(endDate))) {
            alert("End date should be greater than Start date");
            document.getElementById("ExpectedEnd").value = "";
        }
    });
    $("#ExpectedStart").change(function () {

        var startDate = document.getElementById("ExpectedStart").value;
        var endDate = document.getElementById("ExpectedEnd").value;
        if ((Date.parse(startDate) >= Date.parse(endDate))) {
            alert("End date should be greater than Start date");
            document.getElementById("ExpectedStart").value = "";
        }
    });


    function ValidateRole() {
        var isValid = true;
        var count = 0;
        $('input:checkbox[name="chkRow"]:checked').each(function () {
            count = count + 1;
        });


        if (count == 0) {
            bootbox.alert("Please select employees to assign project");
            isValid = false;
        } else {
            $("#tableBenchEmployees tbody").find("tr").each(function () {
                if ($(this).find("td:first").find(".chkEmployee").prop("checked")) {
                    var roleCode = $(this).find("td:last").find(".clsProjects").val();
                    if (roleCode == "0") {
                        alert("Please select role");
                        return isValid = false;
                    }
                }
            });
        }

        return isValid;
    }


    function ClearModalData() {
        $("#ddlProjects").val("");
        $("#ddlResourceType").val("");
        $("#ExpectedStart").val("");
        $("#ExpectedEnd").val("");
    }



     function savepopup() {
            //alert('z');
         debugger;
         var selectedValues = [];
         $('input:checkbox[name="chkRow"]:checked').each(function () {
            
             selectedValues.push({
                 EmployeeId: $(this).val(), EmployeeName: $(this).closest("td").parent().find("#lblassiid1").text(), DesignationCode: $(this).closest("td").parent().find(".clsProjects").val()
                 , AssignmentID: $(this).closest("td").parent().find("#lblassiid").text(),        /* observation*/
                 util: $(this).closest("td").parent().find("#lblutil").text()
             });
         });
             var selectedProject = $('#ddlProjects').val();
                var expectedStartDate = $('#ExpectedStart').val();
                var expectedEndDate = $('#ExpectedEnd').val();
                var resourceType = $('#ddlResourceType').val();
                //var utilization = $('#ddlUtilization').val();
                var prevProjectCode = $('#ddlPractice').val();

                if (selectedValues.length != 0) {
                    $.ajax({
                        url: '@Url.Action("ProjectAutoAssignment", "BulkAssignment")',
                        data: {
                            "SelectedEmployees": selectedValues, "Project": selectedProject, "StartDate": expectedStartDate,
                            "EndDate": expectedEndDate, "ResourceType": resourceType,
                            "PrevProjectCode": prevProjectCode, "project1": $("#ddlPractice :selected").text()  // added project1 -- for get data 
                        },
                        type: 'POST',
                        datatype: 'JSON',
                        beforeSend: function () {
                            $("#GoalSettingLoadingIcon").show();
                        },
                        success: function (result) {
                            $("#GoalSettingLoadingIcon").hide();
                            bootbox.alert(result, function () {
                                window.location.href = '@Url.Action("index", "BulkAssignment")';
                                $('#btn-submit').removeAttr('disabled');
                            });

                            $("#dialog-view-ProjectAutoAssignment").dialog('close');
                        },
                        error: function (ex) {
                            $("#GoalSettingLoadingIcon").hide();
                            //alert(ex.statusText);

                            $("#dialog-view-ProjectAutoAssignment").dialog('close');
                        }
                    });
                }
                else {
                    bootbox.alert("Please select atleast one resource to assign project.");
                }

        }

</script>
