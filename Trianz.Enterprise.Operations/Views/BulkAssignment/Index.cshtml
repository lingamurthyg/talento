            </div>*@
        </div>
    </form>
</div>

</div>
<div id="GoalSettingLoadingIcon"></div>
<script type="text/javascript">
    $("#GoalSettingLoadingIcon").hide();
    $(function () {
        $('#frmAutoAssignment').validator({
            feedback: {
                success: 'glyphicon-ok',
                error: 'glyphicon-remove'
            },
            disable: true
        });
            //.on('submit', function (e) {
            //alert('h');
            @*if (e.isDefaultPrevented()) {
                // handle the invalid form...
                $('#btn-submit').attr('disabled', 'disabled');
            }
            else {
                // everything looks good!
                e.preventDefault();

                $('#btn-submit').attr('disabled', 'disabled');
                var selectedValues = [];
                $('input:checkbox[name="chkRow"]:checked').each(function () {
                    selectedValues.push({ EmployeeId: $(this).val(), DesignationCode: $(this).closest("td").parent().find(".clsProjects").val()
                        , AssignmentID: $(this).closest("td").parent().find("#lblassiid").text(),
                        util: $(this).closest("td").parent().find("#lblutil").text()
                    });
                });

                var selectedProject = $('#ddlProjects').val();
                var expectedStartDate = $('#ExpectedStart').val();
                var expectedEndDate = $('#ExpectedEnd').val();
                var resourceType = $('#ddlResourceType').val();
                //var utilization = $('#ddlUtilization').val();
                var prevProjectCode = $('#ddlPractice').val();

                if (selectedValues.length != 0) {
                    $.ajax({
                        url: '@Url.Action("ProjectAutoAssignment", "BulkAssignment")',
                        data: {
                            "SelectedEmployees": selectedValues, "Project": selectedProject, "StartDate": expectedStartDate,
                            "EndDate": expectedEndDate, "ResourceType": resourceType,
                             "PrevProjectCode": prevProjectCode
                        },
                        type: 'POST',
                        datatype: 'JSON',
                        beforeSend: function () {
                            $("#GoalSettingLoadingIcon").show();
                        },
                        success: function (result) {
                            $("#GoalSettingLoadingIcon").hide();
                            bootbox.alert(result, function () {
                                window.location.href = '@Url.Action("index", "BulkAssignment")';
                                $('#btn-submit').removeAttr('disabled');
                            });

                            $("#dialog-view-ProjectAutoAssignment").dialog('close');
                        },
                        error: function (ex) {
                            $("#GoalSettingLoadingIcon").hide();
                            //alert(ex.statusText);

                            $("#dialog-view-ProjectAutoAssignment").dialog('close');
                        }
                    });
                }
                else {
                    bootbox.alert("Please select atleast one resource to assign project.");
                }
            }*@
        });



        $("#ddlPractice").change(function () {
            //     debugger;
            $("#GoalSettingLoadingIcon").show();
            var url = '@Url.Content("~/BulkAssignment/GetEmployeeInfobyPractice")';
            var ddlPractice = $("#ddlPractice").val();
            $.ajax({
                url: url,
                type: 'GET',
                cache: false,
                data: { ProjectCode: ddlPractice },
                success: function (data) {
                    if (data != null && data != "Sessionexpired") {
                        $('#divGridContent1').html(data);
                        $("#GoalSettingLoadingIcon").hide();
                    }
                    else if (data== "Sessionexpired") {
                        window.location.href = '@Url.Action("SessionExpire", "Signout")';
                        }
                },
                error: function (thrownError) {
                    $("#GoalSettingLoadingIcon").hide();
                    alert(thrownError);
                }
            });
        });
        var nowDate = new Date();
        var today = new Date(nowDate.getFullYear(), nowDate.getMonth(), nowDate.getDate(), 0, 0, 0, 0);
        $('#datetimepicker1').datepicker({
            keyboardNavigation: false,
            forceParse: false,
            autoclose: true,
            todayHighlight: true,
            startDate: today,
            format: 'dd-M-yyyy'
        }).on('changeDate', function (e) {
            $(this).datepicker('hide');
        });

        $('#datetimepicker2').datepicker({
            keyboardNavigation: false,
            forceParse: false,
            autoclose: true,
            todayHighlight: true,
            startDate: today,
            format: 'dd-M-yyyy'
        }).on('changeDate', function (e) {
            $(this).datepicker('hide');
        });



</script>
