<div class="request_header">
<div class="form-inline text-center">

    <div class="form-group" id="project">

        <label style="margin-bottom:20px">Project</label>
        @Html.DropDownList("ddlPractice", ViewBag.Practices as List<SelectListItem>, "Select Project", new { @class = "form-control", @style = "width: 350px;" })
    </div>
</div>


<div id="divGridContent1" class="table table-responsive" style="margin-bottom: 0px;">
    @Html.Partial("BulkAssignmentPartialView", Model)
</div>

<div class="col-lg-12 form-group">
    <div class="col-lg-12">
        <button id="popup" class="button" onclick="div_show()" style="margin-top: 9px;margin-left: 11px;background-color: #004BBB;color:white;width: 118px;border-radius: 3px;border: 5px solid transparent;">Assign Project</button>
    </div>
</div>
<div id="dialog-view-ProjectAutoAssignment" style="display: none;overflow-x:hidden">
    <form class="form-horizontal" role="form" id="frmAutoAssignment">


        @Html.AntiForgeryToken()
        <div class="row">
        
            <div class="col-lg-12 form-group">
                <label class="col-lg-3 control-label">
                    Select Project
                    <span style="color:red">*</span>
                </label>
               
                <div style="margin-left: 20px;width: 187px;">
                    @Html.DropDownList("ddlProjects", ViewBag.AllProjects as List<SelectListItem>, "Select Project", new { @class = "form-control", @required = "required", data_error = "Please select project name" })
                    <div class="help-block with-errors error-msg-font-size"></div>
                    &nbsp;
                </div>
            </div>
            <div class="col-lg-12 form-group" style="position: relative;right: 37px;bottom: 40px;">
                <label class="col-lg-5 control-label">Select Resource Type
                    <span style="color:red">*</span></label>
                
                <div style="margin-left: 79px;width: 203px;">
                    @Html.DropDownList("ddlResourceType", ViewBag.ResourceType as List<SelectListItem>, "Select Resource Type", new { @class = "form-control", @required = "required", data_error = "Please select resource type" })
                    <div class="help-block with-errors error-msg-font-size"></div>
                </div>
            </div>
      

        
            <div class="col-lg-12 form-group" style="position: relative;right: 25px;bottom: 60px;">
                <label class="col-lg-5 control-label">
                    Assignment Start Date
                    <span style="color:red">*</span>
                </label>
               
                <div style="margin-left:47px;width:188px;">
                    <div class='input-group input-append date' id='datetimepicker1'>
                        <input type='text' name="ExpectedStart" id="ExpectedStart" class="form-control" data-error="Assignment Start Date should not be blank." required />
                        <span class="input-group-addon"><span class="glyphicon glyphicon-calendar"></span></span>
                    </div>
                    <div class="help-block with-errors error-msg-font-size"></div>
                </div>
            </div>
            <div class="col-lg-12 form-group" style="position: relative;right:8px;bottom: 76px;">
                <label class="control-label col-lg-5" style="width: 192px;">Assignment End Date
                    <span style="color:red">*</span></label>
                
                <div class="col-lg-6" style="width: 208px;top: 34px;right: 173px;">
                    <div class='input-group input-append date' id='datetimepicker2'>
                        <input type='text' name="ExpectedEnd" id="ExpectedEnd" class="form-control" data-error="Assignment End Date should not be blank." required />
                        <span class="input-group-addon"><span class="glyphicon glyphicon-calendar"></span></span>
                    </div>
                    <div class="help-block with-errors error-msg-font-size"></div>
                </div>
            </div>

      
           </div>
        @*<div class="row">*@

        @*<div class="col-lg-6 form-group">
