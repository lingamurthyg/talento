@model Trianz.Enterprise.Operations.Models.Employee
@{
    var ProjectAssignmentGrid = new WebGrid((IEnumerable<dynamic>)ViewData["ProjectAssignmentDetails"], canPage: true, canSort: true, rowsPerPage: 10, selectionFieldName: "SelectedRow");
    var SearchedSkillsGrid = new WebGrid((IEnumerable<dynamic>)ViewData["SearchedEmployeeSkills"], canPage: true, canSort: true, rowsPerPage: 10, selectionFieldName: "SelectedRow");
    var reportingmanager = ViewData["reportingmanager"].ToString();
    var TrainingGrid = new WebGrid((IEnumerable<dynamic>)ViewData["EmployeeTrainingDetails"], canPage: true, canSort: true, rowsPerPage: 10, selectionFieldName: "SelectedRow");

}
<style>
    table.table-bordered.dataTable tbody th, table.table-bordered.dataTable tbody td {
        border-bottom-width: 0;
        text-align: left;
    }
    body {
        overflow-x: hidden;
    }
</style>
<hr />
@if (Model == null)
{
    <div class="form-group">
        <div class="row">
            <div class="col-sm-12 text-center">
                Employee details does not match with given Employee ID
            </div>
        </div>
    </div>
}
else
{
    <div class="form-group">
        <div class="row">
            <div class="col-sm-2 text-center">
                @*<img src="~/Content/images/defaultimage.png">*@
                <img src="~/Content/images/EmployeeImg.png">
                

                @if (Model.Resumes != null)
                {
                    <button id="btnEmpResume" type="button" class="btn btn-primary emp-resume" title="Click here to download or view resume" emp-id="@Model.EmployeeId" style="margin-top: 20px;"><i class="fa fa-download fa-lg" aria-hidden="true"></i> Download Resume</button>
                }
            </div>
            <div class="col-sm-10">
                <div class="row">
                    <div class="col-sm-5" style="border-right: 1px solid whitesmoke; padding-left: 100px; text-align:left;">
                        @*<h4 class="bold sub-headtext" style="font-size: 16px;"></h4>*@
                        <h4 class="bold sub-headtext" style="font-size: 16px;">@Model.EmployeeId - @Model.FirstName @Model.MiddleName @Model.LastName</h4>
                        <p style="font-size: 13px;">@Model.Designation </p>
                        <p style="font-size: 13px;">@Model.Practice</p>
                        <p style="font-size: 13px;">@Model.EmployeeType</p>
                        <p style="font-size: 13px;">Visa - @((Model.Visa != null && Model.Visa.Trim() != "") ? Model.Visa : "")</p>
                        <p style="font-size: 13px;">@Model.Location</p>
                        <p class="email_text" style="font-size: 13px;">@Model.Email.ToLower()</p>
                    </div>
                    <div class="col-sm-5" style="border-right: 1px solid whitesmoke; padding-left: 25px;">
                        @Html.Raw(ViewData["EmployeeAddressDetails"].ToString())
                    </div>
                </div>
            </div>

        </div>
    </div>

    <div class="form-group">
        <div class="row">
            <div class="col-sm-12">
                <div class="subpage_header page-header nomargin-top" style="text-align:left;">
                    <p>@Model.FirstName's Project Assignments</p>
                </div>

                @*@ProjectAssignmentGrid.GetHtml(columns:
                                ProjectAssignmentGrid.Columns
                                (
                                    ProjectAssignmentGrid.Column("ProjectName", "Project Name", format:@<text>@item.ProjectCode @item.ProjectName </text>  ),
                                    ProjectAssignmentGrid.Column("Assigned_By", "Assigned By"),
                                    ProjectAssignmentGrid.Column("Utilization", "Utilization%"),
                                    ProjectAssignmentGrid.Column("StartDate", "Start Date"),
                                    ProjectAssignmentGrid.Column("StartDate", "End Date")
                                ), mode: WebGridPagerModes.Numeric, htmlAttributes: new { @class = "table table-bordered table-striped p-resources" })*@
                <table id="projectAssignmentdata" class="table table-striped table-bordered" cellspacing="0" style="margin: 0px; width: 100%; text-align:left;">
                    <thead>
                        <tr style="background-color: #248CC8 !important; color: #fff; font-size: 12px;">
                            <th>Project Name</th>
                            <th>Assigned By</th>
                            <th>Utilization(%)</th>
                            <th>Start Date</th>
                            <th>End Date</th>
                          

                        </tr>
                    </thead>
                    <tbody>

                        @if (ProjectAssignmentGrid.TotalRowCount > 0)
                {
                    foreach (var item in ViewBag.ProjectAssignmentDetails)
                    {
                                <tr style="font-size: 12px;">
                                    <td>@item.ProjectCode @item.ProjectName</td>
                                    <td>@item.Assigned_By</td>
                                    <td>@item.Utilization</td>
                                    <td>@item.StartDate</td>
                                    <td>@item.EndDate</td>
                                   

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5">
                                    <div class="text-center">No data available</div>
                                </td>
                            </tr>
                        }


                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="form-group">
        <div class="row">
            <div class="col-sm-12">
                <div class="subpage_header page-header nomargin-top" style="text-align:left;">
                    <p>@Model.FirstName's Skills</p>
                </div>
               
                <table id="searchskill" class="table table-striped table-bordered" cellspacing="0" style="margin: 0px; width: 100%; text-align:left;">
                    <thead>
                        <tr style="background-color: #248CC8 !important; color: #fff; font-size: 12px;">
                            <th>Skill Name</th>
                            <th>Competency Name</th>
                            <th>Expertise Level</th>
                            <th>Technology Last Used</th>                            
                            <th>Skill Status</th>
                            <th>Approver</th>
                            
                        </tr>
                    </thead>
                    <tbody>

                        @if (SearchedSkillsGrid.TotalRowCount > 0)
                {
                    foreach (var item in ViewBag.SearchedEmployeeSkills)
                    {
                                <tr style="font-size: 12px;">
                                    <td>@item.Skillname</td>
                                    <td>@item.CompetincyName</td>
                                    <td>@item.Expertiselevel</td>
                                  
                                    <td>
                                        <span id="lblastused" class="skillreadonly"> @System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(Convert.ToInt32(item.TechnologyLastUsed.Split(',')[0]))-@item.TechnologyLastUsed.Split(',')[1]</span>
                                        <span id="lblastusedid" style="display:none;"> @item.TechnologyLastUsed</span>
                                        <select id="ddlEditMonth" class="form-control pull-left skilleditcontrolls EditMonth" style="width: auto;display:none">
                                            <option value="">Month</option>
                                            <option value="1">Jan</option>
                                            <option value="2">Feb</option>
                                            <option value="3">Mar</option>
                                            <option value="4">Apr</option>
                                            <option value="5">May</option>
                                            <option value="6">June</option>
                                            <option value="7">July</option>
                                            <option value="8">Aug</option>
                                            <option value="9">Sep</option>
                                            <option value="10">Oct</option>
                                            <option value="11">Nov</option>
                                            <option value="12">Dec</option>
                                        </select>
                                        <select id="ddlEidtYear" class="form-control pull-right skilleditcontrolls EidtYear" style="width: auto;display:none">
                                            <option value="">Year</option>
                                            <option value="2016">2016</option>
                                            <option value="2015">2015</option>
                                            <option value="2014">2014</option>
                                            <option value="2013">2013</option>
                                            <option value="2012">2012</option>
                                            <option value="2011">2011</option>
                                            <option value="2010">2010</option>
                                            <option value="2009">2009</option>
                                            <option value="2008">2008</option>
                                            <option value="2007">2007</option>
                                            <option value="2006">2006</option>
                                            <option value="2005">2005</option>
                                            <option value="2004">2004</option>
                                            <option value="2003">2003</option>
                                            <option value="2002">2002</option>
                                            <option value="2001">2001</option>
                                            <option value="2000">2000</option>
                                            <option value="1999">1999</option>
                                            <option value="1998">1998</option>
                                            <option value="1997">1997</option>
                                            <option value="1996">1996</option>
                                            <option value="1995">1995</option>
                                            <option value="1994">1994</option>
                                            <option value="1993">1993</option>
                                            <option value="1992">1992</option>
                                            <option value="1991">1991</option>
                                            <option value="1990">1990</option>
                                        </select>
                                    </td>
                                   
                                    <td>@item.SkillStatus</td>
                                    <td>@reportingmanager</td>
                                   
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6">
                                    <div class="text-center">No data available</div>
                                </td>
                            </tr>
                        }


                    </tbody>
                </table>

            </div>
        </div>
    </div>

    <div class="form-group">
        <div class="row">
            <div class="col-sm-12">
                <div class="subpage_header page-header nomargin-top" style="text-align:left;">
                    <p>@Model.FirstName's Trainings</p>
                </div>
                <table id="Trainingdata" class="table table-striped table-bordered" cellspacing="0" style="margin: 0px; width: 100%;text-align:left;">
                    <thead>
                        <tr style="background-color: #248CC8 !important; color: #fff; font-size: 12px;">
                            <th>Program Name</th>
                            <th>Start Date</th>
                            <th>End Date</th>
                            <th>Attendance Status</th>
                            <th>Total Hours</th>
                            <th>Source</th>
                            <th>Category</th>
                            <th>Mode</th>
                        </tr>
                    </thead>
                    <tbody>

                        @if (TrainingGrid.TotalRowCount > 0)
                {
                    foreach (var item in ViewBag.EmployeeTrainingDetails)
                    {
                                <tr style="font-size: 12px;">
                                    <td>@item.ProgramName</td>
                                    <td>@(item.StartDate == null ? "" : @Convert.ToDateTime(item.StartDate).ToString("dd MMM yyyy"))</td>
                                    <td>@(item.EndDate == null ? "" : @Convert.ToDateTime(item.EndDate).ToString("dd MMM yyyy"))</td>
                                    @*<td>@(item.SOWStartDate == null ? "" : @Convert.ToDateTime(item.SOWStartDate).ToString("dd MMM yyyy"))</td>
                                        <td>@(item.SOWEndDate == null ? "" : @Convert.ToDateTime(item.SOWEndDate).ToString("dd MMM yyyy"))</td>*@
                                    <td>@item.AttendanceStatus</td>
                                    <td>@item.TotalHours</td>
                                    <td>@item.Source</td>
                                    <td>@item.Category</td>
                                    <td>@item.Mode</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8">
                                    <div class="text-center">No data available</div>
                                </td>
                            </tr>
                        }


                    </tbody>
                </table>
            </div>
        </div>
    </div>

}
