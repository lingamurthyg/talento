        function DisplayHRRFList() {
                var url = '@Url.Content("~/TRHome/GetSummaryPieChartInternal")';
           // var url = '@Url.Content("~/TRHome/StatusGraphPieChart")';
            //  debugger
            $.ajax({
                url: url,
                //data: { type: type, },
                type: 'POST',
                datatype: 'JSON',
                cache: false,
                success: function (data) {
                    if (data != "null" && data != "Error" && data != "Sessionexpired") {

                            displaypiechart1(data);
                    }
                    else if (data == "Sessionexpired") {
                        $("#btnProcessing").hide();
                        window.location.href = '@Url.Action("SessionExpire", "Signout")';
                    }
                    else if (data == "Error") {
                        $("#btnProcessing").hide();
                        window.location.href = '@Url.Action("Error","Error")';

                    }
                },
                error: function (error) {

                    alert("error");
                    $("#btnProcessing").hide();
                    alert(error.statusText);
                }
            });
        }

