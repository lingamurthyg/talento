<script>

    $(document).ready(function () {
        $("a[href='http://www.amcharts.com/javascript-charts/']").css("display", "none");



                  $('.clsexternal').click(function () {
                      debugger;
                      var Cricticality = $(this).attr("value");
                
                            var AccountName = $(this).attr("data-docId");
                            var Type = "External"
                         
                      $("#hdnCriticality").val(Cricticality)
                            $("#hdnAccountName").val(AccountName);
                            
                             $.ajax({
                async: false,
                cache: false,
                type: "POST",
                url: "@(Url.Action("GetSummaryByAccountName", "TRHome"))",
                                 data: { AccountName: AccountName, Type: Type, Cricticality: Cricticality},
                           success: function (data) {
                               if (data != "null" && data != "Error") {

                                   tableCreation(data);
                                   div_showAssignment();
                    }
                     else if (data == "Error") {
                    window.location.href = '@Url.Action("Error","Error")';

               }
               }
            });
        });
         $('.clsinternal').click(function () {
             var Cricticality = $(this).attr("value");
                            var AccountName = $(this).attr("data-docId");
             var Type = "Internal"
             $("#hdnCriticality1").val(Cricticality)
             $("#hdnAccountName1").val(AccountName);

                              $.ajax({
                async: false,
                cache: false,
                type: "POST",
                url: "@(Url.Action("GetSummaryByAccountName", "TRHome"))",
                                  data: { AccountName: AccountName, Type: Type, Cricticality: Cricticality},
                           success: function (data) {
                               if (data != "null" && data != "Error") {

                                   tableCreation(data);
                                   div_showAssignment1();
                    }
                     else if (data == "Error") {
                    window.location.href = '@Url.Action("Error","Error")';

               }
               }
