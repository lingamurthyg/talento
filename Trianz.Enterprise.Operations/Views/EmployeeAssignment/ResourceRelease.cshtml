    <div id="dialog-view-ProjectAutoAssignment" class="forscroll" style="display: none">
        <form class="form-horizontal" role="form" id="frmAutoAssignment">
            @Html.AntiForgeryToken()
            <div class="row">
                <div class="col-lg-12 form-group">
                    <label>Employee Number</label>
                    <div>
                        @Html.TextBox("txtemployeenumber", ViewBag.EmpCode as string, new { @class = "form-control", @readonly = "true" })
                        <div class="help-block with-errors error-msg-font-size"></div>
                    </div>
                </div>
                <div class="col-lg-12 form-group">
                    <label>Employee Name</label>
                    <div>
                        @Html.TextBox("txtemployeename", ViewBag.EmpName as string, new { @class = "form-control", @readonly = "true" })
                        <div class="help-block with-errors error-msg-font-size"></div>
                    </div>
                </div>

                <div class="col-lg-12 form-group">
                    <label>Designation</label>
                    <div>
                        @Html.TextBox("txtdesignation", ViewBag.Designation as string, new { @class = "form-control", @readonly = "true" })
                        <div class="help-block with-errors error-msg-font-size"></div>
                    </div>
                </div>
                <div class="col-lg-12 form-group">
                    <label>Release Date</label>
                    <span style="color:red">*</span>
                    <div>
                        <div class='input-group input-append date' id='datetimepicker2' style="width: 60%;">
                            <input type='text' name="ExpectedEnd" id="ExpectedEnd" class="form-control" data-error="Release Date should not be blank." required />
                            <span class="input-group-addon"><span class="glyphicon glyphicon-calendar"></span></span>
                        </div>
                        <div class="help-block with-errors error-msg-font-size"></div>
                    </div>
                </div>


                <div class="col-lg-12 form-group">
                    <label>Project Code</label>
                    <div>

                        @Html.TextBox("txtprojectcode", ViewBag.ProjectCodeData as string, new { @class = "form-control", @readonly = "true" })
                        <div class="help-block with-errors error-msg-font-size"></div>
                    </div>
                </div>
                <div class="col-lg-12 form-group">
                    <label>Utilization(%) </label>
                    <div>
                        @*@Html.DropDownList("ddlUtilization", ViewBag.Utilization as List<SelectListItem>, "-- Select Utilization --", new { @class = "form-control", @required = "required", data_error = "Please select utilization" })*@
                        @Html.TextBox("txtUtilization", ViewBag.UtilisationData as string, new { onkeydown = "return ValidateNumber(event);", @class = "form-control", @readonly = "true" })
                        <div class="help-block with-errors error-msg-font-size"></div>
                    </div>
                </div>


                <div class="col-lg-12 form-group">
                    <label>Client/Project</label>
                    <span style="color:red">*</span>
                    <div>
                        @Html.DropDownList("ddlclientorproject", ViewBag.ClientOrProject as List<SelectListItem>, "Select Project", new { @class = "form-control", @required = "required", data_error = "Please select Client/Project" })
                        <div class="help-block with-errors error-msg-font-size"></div>
                        &nbsp;
                    </div>
                </div>
                <div class="col-lg-12 form-group">
                    <label>Reason For Release</label>
                    <span style="color:red">*</span>
                    <div>
                        @Html.TextArea("txresonforrelease", "", new { @class = "form-control", @placeholder = "Enter Reason" })
                        <div class="help-block with-errors error-msg-font-size"></div>
                    </div>
                </div>


                <div class="col-lg-12 form-group">
                    @*<label class="col-lg-6 control-label">Have Discussed on Project Movement *</label>*@
                    <label>Informed to Employee</label>
                    <span style="color:red">*</span>
                    <div>
                        @Html.DropDownList("ddlProjectmovemnt", ViewBag.ProjectMovement as List<SelectListItem>, "Select", new { @class = "form-control", @required = "required", data_error = "Please enter project movement" })
                        <div class="help-block with-errors error-msg-font-size"></div>
                        &nbsp;
                    </div>
                </div>
                <div class="col-lg-12 form-group">
                    <label>Skills Good At</label>
                    <span style="color:red">*</span>
                    <div>
                        @Html.TextArea("txtskills", "", new { @class = "form-control", @placeholder = "Enter Skills", data_error = "Please enter skills" })
                        <div class="help-block with-errors error-msg-font-size"></div>
                    </div>
                </div>



                <div class="col-lg-12 form-group">
                    <label>Feed Back</label>
                    <span style="color:red">*</span>
                    <div>
                        @*@Html.DropDownList("ddlUtilization", ViewBag.Utilization as List<SelectListItem>, "-- Select Utilization --", new { @class = "form-control", @required = "required", data_error = "Please select utilization" })*@
                        @Html.TextArea("txtfeedback", "", new { @class = "form-control", @placeholder = "Enter Feedback", data_error = "Please enter feedback" })

                        @Html.TextBox("txtassignmentid", "", new { @class = "form-control", @placeholder = "Enter Feedback", @style = "display: none;" })
                        <div class="help-block with-errors error-msg-font-size"></div>
                    </div>
                </div>

                <div class="col-lg-12 form-group">
                    <label>Resource Performance</label>
                    <span style="color:red">*</span>
                    <div>
                        @*ViewBag.PerformanceType*@
                        @Html.DropDownList("ddlresourceperformance", ViewBag.PerformanceType as List<SelectListItem>, "Select", new { @class = "form-control", @required = "required", data_error = "Please select Performance" })

                        <div class="help-block with-errors error-msg-font-size"></div>
                        &nbsp;
                    </div>
                </div>
            </div>
            <div></div>
            <div></div>
            @*<button type="submit" id="btnSubmit" class="btn btn-primary btn-submit prosubmit" style="margin-left: 600px;">Submit</button>*@
        </form>
    </div>


    <script type="text/javascript">
        var jsonarray = [];
        $("#GoalSettingLoadingIcon").hide();
        function chkvalidationforskill() {

            var ischk = true;
            var expectedenddate = $("#ExpectedEnd").val();
            var clientorproject = $("#ddlclientorproject").val();
            var reasonforrelease = $("#txresonforrelease").val();
            var skillname = $("#txtskills").val();
            var feedback = $("#txtfeedback").val();
            var performance = $("#ddlresourceperformance").val();
            var projectmovement = $("#ddlProjectmovemnt").val();
            if (expectedenddate == "") {
                bootbox.alert("Please enter Release Date");
                ischk = false;
            }
            else if (clientorproject == "") {
                bootbox.alert("Please select Client/Project");
                ischk = false;
            }
            else if (skillname == "") {
                bootbox.alert("Please enter Skills");
                ischk = false;
            }
            else if (feedback == "") {
                bootbox.alert("Please enter feedback");
                ischk = false;
            }
            else if (reasonforrelease == "") {
                bootbox.alert("Please Enter reason for release");
                ischk = false;
            }
            else if (performance == "") {
                bootbox.alert("Please select Resource Performance");
                ischk = false;
            }
            else if (projectmovement == "") {
                bootbox.alert("Please select  Is discusion with project movement");
                ischk = false;
            }
            return ischk;
        }
        function popup() {

            //$('#btnSubmit').on('click', function () {
                var employeeDetails = {};
                var chki = chkvalidationforskill();
                if (chki) {
                    employeeDetails.EmployeeId = $("#txtemployeenumber").val();
                    employeeDetails.EmployeeName = $("#txtemployeename").val();
                    employeeDetails.ReleaseDate = $("#ExpectedEnd").val();
                    employeeDetails.ProjectCode = $("#txtprojectcode").val();
                    employeeDetails.ProjectDesignation = $("#txtdesignation").val();
                    employeeDetails.ClientorProject = $("#ddlclientorproject").val();
                    employeeDetails.Utilization = $("#txtUtilization").val();
                    employeeDetails.ReasonForRelease = $("#txresonforrelease").val();
                    employeeDetails.IsDiscResourceOnProject = $("#ddlProjectmovemnt").val();;
                    employeeDetails.SkillsGoodAt = $("#txtskills").val();
                    employeeDetails.DetailedFeedBack = $("#txtfeedback").val();
                    employeeDetails.ResourcePerformance = $("#ddlresourceperformance").val();
                    employeeDetails.Assignment_Id = $("#txtassignmentid").val();
                    $.ajax({
                        type: "POST",
                        url: '@Url.Action("InsertResourceReleaseData", "EmployeeAssignment")',
                        data: JSON.stringify(employeeDetails),
                        contentType: "application/json; charset=utf-8",
                        dataType: "json",
                        success: function (data) {
                            if (data != null && data != "Sessionexpired") {
                                $('#divGridContent1').html(data);
                                alert('Data Saved Successfully');
                                window.location.href = '@Url.Action("ResourceRelease", "EmployeeAssignment")';
                            }
                            else if (data == "Sessionexpired") {
                                window.location.href = '@Url.Action("SessionExpire", "Signout")';
                            }
                            else if (data == "Error") {
                                window.location.href = '@Url.Action("Error", "Error")';
                            }
                        },
                        error: function (thrownError) {
                            alert(thrownError);
                        }
                    });
                }

        }

    function GetEmployeeId(EmpCode) {
        $("#GoalSettingLoadingIcon").show();
        window.location = "@Url.Action("GetEmployeeInfoData", "EmployeeAssignment")" + "?EmpCode=" + EmpCode;
    };

        $("#btnSearch").click(function () {
            var ddlPractice = $("#SearchEmployee").val();
            if (ddlPractice == "") {
                bootbox.alert("Please enter EmployeeId");
            }
            else
            {
            $("#GoalSettingLoadingIcon").show();
            var url = "@Url.Action("GetEmployeeId", "EmployeeAssignment")" + "?EmpCode=" + ddlPractice;
            $.ajax({
                url: url,
                type: 'GET',
                cache: false,
                data: { EmpCode: ddlPractice },
                success: function (result) {
                    if (result == "true") {
                        GetEmployeeId(ddlPractice);
                    }
                    else if (result == "false") {
                        alert('Employee Code does not exist');
                    }
                },
                error: function (thrownError) {
                    $("#GoalSettingLoadingIcon").hide();
                    alert(thrownError);
                }
            });
        }
        });
        $('#btnExportToExcel').click(function () {
            debugger;

            if ($("input[type='radio'].case").is(':checked')) {
                var selected_value = $("input[type='radio'].case:checked").val();

            }
            var empid = $("#txtempcode").val();
            $("#GoalSettingLoadingIcon").show();
            var url = "@Url.Action("ExportReport", "EmployeeAssignment")";
            $.ajax({
                url: url,
                data: { Empid: empid },
                type: "POST",
                datatype: "JSON",
                cache: false,
                success: function (response) {
                    if (response == "success") {
                       //  var url = "@Url.Action("GetEmployeeId", "EmployeeAssignment")" + "?EmpCode=" + ddlPractice;
                        window.location = "@Url.Action("GenerateResourceReleaseReport", "EmployeeAssignment")" + "?data=" + selected_value;
                        setTimeout(function () {
                            $("#btnExportToExcel").show();
                            //$("#btnProcessing").hide();
                        }, 10000);
                    }
                    else if (response == "Sessionexpired") {
                        window.location.href = '@Url.Action("SessionExpire", "Signout")';
                    }
                    else if (response == "Error") {
                        window.location.href = '@Url.Action("Error", "Error")';
                    }
                },
                error: function (error) {
                    alert(error.statusText);
                }
            });
        });

        function div_showAssignment() {

            var isValid = true;
            ClearModalData();
            var proCode = 0;
            var chekedValues = "";
            var id = $('input[name=chkRow]:checked').val();
            if ($('input[name=chkRow]').is(':checked')) {

                $("#tableBenchEmployees td").find("input[name='chkRow']:checked").each(function () {
                    chekedValues = $(this).val();
                    var empCode = $("#txtempcode").val();
                    $('#txtprojectcode').val(chekedValues);
                    var url = '@Url.Content("~/EmployeeAssignment/GetProjectCode")';
                    $.ajax({
                        url: url,
                        type: 'GET',
                        cache: false,
                        data: { assignmentid: chekedValues, empid: empCode },
                        success: function (data) {
                            $('#txtUtilization').val(data.Utilization);
                            $('#txtprojectcode').val(data.ProjectCode);
                            $('#txtassignmentid').val(chekedValues);
                            const decisionDate = data.ReleaseDate;
                            const d = new Date(decisionDate.match(/\d+/)[0] * 1);
                            var month = d.toLocaleString('default', { month: 'short' });
                            const formattedDate = ("0" + d.getDate()).slice(-2) + '-' + month + '-' + d.getFullYear()
                            $('#ExpectedEnd').val(formattedDate);
                            $('#ddlclientorproject').val(data.ClientorProject);
                            $('#txresonforrelease').val(data.ReasonForRelease);
                            $('#ddlresourceperformance').val(data.ResourcePerformance);
                            $('#txtskills').val(data.SkillsGoodAt);
                            $('#ddlProjectmovemnt').val(data.IsDiscResourceOnProject);
                           // $('#ddlProjectmovemnt').val(data.IsDiscResourceOnProject);
                            $('#txtfeedback').val(data.DetailedFeedBack);
                        },
                        error: function (thrownError) {
                            alert(thrownError);
                        }
                    });

                    if (isValid) {
                        $("#dialog-view-ProjectAutoAssignment").dialog({
                            title: 'Resource Release',
                            autoOpen: false,
                            resizable: false,
                            height: 400,
                            width: 565,
                            show: { effect: 'drop', direction: "up" },
                            modal: true,
                            draggable: true,
                            open: function (event, ui) {
                                $('.ui-dialog-titlebar-close').hide();
                            },
                            buttons: {
                                "Submit": function () {
                                    //$(this).dialog("submit");
                                    popup();
                                },
                                "Close": function () {
                                    $(this).dialog("close");
                                }
                            }
                            ,
                            close: function (event, ui) {
                                $(this).dialog('close');
                            },
                            submit: function (event, ui) {
                                //$(this).dialog('submit');
                                popup();
                            }
                        });
                        $("#dialog-view-ProjectAutoAssignment").dialog('open');
                        return false;
                    }

                });
            }
            else
            {
                //alert("Please select the Project you want to Release the Resource");
                bootbox.alert("Please Enter EmployeeId");      /*  observation*/
            }
         }

        function ValidateTextBox() {
            if (document.getElementById("SearchEmployee").value.trim() == "") {
                alert("Please enter Employee ID!");
                return false;
            }
        };

        function ValidateNumber(e) {
            var evt = (e) ? e : window.event;
            var charCode = (evt.keyCode) ? evt.keyCode : evt.which;
            if (charCode > 31 && (charCode < 48 || charCode > 57)) {
                return false;
            }
            return true;
        };

        $("#txtUtilization").on("change", function () {
            var val = parseInt(this.value);
            if (val >= 101) {
                alert('Wrong range Please select 1 to 100');
                this.value = '';
            }
        })
        function ClearModalData()
        {
            $("#ddlProjects").val("");
            $("#ddlResourceType").val("");
            $("#ExpectedStart").val("");
            $("#ExpectedEnd").val("");
            $("#txtUtilization").val("");
        }
        var nowDate = new Date();
        var today = new Date(nowDate.getFullYear(), nowDate.getMonth() - 12, nowDate.getDate(), 0, 0, 0, 0);
        var date2 = new Date();
        date2.setDate(date2.getDate() + 15);
       $('#datetimepicker1').datepicker({
            keyboardNavigation: false,
            forceParse: false,
            autoclose: true,
            todayHighlight: true,
            startDate: today,
            format: 'dd-M-yyyy'
        }).on('changeDate', function (e) {
            $(this).datepicker('hide');
        });

        $('#datetimepicker2').datepicker({
            keyboardNavigation: false,
            forceParse: false,
            autoclose: true,
            todayHighlight: true,
            startDate: date2,
            format: 'dd-M-yyyy'
        }).on('changeDate', function (e) {
            $(this).datepicker('hide');
        });

    </script>
