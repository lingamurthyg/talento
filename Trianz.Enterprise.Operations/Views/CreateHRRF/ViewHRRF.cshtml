        otherrole = document.getElementById('divOtherrole')
        otherrole.style.visibility = "hidden";

        var select = $("#RoleRequired");
        select.empty();
        if ( _Grade != "") {
            $.ajax({
                url: '@Url.Action("GetDesignations", "CreateHRRF")',
