    $(function () {
        $("#project").click(function (e) {
            e.preventDefault();
            $("#profile-v").hide();
            $("#messages-v").hide();
            $("#home-v").show();
        });
        $("#fulfilled").click(function (e) {
            e.preventDefault();
            $("#home-v").hide();
            $("#messages-v").hide();
            $("#profile-v").show();

        });

        $("#skillset").click(function (e) {
            e.preventDefault();
            $("#profile-v").hide();
            $("#home-v").hide();
            $("#messages-v").show();
        });
    });
</script>
<div id="dialog-view-ProjectAutoAssignment" style="display: none">
    <form class="form-horizontal" role="form" id="frmAutoAssignment">
        @Html.AntiForgeryToken()
        <div class="row">
            <div class="col-lg-10 form-group">
                <label class="col-lg-6 control-label">Cancel Reason<span style="color: red;">*</span></label>
                <div class="col-lg-6">
                    @Html.DropDownList("Cancel_Reason", new SelectList((System.Collections.IEnumerable)ViewData["_Cancel_ReasonList"]), "-- Select Cancel Reason --", new { @class = "form-control", @required = "required", @onchange = "CallChangefunc(this.value)", data_error = "Please select cancel reason" })
                    <div class="help-block with-errors error-msg-font-size"></div>
                    &nbsp;
                </div>
            </div>
        </div>
        <div class="row" id="divduplicatehrrfrow" style="display:none">
            <div class="col-lg-10 form-group">
                <label class="col-lg-6 control-label">Enter TRNo<span style="color: red;">*</span></label>
                <div class="col-lg-6">

                    <input type="text" class="form-control" name="duplicatehrrfno" id="duplicatehrrfno" onblur="ValidateHRRFNo();" />
                    &nbsp;
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-lg-10 form-group">
                <label class="col-lg-6 control-label">Enter Remarks<span style="color: red;">*</span></label>
                <div class="col-lg-6">
                    @Html.TextArea("Remarks", new { @class = "form-control", @required = "required", data_error = "Base location should not be blank" })
                    <div class="help-block with-errors error-msg-font-size"></div>
                    &nbsp;
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-lg-6 form-group">
                <label class="col-lg-6 control-label"></label>
                <div class="col-lg-6">
                    &nbsp;
                </div>
            </div>
            <div class="col-lg-6 form-group">
                <div class="col-lg-offset-5 col-lg-6">
                    <button type="button" id="submit" class="btn btn-primary btn-submit" onclick="cancel_submit()">Submit</button>
                </div>
            </div>
        </div>

    </form>
</div>
