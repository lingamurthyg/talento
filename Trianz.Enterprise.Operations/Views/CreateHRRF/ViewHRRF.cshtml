    function FillCompen(SkillID, comptencyControl, skilname, onselect) {
        var Skillname = "";
        if (comptencyControl != undefined)
            Skillname = skilname;
        else
            Skillname = $("#txtSkill").attr('value');

        $.ajax({
            url: "@(Url.Action("GetCompetencyList", "EmployeeSkills"))",
            type: "GET",
            dataType: "JSON",
            data: { Skillname: Skillname, flag: "" },
            success: function (data) {

                if (comptencyControl != undefined) {
                    //comptencyControl.html("");
                    comptencyControl.empty();
                    $.each(data, function (i, dt) {
                        comptencyControl.append($('<option></option>').val(dt.Value).html(dt.Key));
                    });

                }
                else {
                    $("#ddlComp").html("");
                    $("#ddlComp").append(('<option value="">Select Competency</option>'));//.val('').html("--Select Competency--"))// clear before appending new list
                    $.each(data, function (i, dt) {
                        $("#ddlComp").append($('<option></option>').val(dt.Value).html(dt.Key));
                    });
                }
                if (SkillID != 0) {
                    if (onselect != undefined)
                        comptencyControl.append(('<option value="0" selected="selected">Select Competency</option>'));
                    else
                        comptencyControl.val(SkillID.replace(' ', ''));
                }


            }
        });
    }
