    function cancel_submit(e) {
        //debugger
        var isValidCancel = Cancelvalidations();
        //debugger


        var cancel_reasontext = $('#Cancel_Reason').val();
        var duplicatehrrfno = $("#duplicatehrrfno").val();
        if (isValidCancel == true) {
            var item = confirm("Are You sure you want to cancel the TR");
            if (item == true) {
                var remarks = $('#Remarks').val();

                $.ajax({
                    url: '@Url.Action("TerminateTR", "ProposeAssociate")',
                    data: { remarks: remarks, cancel_reasontext: cancel_reasontext,duplicatehrrfno: duplicatehrrfno },
                    type: "post",
                    success: function (result) {


                        if(result==false){

                            bootbox.alert("Please try again");
                            return false;
                        }
                        else{
                            //need alert
                            alert("This TR has been Cancelled successfully.");

                            window.location.href = '@Url.Action("Index", "TRHome")'
                        }}
                });
                return false;
            }
            else {
                e.preventDefault();
                return false;
            }
        }
        else {
            //e.preventDefault();
            return false;
        }
    }
