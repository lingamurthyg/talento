    function onchangeSkillCode(skillCode) {
        var skillCluster = $("#SkillCluster").val();
        var _practice = $('#Practice').val();
        $('#lblSkillCode').text('');
        $('#HRRF_ClusterDesc').val('');
        $("#CLSTRJD").val('');
        if (skillCode != "" && skillCode!="NA") {
             $.ajax({
            url: '@Url.Action("GetSkillCode", "CreateHRRF")',
            data: { Practice: _practice, SkillCluster: skillCluster, SkillCode: skillCode },
            cache: false,
            type: "POST",
            success: function (data) {
                console.log(data)
                if (data != '' && data != null) {
                    document.getElementById('lblSkillCode').innerHTML = data.SkillCode;
                    document.getElementById('lblSkillCode').style.color = "blue";
                    document.getElementById('HRRF_ClusterDesc').value = data.ClusterDisc;
                    if (data.ClusterJD != '' && data.ClusterJD != null) {
                        $("#CLSTRJD").val(data.ClusterJD);
                    }
                } else {
                    $('#lblSkillCode').val('');
                }
            },
            error: function (reponse) {
                //alert(" " + "Please select SkillCluster");
            }
        });
        }

    }
