    $(function () {

        $('.Reject-case').on('click', function (e) {
            //  debugger;
            e.preventDefault();
            var tr = $(this).parents('tr:first');
            // id = $(this).prop('id');
            var _AppCode = tr.find('#AppCode')[0].innerText;
            var _AppId = tr.find('#AppId')[0].innerText;
            var url = this.href;
            var dialog = $("#dialog");
            if ($("#dialog").length == 0) {
                dialog = $('<div id="dialog" style="display:hidden"><div class="row" style="overflow:hidden;"><div class="col-md-1">&nbsp;&nbsp;&nbsp;</div><textarea id="txtremarks" required class="form-control" style="height: 80px;width:80%;"></textarea></div></div>').appendTo('body');
            }




            dialog.dialog({
                close: function (event, ui) {
                    dialog.remove();
                },
                modal: true,
                width: 400, resizable: false,
                height: 250,
                title: 'Please Enter Remarks',

                buttons: {
                    "Close": function () {
                        $(this).dialog("close");
                    },
                    "Ok": function () {

                        var remarks = $("#txtremarks").val();
                        $.ajax({
                            type: "POST",
                            data: { AppCode: _AppCode, AppId: _AppId, _Remarks: remarks },
                            url: '@Url.Action("RejectItem", "Notifications")',
                            success: function (result) {


                                $(this).dialog("close");



                            }
                        });
                        window.location.href = '@Url.Action("Mynotifications", "Notifications")';
                        $(this).dialog("close");

                    }
                }



            });

        });



        $('.Approve-case').on('click', function (e) {
            // debugger;

            e.preventDefault();
            var tr = $(this).parents('tr:first');
            // id = $(this).prop('id');
            var _AppCode = tr.find('#AppCode')[0].innerText;
            var _AppId = tr.find('#AppId')[0].innerText;

            var url = this.href;
            var dialog = $("#dialog");
            if ($("#dialog").length == 0) {
                dialog = $('<div id="dialog" style="display:hidden"><div class="row" style="overflow:hidden;"><div class="col-md-1">&nbsp;&nbsp;&nbsp;</div><textarea id="txtremarks" class="form-control" style="height: 80px;width:80%;"></textarea></div></div>').appendTo('body');
            }

            dialog.dialog({
                close: function (event, ui) {
                    dialog.remove();
                },
                modal: true,
                width: 400, resizable: false,
                height: 250,
                title: 'Please Enter Remarks',

                buttons: {
                    "Close": function () {
                        $(this).dialog("close");
                    },
                    "Ok": function () {
                        var remarks = $("#txtremarks").val();
                        $.ajax({
                            type: "POST",
                            data: { AppCode: _AppCode, AppId: _AppId, _Remarks: remarks },
                            url: '@Url.Action("AcceptItem", "Notifications")',
                            success: function (result) {


                                $(this).dialog("close");



                            }
                        });
                        window.location.href = '@Url.Action("Mynotifications", "Notifications")';
                        $(this).dialog("close");
                    }
                }



            });
            //    }
            //);
            //return false;
        });
    });
        </script>
