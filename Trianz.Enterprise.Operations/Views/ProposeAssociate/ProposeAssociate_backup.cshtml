        //Approve associates/Resources  -   PH
        function acceptProposeAssociate() {
            // Saving Propose Associates
            //if already exists show validation message to user in form of alert/viewbag
            //saving associates to proposeassociates table
            // alert('approve process intiated');
            var slvals = []
            $('input:radio[name=chkAssociateId]:checked').each(function () {
                slvals.push($(this).val())
            })
            //alert(slvals);
            //passing check items associate ids to controller
            if (slvals.length != 0) {
                $.ajax({
                    type: "POST",
                    data: { ProposedId: slvals, },
                    url: '@Url.Action("AcceptProposedResource", "ProposeAssociate")',
                    success: function (result) {
                        //debugger;
