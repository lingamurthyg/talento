@{
    var hrrfCreatedById = ViewBag.HRRFCreatedBy != null ? ViewBag.HRRFCreatedBy : 0;
    var showApprovalBtn = ViewBag.ShowApprovalButton != null ? ViewBag.ShowApprovalButton : false;
}

@{
    ViewBag.Title = "ProposedAssociates";
    //Layout = "~/Views/Shared/_Layout.cshtml";

    var acceptStatus = "";
    if (Model.ExternalFulfillments.Count() > 0)
    {
        foreach (var modelItemE in Model.ExternalFulfillments)
        {
            if (acceptStatus != null || acceptStatus != "")
            {
                acceptStatus = modelItemE.ApprovalStatus;
            }
        }
    }
}

@if (TempData["RequestStatus"] != null)
{
    if (TempData["RequestStatus"].ToString().ToLower() == "qualified")
    {
        <script>
            bootbox.alert("This TR has been qualified successfully.");
        </script>
    }
}
else if (TempData["Message"] != null)
{
    switch (TempData["Message"].ToString().ToLower())
    {
        case "acceptedexternal":
            <script>
                var prevPage = '@TempData["PrevPage"]';

                bootbox.alert({
                    message: "This TR has been accepted for external.",
                    callback: function () {
                        if (prevPage == '/') {
                            window.location.href = '@Url.Action("index", "trHome")';
                        }
                        else if (prevPage == 'mynotifications') {
                            window.location.href = '@Url.Action("mynotifications", "notifications")';
                        }
                    }
                });
            </script>
            break;
            @*case "rejectedexternal":
                <script>
                    bootbox.alert("This TR has been rejected for external.");
                </script>
                break;*@
    }


    @*if (TempData["Message"].ToString().ToLower() == "acceptedexternal")
        {
            <script>
                bootbox.alert("This TR has been accepted for external.");
            </script>
        }*@
}






@using (@Html.BeginForm("ProposeAssociate", "ProposeAssociate", FormMethod.Post))
{

    foreach (var items in Model.HRRFs)
    {
        <div class="container row">
            @if ((Session["Role"].ToString() == "RL"))
            {
                if (items.RequestStatus != "Cancelled")
                {
                    if (TempData["PrevPage"] != null && TempData["PrevPage"].ToString().ToLower() == "externalreport")
                    {

                        <div class="col-md-6 col-sm-12 nopadding-left">
                            <div class="col-md-4 col-sm-12 nopadding-left">
                                <button id="btnCreate" type="button" onclick="location.href='@Url.Action("Save", "ExternalReport", new { HrrfId = items.HRRFID, HrrfNumber = items.HRRFNumber })'" class="btn btn-primary pull-left">Update TR Status</button> @*Propose Candidates*@
                            </div>
                        </div>


                    }
                }
            }

            @foreach (var modelItem in Model.HRRFs)
            {

                if (modelItem.RequestStatus.ToLower() != "fulfilled" && modelItem.RequestStatus.ToLower() != "terminated" && modelItem.RequestStatus.ToLower() != "cancelled")
                {

                    if (Session["Role"].ToString() == "OM") // || (Session["Role"].ToString() == "RL" && ViewBag.CanEditByRL == true))
                    {

                        <button id="btnedit" type="button" class="btn btn-primary pull-left" onclick="location.href=' @Url.Action("ViewHRRF", "CreateHRRF", new { HRRFNumber = modelItem.HRRFNumber })'">Edit</button> }

                    else
                    {
                        if ((modelItem.RequestStatus.ToLower() == "draft" || modelItem.RequestStatus.ToLower() == "request more info") && modelItem.HRRFCreatedBy == (int)Session["EmployeeId"])
                        {

                            <button id="btnedit" type="button" class="btn btn-primary pull-left" onclick="location.href=' @Url.Action("ViewHRRF", "CreateHRRF", new { HRRFNumber = modelItem.HRRFNumber })'">Edit</button>}
                    }

                }

                if (Session["Role"].ToString() == "OM")
                {
                    if (modelItem.RequestStatus != "Fulfilled")
                    {
                        if (modelItem.RequestStatus != "Terminated")
                        {
                            if (modelItem.RequestStatus != "Cancelled")
                            {

                                <button type="button" id="btncancel" style="background-color: #0070C1;" onclick="cancel_TR()" class="btn btn-primary pull-left">Cancel</button>

                            }
                        }
                    }
                }
                else if (modelItem.RequestStatus == "Draft" && (Session["EmployeeId"].ToString() == hrrfCreatedById.ToString()))
                {

                    <button type="button" id="btncancel" style="background-color: #0070C1;" onclick="cancel_TR()" class="btn btn-primary pull-left"> Cancel</button>

                }



            }






            @if (items.RequestStatus.ToLower() != "fulfilled" && items.RequestStatus.ToLower() != "terminated" && items.RequestStatus.ToLower() != "cancelled" && items.RequestStatus.ToLower() != "draft" && items.RequestType != "External")
            {
                if (TempData["PrevPage"] != null && (Session["Role"].ToString() != "RL") && (Session["Role"].ToString() != "PM") && (Session["Role"].ToString() != "DH") && (Session["Role"].ToString() != "Admin") && (Session["Role"].ToString() != "SM"))
                {
                    <button id="btnHold" type="button" style="background-color: #0070C1;" onclick="funcChangeHoldStatus()" class="btn btn-primary pull-left">Hold</button>
                }
            }

            @if ((Session["Role"].ToString() == "OM"))
            {
                @*if (items.RequestStatus == "Submitted" || items.RequestStatus == "Hold")
                    {
                        if (TempData["PrevPage"] != null && TempData["PrevPage"].ToString().ToLower() != "externalreport")
                        {
                            <button id="btnHold" type="button" onclick="funcChangeHoldStatus()" class="btn btn-primary pull-left">Hold</button>
                        }
                    }*@
                //Following if condition is added to add "HOLD" button in case of a TR external
                if (items.RequestStatus.ToLower() != "fulfilled" && items.RequestStatus.ToLower() != "terminated" && items.RequestStatus.ToLower() != "cancelled" && items.RequestStatus.ToLower() != "draft" && items.RequestType == "External" && items.RequestStatus == "Pending For DH Approval")
                {
                    if (TempData["PrevPage"] != null)
                    {
                        <button id="btnHold" type="button" style="background-color: #0070C1;" onclick="funcChangeHoldStatus()" class="btn btn-primary pull-left">Hold</button>
                    }
                }

                if (items.RequestType == "External" && items.RequestStatus != "Fulfilled" && items.RequestStatus != "Cancelled" && items.RequestStatus.ToLower() != "terminated")
                {
                    if (TempData["PrevPage"] != null && TempData["PrevPage"].ToString().ToLower() == "externalreport")
                    {
                        <button id="btnCreate" type="button" style="background-color: #0070C1;margin-top: 8px;margin-left: 8px;height: 37px;" onclick="location.href='@Url.Action("Save", "ExternalReport", new { HrrfId = items.HRRFID, HrrfNumber = items.HRRFNumber })'" class="btn btn-primary pull-left">Update TR Status</button> @*Propose Candidates*@
                    }
                }
                if (items.RequestType == "External" && items.RequestStatus.ToLower() != "fulfilled" && items.RequestStatus.ToLower() != "terminated" && items.RequestStatus.ToLower() != "cancelled")
                {
                    <button id="btnConvert" type="button" value="Submit" style="background-color: #0070C1;" class="btn btn-primary pull-left">Convert to Internal</button>
                }
            }

            @if (ViewBag.IsButtonEnabled != null && Convert.ToBoolean(ViewBag.IsButtonEnabled))
            {
                <script>
                    $('#btnCreate').attr('disabled', 'disabled');
                </script>
            }
        </div>



        <div>

            <div class="col-md-12 col-sm-12 text-right nopadding-right" style="margin-top: -17px;">
                @* Qualify based on status *@

                @if (Session["Role"].ToString() != "" && (Session["Role"].ToString() == "OM" || Session["Role"].ToString() == "PM"))
                {
                    foreach (var modelItem1 in Model.HRRFs)
                    {
                        //Practice checking to disble buttons
                        if (Convert.ToBoolean(Session["IsPractice"]) == true)
                        {
                            if (modelItem1.RequestStatus == "Submitted")
                            {
                                if (Session["Role"].ToString() != "" && Session["Role"].ToString() != "PM")
                                {
                                    <button type="button" id="btnQualifyHRRF" name="btnQualifyHRRF" class="btn btn-primary" onclick="qualifyTR()" @*"location.href='@Url.Action("QualifyHRRF", "ProposeAssociate")'"*@>Qualify this TR</button>
                                    @*<button type="button" name="btnRequestForMoreInfo"  class="btn btn-primary">Request for More Info</button>*@
                                    <input type="button" class="btn btn-primary" id="btnRequestForMoreInfo" value="Request for More Info" />
                                }
                            }
                            else if (modelItem1.RequestStatus == "Qualified")
                            {

                                <button type="button" name="btnQualifyHRRF" style="display:none" class="btn btn-primary" onclick="location.href='@Url.Action("QualifyHRRF", "ProposeAssociate")'">Qualify this TR</button>
                                <button type="button" name="btnRequestForMoreInfo" style="display:none" onclick="location.href='@Url.Action("RequestForMoreInfo", "ProposeAssociate")'" class="btn btn-primary">Request for More Info</button>

                                if (modelItem1.RequestType != "External")
                                {
                                    if (Session["Role"].ToString() != "" && Session["Role"].ToString() != "PM")
                                    {
                                        if (string.IsNullOrEmpty(modelItem1.TECHPANEL) || string.IsNullOrWhiteSpace(modelItem1.SECONDTECHPANEL))
                                        //if (modelItem1.TECHPANEL == "" || modelItem1.SECONDTECHPANEL == "")
                                        {
                                            <button type="button" id="addtechvalue" name="addtechvalue" class="btn btn-primary" onclick="Add_TechPanel_Values()">Add Tech Panel Values</button>
                                        }
                                        <button type="button" id="btnExternalFulfillment" style="background-color:#0070C1;" name="btnExternal" class="btn btn-primary" onclick="funcConvertToExternalFulfillment();">Convert to External Fulfillment</button>
                                    }

                                }
                                else if (modelItem1.RequestType == "External")
                                {
                                    <button type="button" name="btnExternal" style="display:none" class="btn btn-primary" onclick="location.href='@Url.Action("ConvertHrrfToExternal", "ProposeAssociate")'">Convert to External Fulfilment</button>
                                }
                            }
                            else if (modelItem1.RequestStatus == "Hold")
                            {
                                if (Session["Role"].ToString() != "" && Session["Role"].ToString() != "PM")
                                {
                                    if (TempData["PrevPage"] != null && TempData["PrevPage"].ToString().ToLower() != "externalreport")
                                    {
                                        <button type="button" id="btnQualifyHRRF" name="btnQualifyHRRF" disabled="disabled" class="btn btn-primary">Qualify this TR</button>
                                        <input type="button" class="btn btn-primary" id="btnRequestForMoreInfo" disabled="disabled" value="Request for More Info" />
                                    }
                                }
                            }

                            else if (modelItem1.RequestStatus == "Fulfilled")
                            {
                                if (Session["Role"].ToString() != "" && Session["Role"].ToString() != "PM")
                                {
                                    if (TempData["PrevPage"] != null && TempData["PrevPage"].ToString().ToLower() != "externalreport")
                                    {
                                        if (modelItem1.RequestType == "External")
                                        {
                                            <br />
                                            <div style="text-align: left;right: 15px;position: relative; ">
                                                <button type="button" id="btnreopen" name="btnreopen" onclick="Reopen1()" class="btn btn-primary">ReOpen</button>
                                            </div>
                                            <br />
                                        }

                                    }
                                }
                            }
                        }
                    }
                }
            </div>
        </div>
        
        <div class="col-md-12 nopadding text-left">
            <div>
                @if ((Session["Role"].ToString() == "DH" && ViewBag.CanDHApprove) || showApprovalBtn) // || (Session["Role"].ToString() == "PM" && ViewBag.EmployeeID == (int)Session["EmployeeId"])
                {
                    foreach (var modelItem1 in Model.HRRFs)
                    {
                        if (modelItem1.RequestStatus.ToLower() == "pending for dh approval") //if (modelItem1.RequestStatus == "Qualified")
                        {
                            @* Proposed employees for accept/reject for -- PH *@
                            <div class="col-md-12 nopadding text-left">
                                <div id="gridContent" class="table">
                                    <div>
                                        @Html.Partial("_PartialProposeAssociate")
                                    </div>
                                </div>
                            </div>
                            <div class="clear-both"></div>
                        }

                        //buttons
                        if ((Session["Role"].ToString() == "DH" && ViewBag.CanDHApprove) || showApprovalBtn)
                        {
                            // pratice only can view accept/reject
                            //if (Convert.ToBoolean(Session["IsPractice"]) == true)
                            //{
                            if (modelItem1.RequestStatus != "Cancelled")
                            {
                                if (modelItem1.RequestType == "External")
                                {
                                    <div id="reject" class="col-md-2  text-right pull-right margin-right" style="bottom:56px;">
                                        <button type="button" id="btnRejectHrrf" name="btnRejectHrrf" class="btn btn-primary top-left" onclick="funcRejectExternalFulfillment();">Reject External Fulfillment</button>
                                    </div>
                                    <div id="accept" class="col-md-2  text-right pull-right margin-right" style="bottom:56px;">
                                        <button type="button" id="btnAcceptHrrf" name="btnAcceptHrrf" class="btn btn-primary top-left" onclick="location.href='@Url.Action("AcceptExternalHrrf", "ProposeAssociate")'">Accept External Fulfillment</button>
                                    </div>
                                    if (acceptStatus == "Accepted")
                                    {
                                        <script type="text/javascript">
                                            $('#btnAcceptHrrf, #btnRejectHrrf').attr('disabled', 'disabled');
                                        </script>
                                    }
                                }
                            }
                            //}
                        }
                    }
                }
                else if (ViewBag.EmployeeID == (int)Session["EmployeeId"])
                //Session["Role"].ToString() == "PM"
                {
                    foreach (var modelItem1 in Model.HRRFs)
                    {
                        if (modelItem1.RequestStatus.ToLower() == "pending for pm approval")
                        {
                            <div class="col-md-12 nopadding text-left">
                                <div id="gridContent" class="table">
                                    <div>
                                        @Html.Partial("_PartialProposeAssociate")
                                    </div>
                                </div>
                            </div>
                            <div class="clear-both"></div>
                        }
                    }
                }
                else if (Session["Role"].ToString() == "OM")
                {
                    foreach (var modelItem1 in Model.HRRFs)
                    {
                        if (modelItem1.RequestStatus.ToLower() == "pending for dh approval" || modelItem1.RequestStatus.ToLower() == "pending for pm approval")
                        {
                            <div class="col-md-12 nopadding text-left">
                                <div id="gridprosedContent" class="table">
                                    <div>
                                        <script>$("#searchbtn").css("display", "block");</script>
                                        @Html.Partial("_PartialProposedAssociate")
                                        @*@Html.Partial("_PartialProposeAssociate")*@
                                    </div>
                                </div>
                            </div>
                            <div class="clear-both"></div>
                        }
                    }
                }
            </div>
        </div>
    }


