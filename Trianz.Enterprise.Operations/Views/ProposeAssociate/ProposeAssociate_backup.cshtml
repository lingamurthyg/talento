<style>
    .input-group .form-control {
        position: relative;
        z-index: 2;
        float: left;
        width: 212px;
        margin-bottom: 0;
    }

    .ui-dialog .ui-dialog-content {
        position: relative;
        border: 0;
        padding: .5em 1em;
        background: none;
        overflow: auto;
        background-color: #f8f8f8;
    }

    body {
        overflow-x: hidden;
    }

    #txtRemarks {
        width: 550px;
    }

    .HRRF_custom .summary_list p label {
        margin-bottom: 0px;
        width: 415px;
    }

    .HRRF_custom table.p-resources thead th, .HRRF_custom table.p-resources tbody th, table.dataTable.nowrap th {
        background-color: #E1F3FF !important;
        color: black;
    }

        .HRRF_custom table.p-resources thead tr a, table.dataTable.nowrap th, table.dataTable.nowrap th a {
            color: black;
