                    {
                        window.location.href = '@Url.Action("Error","Error")';
                    }

                        else {
                            bootbox.alert("Selected proposed resource has been approved successfully.", function () {
                                window.location.href = '@Url.Action("ProposeAssociate", "ProposeAssociate")';
                            });
                        }
                    }
                });
            }
            else {
                bootbox.alert("Please select atleast one proposed resource.");
            }
