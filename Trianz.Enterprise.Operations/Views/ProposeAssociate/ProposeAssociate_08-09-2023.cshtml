        $(document).on("click", '#btnremark', function (e)
        {
            var remark = $('#txtTrremark').val();
            if (remark == "") {
                alert("please enter remark");

               event.preventDefault();
            }
            else
            {

                $.ajax({
                    type: 'POST',
                    datatype: 'JSON',
                    cache: false,
                    url: "@(Url.Action("SaveRemark", "ProposeAssociate"))",
                    data: { remark: remark },
                    async: false,
                    success: function (data) {
                        if (data == "true") {
                            //bootbox.alert("<span style='color:black'>remark  saved successfully.</span>");
                            $('#txtTrremark').val('');
                         alert('Remarks Saved Successfully.');
                         window.location.href = "@Url.Action("ProposeAssociate", "ProposeAssociate")";

