        foreach (var modelItemE in Model.ExternalFulfillments)
        {
            if (acceptStatus != null || acceptStatus != "")
            {
                acceptStatus = modelItemE.ApprovalStatus;
            }
        }
    }

    var trcount = 0;
    if (Model.HRRFRemarksinfo != null)
    {
        if (Model.HRRFRemarksinfo.Count() > 0)
        {

            trcount = Model.HRRFRemarksinfo.Count();
        }


    }
}

@if (TempData["RequestStatus"] != null)
{
    if (TempData["RequestStatus"].ToString().ToLower() == "qualified")
    {
        <script>
            bootbox.alert("This TR has been qualified successfully.");
        </script>
    }
}
else if (TempData["Message"] != null)
{
    switch (TempData["Message"].ToString().ToLower())
    {
        case "acceptedexternal":
            <script>
                var prevPage = '@TempData["PrevPage"]';

                bootbox.alert({
                    message: "This TR has been accepted for external.",
                    callback: function () {
                        if (prevPage == '/') {
                            window.location.href = '@Url.Action("index", "trHome")';
                        }
                        else if (prevPage == 'mynotifications') {
                            window.location.href = '@Url.Action("mynotifications", "notifications")';
                        }
                    }
                });
            </script>
            break;
            @*case "rejectedexternal":
                <script>
                    bootbox.alert("This TR has been rejected for external.");
                </script>
                break;*@
    }


    @*if (TempData["Message"].ToString().ToLower() == "acceptedexternal")
        {
            <script>
                bootbox.alert("This TR has been accepted for external.");
            </script>
        }*@
}

@using (@Html.BeginForm("ProposeAssociate", "ProposeAssociate", FormMethod.Post))
{

    foreach (var items in Model.HRRFs)
    {
       
        


            <div class="container row" style="background-color: #F3F4F9;right: 3px;position: relative;max-width: 100%;height: 74px;width: 100%;">
                @if ((Session["Role"].ToString() == "RL"))
                {
                    if (items.RequestStatus != "Cancelled")
                    {
                        if (TempData["PrevPage"] != null && TempData["PrevPage"].ToString().ToLower() == "externalreport")
                        {

                            <div class="col-md-6 col-sm-12 nopadding-left">
                                <div class="col-md-4 col-sm-12 nopadding-left">
                                    <button id="btnCreate" type="button" onclick="location.href='@Url.Action("Save", "ExternalReport", new { HrrfId = items.HRRFID, HrrfNumber = items.HRRFNumber })'" class="btn btn-primary pull-left">Update TR Status</button> @*Propose Candidates*@
                                </div>
                            </div>


                        }
                    }
                }

                @foreach (var modelItem in Model.HRRFs)
                {

                    if (modelItem.RequestStatus.ToLower() != "fulfilled" && modelItem.RequestStatus.ToLower() != "terminated" && modelItem.RequestStatus.ToLower() != "cancelled")
                    {

                        if (Session["Role"].ToString() == "OM") // || (Session["Role"].ToString() == "RL" && ViewBag.CanEditByRL == true))
                        {

                            <button id="btnedit" type="button" style="background-color: #ffffff;color: #004BBB;position: relative;top: 20px;" class="btn btn-primary pull-left" onclick="location.href=' @Url.Action("ViewHRRF", "CreateHRRF", new { HRRFNumber = modelItem.HRRFNumber })'"> <img src="~/Content/images/editimg.png" style="width: 11px;" /> Edit</button>
                        }


                        else
                        {
                            if ((modelItem.RequestStatus.ToLower() == "draft" || modelItem.RequestStatus.ToLower() == "request more info") && modelItem.HRRFCreatedBy == (int)Session["EmployeeId"])
                            {

                                <button id="btnedit" type="button" style="background-color: #ffffff;color: #004BBB;position: relative;top: 20px;" class="btn btn-primary pull-left" onclick="location.href=' @Url.Action("ViewHRRF", "CreateHRRF", new { HRRFNumber = modelItem.HRRFNumber })'">  <img src="~/Content/images/editimg.png" style="width: 11px;" /> Edit</button>}
                        }



                    }

                    if (Session["Role"].ToString() == "OM")
                    {
                        if (modelItem.RequestStatus != "Fulfilled")
                        {
                            if (modelItem.RequestStatus != "Terminated")
                            {
                                if (modelItem.RequestStatus != "Cancelled")
                                {

                                    <button type="button" id="btncancel" style="background-color: #ffffff;color: #004BBB;position: relative;bottom: 7px;" onclick="cancel_TR()" class="btn btn-primary pull-left">
                                        <img src="~/Content/images/Cancelimg.png" style="width: 12px; position: relative; bottom: 1px;" />

                                        Cancel
                                    </button>

                                }
                            }
                        }
                    }
                    else if (modelItem.RequestStatus == "Draft" && (Session["EmployeeId"].ToString() == hrrfCreatedById.ToString()))
                    {

                        <button type="button" id="btncancel" style="background-color: #ffffff;color: #004BBB;position: relative;bottom: 7px;" onclick="cancel_TR()" class="btn btn-primary pull-left">
                            <img src="~/Content/images/Cancelimg.png" style="width: 12px; position: relative; bottom: 1px;" />

                            Cancel

                        </button>

                    }



                }

                @if (items.RequestStatus.ToLower() != "fulfilled" && items.RequestStatus.ToLower() != "terminated" && items.RequestStatus.ToLower() != "cancelled" && items.RequestStatus.ToLower() != "draft" && items.RequestType != "External")
                {
                    if (TempData["PrevPage"] != null && (Session["Role"].ToString() != "RL") && (Session["Role"].ToString() != "PM") && (Session["Role"].ToString() != "DH") && (Session["Role"].ToString() != "Admin") && (Session["Role"].ToString() != "SM"))
                    {
                        <button id="btnHold" type="button" style="background-color: #ffffff;color: #004BBB;margin-top: 1px;width: 83px;" onclick="funcChangeHoldStatus()" class="btn btn-primary pull-left">

                            <img src="~/Content/images/holdimg.png" style="width: 10px;" />
                            Hold
                        </button>
                    }
                }

                @if ((Session["Role"].ToString() == "OM"))
                {
                    @*if (items.RequestStatus == "Submitted" || items.RequestStatus == "Hold")
                        {
                            if (TempData["PrevPage"] != null && TempData["PrevPage"].ToString().ToLower() != "externalreport")
                            {
                                <button id="btnHold" type="button" onclick="funcChangeHoldStatus()" class="btn btn-primary pull-left">Hold</button>
                            }
                        }*@


                    //Following if condition is added to add "HOLD" button in case of a TR external
                    if (items.RequestStatus.ToLower() != "fulfilled" && items.RequestStatus.ToLower() != "terminated" && items.RequestStatus.ToLower() != "cancelled" && items.RequestStatus.ToLower() != "draft" && items.RequestType == "External" && items.RequestStatus == "Pending For DH Approval")
                    {
                        if (TempData["PrevPage"] != null)
                        {
                            <button id="btnHold" type="button" style="background-color: #ffffff;color: #004BBB;margin-top: 1px;width: 83px;" onclick="funcChangeHoldStatus()" class="btn btn-primary pull-left">
                                <img src="~/Content/images/holdimg.png" style="width: 10px;" />
                                Hold
                            </button>
                        }

                    }


                    if (items.RequestType == "External" && items.RequestStatus != "Fulfilled" && items.RequestStatus != "Cancelled" && items.RequestStatus.ToLower() != "terminated")
                    {
                        if (TempData["PrevPage"] != null && TempData["PrevPage"].ToString().ToLower() == "externalreport")
                        {
                            <button id="btnCreate" type="button" style="background-color: #ffffff;margin-top: 1px;margin-left: 10px;height: 37px;color: #004BBB;" onclick="location.href='@Url.Action("Save", "ExternalReport", new { HrrfId = items.HRRFID, HrrfNumber = items.HRRFNumber })'" class="btn btn-primary pull-left">Update TR Status</button> @*Propose Candidates*@
                        }
                    }
                    if (items.RequestType == "External" && items.RequestStatus.ToLower() != "fulfilled" && items.RequestStatus.ToLower() != "terminated" && items.RequestStatus.ToLower() != "cancelled")
                    {
                        <button id="btnConvert" type="button" value="Submit" style="background-color: #ffffff;color: #004BBB;position: relative;bottom:7px;" class="btn btn-primary pull-left">
                            <img src="~/Content/images/convertimg.png" style="width: 13px;position: relative;bottom: 1px;" />

                            Convert to Internal
                        </button>
                    }

                    @*<img src="~/Content/images/convertinternalimg.png" style="position: relative;top: 8px;right: 172px;width: 11px;" />*@
                }

                @if (ViewBag.IsButtonEnabled != null && Convert.ToBoolean(ViewBag.IsButtonEnabled))
                {
                    <script>
                        $('#btnCreate').attr('disabled', 'disabled');
                    </script>
                }
            </div>

        

        <div>

            <div class="col-md-12 col-sm-12 text-right nopadding-right" style="margin-top: -17px;">
                @* Qualify based on status *@

                @if (Session["Role"].ToString() != "" && (Session["Role"].ToString() == "OM" || Session["Role"].ToString() == "PM"))
                {
                    foreach (var modelItem1 in Model.HRRFs)
                    {
                        //Practice checking to disble buttons
                        if (Convert.ToBoolean(Session["IsPractice"]) == true)
                        {
                            if (modelItem1.RequestStatus == "Submitted")
                            {
                                if (Session["Role"].ToString() != "" && Session["Role"].ToString() != "PM")
                                {
                                    <button type="button" id="btnQualifyHRRF" name="btnQualifyHRRF" class="btn btn-primary" onclick="qualifyTR()" @*"location.href='@Url.Action("QualifyHRRF", "ProposeAssociate")'"*@ style="position: relative;bottom: 53px;background-color: #ffffff; color: #004BBB;">
                                        <img src="~/Content/images/qualifyimg.png" style="width: 11px;position: relative;bottom: 2px" />
                                        Qualify this TR
                                    </button>
                                    @*<button type="button" name="btnRequestForMoreInfo"  class="btn btn-primary">Request for More Info</button>*@

                                    @*<input type="button" class="btn btn-primary" id="btnRequestForMoreInfo" value="Request for More Info" style="position: relative;right: 129px;bottom: 53px;background-color: #ffffff;color: #004BBB;" />*@


                                    <button type="button" id="btnRequestForMoreInfo" name="btnRequestForMoreInfo" class="btn btn-primary" @*"location.href='@Url.Action("QualifyHRRF", "ProposeAssociate")'"*@ style="position: relative;bottom: 53px;background-color: #ffffff; color: #004BBB;">
                                        <img src="~/Content/images/moreinfoimg.png" style="width: 13px;position: relative;bottom: 1px;" />

                                        Request for More Info
                                    </button>
                                }
                            }
                            else if (modelItem1.RequestStatus == "Qualified")
                            {

                                <button type="button" name="btnQualifyHRRF" style="display:none" class="btn btn-primary" onclick="location.href='@Url.Action("QualifyHRRF", "ProposeAssociate")'">
                                    <img src="~/Content/images/qualifyimg.png" style="width: 11px;" />
                                    Qualify this TR
                                </button>
                                <button type="button" name="btnRequestForMoreInfo" style="display:none" onclick="location.href='@Url.Action("RequestForMoreInfo", "ProposeAssociate")'" class="btn btn-primary">
                                    <img src="~/Content/images/moreinfoimg.png" style="width: 11px;" />

                                    Request for More Info
                                </button>

                                if (modelItem1.RequestType != "External")
                                {
                                    if (Session["Role"].ToString() != "" && Session["Role"].ToString() != "PM")
                                    {
                                        if (string.IsNullOrEmpty(modelItem1.TECHPANEL) || string.IsNullOrWhiteSpace(modelItem1.SECONDTECHPANEL))
