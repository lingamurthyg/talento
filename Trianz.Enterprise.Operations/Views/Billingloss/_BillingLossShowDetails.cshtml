<html>
<head>
    <title></title>
    <script src="~/Scripts/amcharts.js"></script>

    <script src="~/Scripts/pie.js"></script>
    <script src="~/Scripts/light.js"></script>


    <style>
        .table.table-bordered.dataTable th, table.table-bordered.dataTable td {
