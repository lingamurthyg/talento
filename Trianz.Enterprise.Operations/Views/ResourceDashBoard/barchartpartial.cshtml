          @(Html.JQChart()
                .Chart(Model)
                .ID("barchart")
                .Width(500)
                .Height(300)
                .Title("Practice Level Demand View")
     .Background(background => background.LinearGradient(0, 0, 0, 1).ColorStops(stop =>
     {
         stop.Add(0, "#d2e6c9");
         stop.Add(1, "white");
     }))
                .Animation(TimeSpan.FromSeconds(1))
                .Shadows(true)
                .Series(series =>
                {
                    series.Column()
                          .Title("Demand")
                          .FillStyle("#418CF0")
                          .XValues(el => el.Label)
                          .YValues(el => el.Value1);


                    series.Line().Title("Bench")
                                .XValues(el => el.Label)
                                .YValues(el => el.Value2);
                }
                )
                .Render()
          )
 
       
   
   
