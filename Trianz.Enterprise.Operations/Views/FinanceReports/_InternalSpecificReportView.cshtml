@model IEnumerable<Trianz.Enterprise.Operations.ViewModel.FinanceInternalspecificDetails>
<div id="Internalspcreportdiv" class="col-md-12">
    <table id="InternalspcReport" class="table table-striped table-bordered" cellspacing="0" style="margin: 0px; width: 100%;">
        <thead>
            <tr style="background-color: #248CC8 !important; color: #fff; font-size: 12px;">
                <th>EmployeeID</th>
                <th>EmployeeName</th>
                <th>Work Location</th>
                <th>Employee Type</th>
                <th>Grade</th>
                <th>DOJ</th>
                <th>Relieving Date</th>
                <th>Client Name</th>
                <th>Business Group</th>
                <th>Project Code</th>
                <th>Project name</th>
                <th>Roll on Date</th>
                <th>HC</th>
                <th>Aging</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr style="font-size: 12px;">
                    <td>@item.EmployeeID</td>
                    <td>@item.EmployeeName</td>
                    <td>@item.Worklocation</td>
                    <td>@item.EmployeeType</td>
                    <td>@item.Grade</td>
                    <td>@(item.DOJ == null ? "" : item.DOJ.Value.ToString("MM/dd/yyyy").Replace("-", "/"))</td>
                    <td>@(item.RelievingDate == null ? "" : item.RelievingDate.Value.ToString("MM/dd/yyyy").Replace("-", "/"))</td>
                    <td>@item.ClientName</td>
                    <td>@item.BusinessGroup</td>
                    <td>@item.ProjectCode</td>
                    <td>@item.ProjectName</td>
                    <td>@(item.StartDate == null ? "" : item.StartDate.Value.ToString("MM/dd/yyyy").Replace("-", "/"))</td>
                    <td>@item.HC</td>
                    <td>@item.Aging</td>
                </tr>
            }
            @*else
                {
                    <tr>
                        <td colspan="5">
                            <div class="text-center">No data available</div>
                        </td>
                    </tr>
                }*@
        </tbody>
    </table>
</div>



