@*@model List<Trianz.Enterprise.Operations.Models.BenchResourceStatusReport>*@


<style>
    th, td {
        border-spacing: 0;
    }

    .HRRF_custom table tr th {
        padding: 5px;
        color: #ffffff;
        background-color: #D6DCE3 !important;
    }

    body {
        overflow-x: hidden;
    }

    .HRRF_custom table tr th {
        padding: 5px;
        color: black;
        background-color: #D6DCE3 !important;
    }

    .questionlogo1 {
        margin-left: 476px;
        margin-top: -9px;
    }

    .onlinebtn {
        margin-left: 434px;
        position: relative;
        top: 26px;
    }
</style>





<table id="tableEmpSkillsReport" class="table table-striped table-bordered dt-responsive nowrap" cellspacing="0" style="margin: 10px;
    width: 98%;
    position: relative;
    top: 13px;">

    <thead>
        <tr style="background-color: #D6DCE3  !important; color: black; font-size: 12px;">

            <th cellspacing="0" style="padding-left:10px">Employee Name</th>
            <th cellspacing="0">Employee ID</th>
            <th>Grade</th>
            <th>Project Code</th>
            <th>Bench Category</th>
            <th>Actual Start Date</th>
            <th style="padding-right:20px">Start Date</th>
            <th style="padding-right:20px">End Date</th>
            <th>Current Date</th>
            <th>No of Working Days</th>
            <th>Utilization(%)</th>
            <th>Total Hours</th>
            <th>Total Cost</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in ViewBag.projectList1)
        {
            <tr style="font-size: 12px;">
                <td>@item.EMPLOYEENAME</td>
                <td>@item.EMPLOYEEID</td>
                <td>@item.GRADE</td>
                <td>@item.PROJECTCODE</td>
                <td>@item.CATEGORY</td>
                @{
                    DateTime ACTUALSTARTDATE = Convert.ToDateTime(@item.ACTUALSTARTDATE);
                    <td>@ACTUALSTARTDATE.ToString("dd-MMM-yyyy")</td>
                    DateTime STARTDATE = Convert.ToDateTime(@item.STARTDATE);
                    <td>@STARTDATE.ToString("dd-MMM-yyyy")</td>
                    DateTime ENDDATE = Convert.ToDateTime(@item.ENDDATE);
                    <td>@ENDDATE.ToString("dd-MMM-yyyy")</td>
                    DateTime CURRENTDATE = Convert.ToDateTime(@item.CURRENTDATE);
                    <td>@CURRENTDATE.ToString("dd-MMM-yyyy")</td>
                }
                <td><p style="text-align:right;">@item.TOTALDAYS</p></td>
                <td><p style="text-align:right;">@item.UTILIZATION</p></td>
                <td><p style="text-align:right;">@item.TOTALHOURS</p></td>
                <td><p style="text-align:right;">@item.TOTALCOST</p></td>
            </tr>
        }
    </tbody>
</table>


