<style>


    body {
        overflow-x: hidden;
    }

    .questionlogo1 {
        margin-left: 476px;
        margin-top: -9px;
    }

    .onlinebtn {
        margin-left: 434px;
        position: relative;
        top: 26px;
    }
</style>
<b  id="txt" style="position: relative;left: 10px;top: 3px;">BENCH RESOURCE SUMMARY</b>
&nbsp;
<table id="tableEmpSkillsReport2" class="table table-striped table-bordered dt-responsive nowrap" cellspacing="0" style="    margin: 11px;
    width: 98%;
    position: relative;
    top: 13px;">
    <thead>
        <tr style="background-color: #D6DCE3   !important; color: #fff; font-size: 12px;">
            <th>Project Code</th>
            <th>Project Name</th>

            <th>Start Date</th>
            <th>End Date</th>
            <th>Deployable</th>
            <th>Non-Deployable</th>
            <th>Reserved</th>
            <th style="text-align:right">Total Head Count</th>

            <th>Total Work Days</th>
            <th>Total Hours</th>
            <th>Total Cost</th>
        </tr>

    </thead>
    <tbody>
        @foreach (var item in ViewBag.projectList)
        {

            <tr style="font-size: 12px;">

                <td>@item.PROJECTCODE</td>
                <td>@item.PROJECTNAME</td>

                @*<td>@item.STARTDATE</td>

        <td>@item.ENDDATE</td>*@
                @{
                    //dd MMM yyyy
                    DateTime STARTDATE = Convert.ToDateTime(@item.STARTDATE);
                    <td>@STARTDATE.ToString("dd-MMM-yyyy")</td>
                    DateTime ENDDATE = Convert.ToDateTime(@item.ENDDATE);
                    <td>@ENDDATE.ToString("dd-MMM-yyyy")</td>
                }
                <td><p style="text-align:right;">@item.DEPLOYABLECOUNT</p></td>
                <td><p style="text-align:right;">@item.NONDEPLOYABLECOUNT</p></td>
                <td><p style="text-align:right;">@item.RESERVEDCOUNT</p></td>
                <td><p style="text-align:right;">@item.HEADCOUNT</p></td>
                <td><p style="text-align:right;">@item.TOTALDAYS</p></td>
                <td><p style="text-align:right;">@item.TOTALHOURS</p></td>
                <td><p style="text-align:right;">@item.TOTALCOST</p></td>
            </tr>
        }
    <tr style="font-size: 14px; ">
        <td>Grand Total</td>
        <td></td>
        <td></td>
        <td></td>
        <td></td>
        <td></td>
        <td></td>
        <td><p style="text-align:right;">@ViewBag.TotalHeadCount</p></td>
        <td><p style="text-align:right;">@ViewBag.TotalBenchDays</p></td>
        <td><p style="text-align:right;">@ViewBag.TotalBenchHours</p></td>
        <td><p style="text-align:right;">@ViewBag.TotalBenchCost</p></td>
    </tr>
    </tbody>
</table>
<br />

<b id="txt" style="position:relative;  left: 10px;
    top: 6px;">BENCH RESOURCE LIST</b>





