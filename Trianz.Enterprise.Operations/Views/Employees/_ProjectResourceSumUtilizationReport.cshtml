<style>
    .HRRF_custom table.p-resources thead th, .HRRF_custom table.p-resources tbody th, table.dataTable.nowrap th {
        background-color: #D6DCE3 !important;
        color: black;
    }
    .table.table-bordered.dataTable th, table.table-bordered.dataTable td {
        border-left-width: 0;
        color: rgb(0, 0, 0);
        font-size: 12px;
    }

    body {
        overflow-x: hidden;
    }

    .questionlogo1 {
        margin-left: 476px;
        margin-top: -9px;
    }

    .onlinebtn {
        margin-left: 434px;
        position: relative;
        top: 26px;
    }
    /*#tableEmpSkillsReport2 {
       background-color: #D6DCE3 !important; 
       color: #fff;
       font-size: 12px;
    }*/
    .Empname {
        position: relative;
        bottom: 44px;
        left: 95px;
    }
</style>
<b style="position: relative;margin-left: 12px;">PROJECT INFO</b>
&nbsp;
<table id="tableEmpSkillsReport2" class="table table-striped table-bordered dt-responsive nowrap" cellspacing="0" style="margin: 1px;width: 98%;margin-left: 12px;">
    <thead>
        <tr style="background-color: #D6DCE3 !important; color: #fff; font-size: 12px;">
            <th>Project Code</th>
            <th>Project Name</th>
            <th>Billing Status</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th style="text-align:right">Head Count</th>

            <th>Total Working Days</th>
            <th>Total Working Hours</th>

        </tr>

    </thead>
    <tbody>
        @foreach (var item in ViewBag.projectList)
        {

        <tr style="font-size: 12px;">

            <td>@item.PROJECTCODE</td>
            <td>@item.PROJECTNAME</td>
            <td>@item.BILLINGSTATUS</td>
            @*<td>@item.STARTDATE</td>

        <td>@item.ENDDATE</td>*@
            @{
                DateTime STARTDATE = Convert.ToDateTime(@item.STARTDATE);
                <td>@STARTDATE.ToString("dd-MMM-yyyy")</td>
                DateTime ENDDATE = Convert.ToDateTime(@item.ENDDATE);
                <td>@ENDDATE.ToString("dd-MMM-yyyy")</td>
            }
            <td><p style="text-align:right;">@item.HEADCOUNT</p></td>
            <td><p style="text-align:right;">@item.TOTALWORKINGDAYS</p></td>
            <td><p style="text-align:right;">@item.TOTALWORKINGHOURS</p></td>

        </tr>
        }
    </tbody>
</table>
<br />
&nbsp;
<b style="color:#2C2E31; margin-left: 6px;">EMPLOYEE INFO</b>




