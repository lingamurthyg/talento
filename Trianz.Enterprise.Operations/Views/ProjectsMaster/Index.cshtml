<link href="~/Content/dataTables.bootstrap.css" rel="stylesheet">
<script type="text/javascript" language="javascript" src="https://cdn.datatables.net/1.10.11/js/jquery.dataTables.min.js"></script>
<script type="text/javascript" language="javascript" src="https://cdn.datatables.net/1.10.11/js/dataTables.bootstrap.min.js"></script>

<div id="divGridContent1" class="table table-responsive" style="margin-bottom: 0px;overflow-x:hidden;color:#000000">
    <table id="tableBenchEmployees" class="table table-striped table-bordered" cellspacing="0" style="margin: 0px; width: 100%;">
        <thead>
            <tr id="theadcolour">
                <th style="width:164px;font-size:12px;">Account Name</th>
                <th style="width:89px;font-size:12px;">Project Code</th>
                <th style="width:181px;font-size:12px;">Project Name</th>
                <th style="width:150px;font-size:12px;">SOW Start Date</th>
                <th style="width:150px;font-size:12px;">SOW End Date</th>
                <th style="width:164px;font-size:12px;">Project Manager</th>
                <th style="width:90px;font-size:12px;">Billing Type</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null)
            {
                foreach (var item in Model)
                {
                    <tr style="font-size: 12px;">
                        <td>@item.AccountName</td>
                        <td>@item.ProjectCode</td>
                        <td>@item.ProjectName</td>
                        <td>@(item.SOWStartDate == null ? "" : @Convert.ToDateTime(item.SOWStartDate).ToString("dd-MMM-yyyy"))</td>
                        <td>@(item.SOWEndDate == null ? "" : @Convert.ToDateTime(item.SOWEndDate).ToString("dd-MMM-yyyy"))</td>
                        <td>@item.ProjectManager</td>
                        <td>@item.BillingType</td>
                    </tr>
                }
            }
        </tbody>

    </table>

</div>


<script type="text/javascript">
    $(document).ready(function () {
        $("#btnProcessing").hide();
        $('#tableBenchEmployees').DataTable({});
    });

        $('#btnExportToExcel').click(function () {
                //$(this).hide();
                $("#btnProcessing").show();

                $.ajax({
                    url: "@Url.Action("ExportReport", "ProjectsMaster")",
                    data: "",
                    type: "POST",
                    datatype: "JSON",
                    cache: false,
                    success: function (response) {
                        if (response == "success") {
                            window.location = "@Url.Action("GenerateProjectInfo", "ProjectsMaster")";

                            setTimeout(function () {
                                $("#btnExportToExcel").show();
                                $("#btnProcessing").hide();
                            }, 10000);
                        }
                        else if (response == "Sessionexpired") {
                                window.location.href = '@Url.Action("SessionExpire", "Signout")';
                        }
                        else if (response == "Error") {
                                window.location.href = '@Url.Action("Error", "Error")';
                            }
                    },
                    error: function (error) {
                        alert(error.statusText);
                    }
                });
            });
</script>





