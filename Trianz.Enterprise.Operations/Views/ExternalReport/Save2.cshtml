<script type="text/javascript">
    $(function () {
        var nowDate = new Date();
        var today = new Date(nowDate.getFullYear(), nowDate.getMonth(), nowDate.getDate(), 0, 0, 0, 0);

        $('#datetimepicker1').datepicker({
            keyboardNavigation: false,
            forceParse: false,
            autoclose: true,
            startDate: today,
            todayHighlight: true
        }).on('changeDate', function (e) {
            $(this).datepicker('hide');
        });
        $('#datetimepicker2').datepicker({
            keyboardNavigation: false,
            forceParse: false,
            autoclose: true,
            startDate: today,
            todayHighlight: true
            //format: 'dd/mm/yyyy',
        }).on('changeDate', function (e) {
            $(this).datepicker('hide');
        });
        $('#datetimepicker3').datepicker({
            keyboardNavigation: false,
            forceParse: false,
            autoclose: true,
            startDate: today,
            todayHighlight: true
        }).on('changeDate', function (e) {
            $(this).datepicker('hide');
        });



    });
    function toggleChevron(e) {
        $(e.target)
            .prev('.panel-heading')
            .find("i.indicator")
            .toggleClass('glyphicon-chevron-down glyphicon-chevron-up');
    }

    $(function () {
        $('#accordion').on('hidden.bs.collapse', toggleChevron);
        $('#accordion').on('shown.bs.collapse', toggleChevron);
    });
    function CancellationRemarksChange(event) {
        if (event == "Duplicate")
            $("#divDuplicateHrrf").show();
        else
            $("#divDuplicateHrrf").hide();
    }


    

    function ValidateHRRFNo() {
        var dupHrrfNo = $("#txtDuplicateHrrfNumber").val();
        if (dupHrrfNo != "") {
            $.ajax({
                url: '@Url.Action("ValidateHRRFNo", "ExternalReport")',
                data: { duplicatehrrfno: dupHrrfNo },
                type: "POST",
                success: function (result) {

                    if (result == "false") {

                        bootbox.alert("Please enter correct  hrrf no");
                        $("#txtDuplicateHrrfNumber").val('');

                    }
                    else if (result == "Sessionexpired") {
                    window.location.href = '@Url.Action("SessionExpire", "Signout")';
                    }
                     else if (result == "Error")
                    {
                        window.location.href = '@Url.Action("Error","Error")';
                    }

                }
            });
            return true;
        }
    }
</script>

