    function GrayoutFields() {
        //  debugger
        var RequestStatus = $('#ddlRequestStatus').val()
        DivCancel = document.getElementById('DivCancel')


        //$("#datetimepicker1").find(".input-group-addon").css("pointer-events", "none");
        $("#datetimepicker1").find("#DOJ").val("");
        $('#txtEmpId').val("");

        if (RequestStatus == "Cancelled") {
            DivCancel.style.visibility = "visible";
            Divdatetimepicker3.style.visibility = "visible";
        }
        else {
            DivCancel.style.visibility = "hidden";
            Divdatetimepicker3.style.visibility = "hidden";
        }
        empid = document.getElementById('EmpId')
        if (RequestStatus == "Fulfilled") {
            empid.style.visibility = "visible";
            $("#datetimepicker1").find(".input-group-addon").css("pointer-events", "none");
            $("#datetimepicker1").find("#DOJ").attr("disabled", true);

        }
        else {
            empid.style.visibility = "hidden";
            $("#datetimepicker1").find(".input-group-addon").css("pointer-events", "visible");
            $("#datetimepicker1").find("#DOJ").attr("disabled", false);
        }
        if (RequestStatus.toLowerCase() == "yet to join") {
            DOJSign.style.visibility = "visible";
        }
        else {
            DOJSign.style.visibility = "hidden";
        }

    }
