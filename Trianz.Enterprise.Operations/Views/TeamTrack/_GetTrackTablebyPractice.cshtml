                                        <option value="1">Select Track</option>
                                        @foreach (SelectListItem opt in ViewBag.AnalyticsTracks)
                                        {
                                            <option value="@opt.Text" @(opt.Text == "DW/ Data Information Architecture" ? "selected='selected'" : "")>@opt.Text</option>
                                        }
                                    </select>
                                }
                                else
