                                        <option value="1">Select Track</option>
                                        @foreach (SelectListItem opt in ViewBag.ImsTracks)
                                        {
                                            <option value="@opt.Text" @(opt.Text == "Service Now" ? "selected='selected'" : "")>@opt.Text</option>
                                        }
                                    </select>
                                }
                                else
