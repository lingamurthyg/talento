                                        <option value="1">Select Track</option>


                                        @foreach (SelectListItem opt in ViewBag.AnalyticsTracks)
                                        {

                                            <option value="@opt.Text" @(opt.Text == item.Track ? "selected='selected'" : "")>@opt.Text</option>

                                        }
                                    </select>
                                }
                            }


                            else if (item.Practice == "IMS")
                            {
                                if (item.Track == null || item.Track == "")
                                {
