@model IEnumerable<Trianz.Enterprise.Operations.Models.DemandData>


    @using JQChart.Web.Mvc
    @{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "DemandTrend";
    
    }
<div class="subpage_header page-header nomargin-top">
    <p>Demand DashBoard</p>
</div>

    <!DOCTYPE HTML>
    <html>
    <head>
        <title></title>
        <link rel="stylesheet" type="text/css" href="~/Content/jquery.jqChart.css" />
        <link rel="stylesheet" type="text/css" href="~/Content/jquery.jqRangeSlider.css" />
        <link rel="stylesheet" type="text/css" href="~/Content/themes/le-frog/jquery-ui-1.8.20.css" />

        <script src="@Url.Content(" ~ />Scripts/jquery.mousewheel.js")" type="text/javascript"></script>
        <script src="@Url.Content(" ~ />Scripts/jquery.jqChart.min.js")" type="text/javascript"></script>
        <script src="@Url.Content(" ~ />Scripts/jquery.jqRangeSlider.min.js")" type="text/javascript"></script>
        <!--[if IE]><script lang="javascript" type="text/javascript" src="@Url.Content("~/Scripts/excanvas.js")"></script><![endif]-->
    </head>
    <body>
        <div>

            <table class="table">

                <tr>
                    <td>
                        @(Html.JQChart()
                .Chart(Model)
                .ID("barchart")
                .Width(500)
                .Height(400)
                .Title("Monthly Wise Demand View")
     .Background(background => background.LinearGradient(0, 0, 0, 1).ColorStops(stop =>
     {
         stop.Add(0, "#d2e6c9");
         stop.Add(1, "white");
     }))
                .Animation(TimeSpan.FromSeconds(1))
                .Shadows(true)
                .Series(series =>
                {
                    series.Column()
                          .Title("Demands Submitted")
                          .FillStyle("#418CF0")
                          .XValues(el => el.Label)
                          .YValues(el => el.Value1);
                    series.Column()
                          .Title("Demands Draft")
                          .FillStyle("#FCB441")
                          .XValues(el => el.Label)
                          .YValues(el => el.Value2);
                    series.Column()
                          .Title("Demands Qualified")
                          .FillStyle("#056492")
                          .XValues(el => el.Label)
                          .YValues(el => el.Value3);
                    series.Column()
                         .Title("Demands Fullfilled")
                         .FillStyle("#E0400A")
                         .XValues(el => el.Label)
                         .YValues(el => el.Value4);
                    //series.Column()
                    //      .Title("Demands Draft")
                    //      .FillStyle("#056492")
                    //      .XValues(el => el.Label)
                    //      .YValues(el => el.Value4);


                }
                )
                .Render()
                        )


                    </td>
                    <td>
                        @Html.Partial("CurrentDemandOverview", TempData["DemandTrend"])

                        @*@(Html.JQChart()
                        .Chart(Model)
                        .ID("barchart")
                        .Width(500)
                        .Height(300)
                        .Title("Practice Level Demand View")
                        .Legend(legend => legend.Title("Parameters"))
                        .Animation(TimeSpan.FromSeconds(1))
                        .Shadows(true)
                        .Series(series =>
                        {
                        series.Column()
                        .Title("Series 1")
                        .XValues(el => el.Label)
                        .YValues(el => el.Value1)
                        .FillStyles(new object[] { "#418CF0", "#FCB441", "#E0400A", "#056492", "#BFBFBF", "#1A3B69", "#FFE382" });
                        }
                        )
                        .Render())*@

                       

                    </td>
                </tr>

            </table>


        </div>

        

        <script lang="javascript" type="text/javascript">

        $(document).ready(function () {
          //  debugger;
            $('#jqChart').bind('tooltipFormat', function (e, data) {
                var percentage = data.series.getPercentage(data.value);
                percentage = data.chart.stringFormat(percentage, '%.2f%%');

                return '<b>' + data.dataItem[0] + '</b><br />' +
                           data.value + ' (' + percentage + ')';
            });


        });

        </script>
    </body>
</html>



