        function split(val) {
            return val.split(/,\s*/);
        }
        function extractLast(term) {
            return split(term).pop();
        }
        $("#Searchskill").autocomplete({
                source: function (request, response) {
                    var Skill = new Array();
                    $.ajax({
                        async: false,
                        cache: false,
                        type: "POST",
                        url: "@(Url.Action("GetSkillsListByCompetency", "EmployeeSkills"))",
                        data: { skill: extractLast(request.term), flag: "" }, //cmptny: $("#txtCompetency").attr('value'),
                        success: function (data) {
                            if (data != null && data != "Sessionexpired" && data != "Error") {


                                for (var i = 0; i < data.length; i++) {
                                    Skill[i] = { label: data[i].Key, Id: data[i].Value };
                                }
                            }
                            else if (data == "Sessionexpired") {
                                window.location.href = '@Url.Action("SessionExpire", "Signout")';
                            }
                            else if (data == "Error") {
                                window.location.href = '@Url.Action("Error","Error")';
                            }
                        }
                    });

                    response(Skill);

                },
                select: function (event, ui) {
                    var terms = split(this.value);
                    // remove the current input
                    terms.pop();
                    // add the selected item
                    terms.push(ui.item.value);
                    // add placeholder to get the comma-and-space at the end
                    terms.push("");
                    this.value = terms.join(", ");
                    return false;
                }
            });
    });
