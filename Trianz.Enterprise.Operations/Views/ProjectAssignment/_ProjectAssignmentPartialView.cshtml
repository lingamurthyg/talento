
@model Trianz.Enterprise.Operations.Models.ValidationModel
<style>
    .HRRF_custom table tr th {
        color: black;
    }   
</style>
<style>
    div.dataTables_wrapper div.dataTables_paginate {
        margin: 0 -20px;
        white-space: nowrap;
        text-align: right;
    }
</style>
<div style="overflow:auto;padding:0 20px 0 0">
    <table id="tableassig" class="table table-striped table-bordered" cellspacing="0" style="margin-left:18px; width: 96%;">
        <thead>
            <tr style="background-color: #D6DCE3 !important; color: black; font-size: 12px;">
                @if (Session["Role"].ToString() == "OM")
                {
                    <th class="text-center"></th>
                }
                    <th style="width:15px">Emp Code</th>
                    <th style="width:30px;"> Emp Name</th>
                    <th>Project Name</th>
                    <th>Code</th>
                    <th>Assigned By</th>
                    <th>(%)</th>
                    <th>Start Date </th>
                    <th>End Date</th>
                    <th>
                        Billing Type
                        
                    </th>
                    <th>
                        Billing Status
                        
                    </th>
                    <th>
                        Practice
                       
                    </th>
                    <th>
                        Is Active
                      
                    </th>
                @*<th>Assignment Status</th>*@

            </tr>
        </thead>
        <tbody>
            @if (Model != null)
            {
                foreach (var item in Model.ProjectAssignments)
                {
                    <tr style="font-size: 12px;">
                        @if (Session["Role"].ToString() == "OM")
                        {
                            <td class="text-center">
                                <input type="button" class="btn btn-link" value="Edit" id="@item.Assignment_Id" />
                                <label id="EmployeeID" style="display:none;">@item.EmployeeId</label>
                                <label id="Assignmentid" style="display:none;">@item.Assignment_Id</label>
                                <label id="projectName" style="display:none;">@item.ProjectCode</label>
                            </td>
                        }
                        <td>@item.EmployeeId</td>
                        <td><label id="lblemplname">@item.EmployeeName</label></td>
                        <td>
                            <label id="lblprojectnamegr">@item.ProjectName</label>
                            <label id="lblprjectid" style="display:none;">@item.ProjectID</label>
                        </td>
                        <td>@item.ProjectCode</td>
                        <td><label id="lblassby">@item.Assigned_By</label></td>
                        <td><label id="lblut">@item.Utilisation</label></td>
                        <td><span id="StartDate" class="display-mode">@(item.StartDate == null ? "" : @Convert.ToDateTime(item.StartDate).ToString("dd-MMM-yyyy"))</span></td>
                        <td><span id="EndDate" class="display-mode">@(item.EndDate == null ? "" : @Convert.ToDateTime(item.EndDate).ToString("dd-MMM-yyyy"))</span></td>
                        <td><span id="Name" class="display-mode">@item.BillingType</span></td>
                        <td><span id="bilngsta" class="display-mode">@item.BillingStatus</span></td>
                        <td><span id="lblprac" class="display-mode">@item.Practice</span></td>
                        <td>

                            @if (item.IsActive == true)
                            {
                                <span id="lblisactive" class="display-mode">
                                    Active
                                </span>
                            }
                            else if (Convert.ToDateTime(item.StartDate).Date > DateTime.Now.Date)
                            {
                                <span id="lblisactive" class="display-mode">
                                    Not Yet Started
                                </span>
                            }
                            else
                            {
                                <span id="lblisactive" class="display-mode">
                                    Completed
                                </span>
                            }

                            <span id="AssignmentStatus" style="display:none;">@item.AssignmentStatus</span>
                        </td>
                        @*<td></td>*@

                    </tr>
                }
            }

        </tbody>
    </table>
</div>
<hr />

<script type="text/javascript">
    $(document).ready(function () {
        $('#tableassig').DataTable({
            //    "aoColumns": [
            //        { "bSortable": false },
            //        null,
            //        null,
            //        null
            //    ],
            //    "order": [
            //        [2, "asc"]
            //    ]
        });

    });
</script>