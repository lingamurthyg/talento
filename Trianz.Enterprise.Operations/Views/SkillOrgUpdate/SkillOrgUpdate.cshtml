            $("#GoalSettingLoadingIcon").show();
            var url = "@Url.Action("ExportReport", "EmployeeAssignment")";
            $.ajax({
                url: url,
                data: { Empid: empid },
                type: "POST",
                datatype: "JSON",
                cache: false,
                success: function (response) {
                    if (response == "success") {
                       //  var url = "@Url.Action("GetEmployeeId", "EmployeeAssignment")" + "?EmpCode=" + ddlPractice;
                        window.location = "@Url.Action("GenerateResourceReleaseReport", "EmployeeAssignment")" + "?data=" + selected_value;
                        setTimeout(function () {
                            $("#btnExportToExcel").show();
                            //$("#btnProcessing").hide();
                        }, 10000);
                    }
                    else if (response == "Sessionexpired") {
                        window.location.href = '@Url.Action("SessionExpire", "Signout")';
                    }
                    else if (response == "Error") {
                        window.location.href = '@Url.Action("Error", "Error")';
                    }
                },
                error: function (error) {
                    alert(error.statusText);
                }
            });
        });

        function div_showAssignment() {

            var isValid = true;
            ClearModalData();
            var proCode = 0;
            var chekedValues = "";
            var id = $('input[name=chkRow]:checked').val();
            if ($('input[name=chkRow]').is(':checked')) {

                $("#tableBenchEmployees td").find("input[name='chkRow']:checked").each(function () {
                    chekedValues = $(this).val();
                    var empCode = $("#txtempcode").val();
                    $('#txtprojectcode').val(chekedValues);
                    var url = '@Url.Content("~/EmployeeAssignment/GetProjectCode")';
                    $.ajax({
                        url: url,
                        type: 'GET',
                        cache: false,
                        data: { assignmentid: chekedValues, empid: empCode },
                        success: function (data) {
                            if (data != null && data != "Sessionexpired") {
                                $('#txtUtilization').val(data.Utilization);
                                $('#txtprojectcode').val(data.ProjectCode);
                                $('#txtassignmentid').val(chekedValues);
                                const decisionDate = data.ReleaseDate;
                                const d = new Date(decisionDate.match(/\d+/)[0] * 1);
                                var month = d.toLocaleString('default', { month: 'short' });
                                const formattedDate = ("0" + d.getDate()).slice(-2) + '-' + month + '-' + d.getFullYear()
                                $('#ExpectedEnd').val(formattedDate);
                                $('#ddlclientorproject').val(data.ClientorProject);
                                $('#txresonforrelease').val(data.ReasonForRelease);
                                $('#ddlresourceperformance').val(data.ResourcePerformance);
                                $('#txtskills').val(data.SkillsGoodAt);
                                $('#ddlProjectmovemnt').val(data.IsDiscResourceOnProject);
                                // $('#ddlProjectmovemnt').val(data.IsDiscResourceOnProject);
                                $('#txtfeedback').val(data.DetailedFeedBack);
                            }
                            else if (data == "Sessionexpired")
                            {
                                window.location.href = '@Url.Action("SessionExpire", "Signout")';
                            }
                            else if (data == "Error")
                            {
                                window.location.href = '@Url.Action("Error","Error")';
                            }
                        },
                        error: function (thrownError) {
                            alert(thrownError);
                        }
                    });

                    if (isValid) {
                        $("#dialog-view-ProjectAutoAssignment").dialog({
                            title: 'Resource Release',
                            autoOpen: false,
                            resizable: false,
                            height: 400,
                            width: 565,
                            show: { effect: 'drop', direction: "up" },
                            modal: true,
                            draggable: true,
                            open: function (event, ui) {
                                $('.ui-dialog-titlebar-close').hide();
                            },
                            buttons: {
                                "Submit": function () {
                                    //$(this).dialog("submit");
                                    popup();
                                },
                                "Close": function () {
                                    $(this).dialog("close");
                                }
                            }
                            ,
                            close: function (event, ui) {
                                $(this).dialog('close');
                            },
                            submit: function (event, ui) {
                                //$(this).dialog('submit');
                                popup();
                            }
                        });
                        $("#dialog-view-ProjectAutoAssignment").dialog('open');
                        return false;
                    }

                });
            }
            else
            {
                //alert("Please select the Project you want to Release the Resource");
                bootbox.alert("Please Enter EmployeeId");      /*  observation*/
            }
         }

        function ValidateTextBox() {
            if (document.getElementById("SearchEmployee").value.trim() == "") {
                alert("Please enter Employee ID!");
                return false;
            }
        };

        function ValidateNumber(e) {
            var evt = (e) ? e : window.event;
            var charCode = (evt.keyCode) ? evt.keyCode : evt.which;
            if (charCode > 31 && (charCode < 48 || charCode > 57)) {
                return false;
            }
            return true;
        };

        $("#txtUtilization").on("change", function () {
            var val = parseInt(this.value);
            if (val >= 101) {
                alert('Wrong range Please select 1 to 100');
                this.value = '';
            }
        })
        function ClearModalData()
        {
            $("#ddlProjects").val("");
            $("#ddlResourceType").val("");
            $("#ExpectedStart").val("");
            $("#ExpectedEnd").val("");
            $("#txtUtilization").val("");
        }
        var nowDate = new Date();
        var today = new Date(nowDate.getFullYear(), nowDate.getMonth() - 12, nowDate.getDate(), 0, 0, 0, 0);
        var date2 = new Date();
        date2.setDate(date2.getDate() + 15);
       $('#datetimepicker1').datepicker({
            keyboardNavigation: false,
            forceParse: false,
            autoclose: true,
            todayHighlight: true,
            startDate: today,
            format: 'dd-M-yyyy'
        }).on('changeDate', function (e) {
            $(this).datepicker('hide');
        });

        $('#datetimepicker2').datepicker({
            keyboardNavigation: false,
            forceParse: false,
            autoclose: true,
            todayHighlight: true,
            startDate: date2,
            format: 'dd-M-yyyy'
        }).on('changeDate', function (e) {
            $(this).datepicker('hide');
        });

    </script>
