    <script type="text/javascript">

        //$(document).ready(function () {
        //       $("#txtempid").hide();
        //});
        var jsonarray = [];
        $("#GoalSettingLoadingIcon").hide();
     /*   $("#txtempid").hide();*/

        $("#btnSearch").click(function () {
            var txttrnumber = $("#SearchTRNumber").val();
            if (txttrnumber == "") {
                bootbox.alert("Please enter TR Number");
            }
            else
            {
            $("#GoalSettingLoadingIcon").show();

                var url = "@Url.Action("SkillOrgUpdatedetails", "SkillOrgUpdate")"; /*+ "?TRNumber=" + txttrnumber;*/
            $.ajax({
                url: url,
                type: 'GET',
                cache: false,
                data: { TRNumber: txttrnumber },
                success: function (result) {
                    //alert(JSON.stringify(result));
                    //alert("Success");
                    if (result != null) {
                        if (result != null && result != "Sessionexpired") {
                            $('#txtPractice').val(result.Practice);
                            $('#txtPurpose').val(result.Purpose);
                            $('#txtSkillCode').val(result.SkillCode);
                            $('#txtOrganizationGroup').val(result.OrganizationGroup);
                            $('#txtRaisedBy').val(result.ResourceName);

                            $('#txtempid').val(result.HRRFCreatedBy);
                            $('#txtorgsubgroupo').val(result.Organization_SubGroup);
                            $('#txtSkillCode_WIP').val(result.SkillCode_WIP);
                            $('#txtskills').val(result.skill);
                            $('#txtAgeing').val(result.Ageing);
                            $('#Criticality').val(result.Criticality);

                            $('#RecruiterName').val(result.recruiter);
                            $('#leadName').val(result.lead);

                            //  $('#txtSubmiteddate').val(data.HRRFSubmitedDate.Date("dd/MM/yyyy"));

                            //  $('#txtSubmiteddate').val(Convert.ToDateTime(result.HRRFSubmitedDate).ToString("dd-MMM-yyyy"));
                            $('#txtSubmiteddate').val(result.hrrfdate);

                        }
                        else if (response == "Error") {
                            window.location.href = '@Url.Action("Error", "Error")';
                        }
                        else if (response == "Sessionexpired") {
                            window.location.href = '@Url.Action("SessionExpire", "Signout")';
                        }
                    }
                },
                error: function (thrownError) {
                    console.log(thrownError);
                    $("#GoalSettingLoadingIcon").hide();
                    alert("error object");
                    alert(thrownError);
                }
            });
        }
        });
        $("#Criticality").change(function () {

            var Criticality = $("#Criticality").val();
        });

           function updateorgsubgroupdata() {

