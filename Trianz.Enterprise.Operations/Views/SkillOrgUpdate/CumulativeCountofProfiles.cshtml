@model Trianz.Enterprise.Operations.Models.BenchAssignment


@{
    ViewBag.Title = "SkillOrgUpdate";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="~/Content/Footer2.css" rel="stylesheet" />
<link href="~/Content/Talento5.css" rel="stylesheet" />
<link href="~/Content/LayoutHeader.css" rel="stylesheet" />
<style>
    .form-control {
        width: 60%;
        margin-left: 2px;
    }

    .ui-dialog .ui-dialog-content {
        position: relative;
        border: 0;
        padding: .5em 1em;
        background: none;
        overflow: auto;
        background-color: #FFFFFF;
    }

    .ui-widget-content {
        margin-left: 20px;
        background: #FFFFFF;
        border: 1px solid #FFF;
    }
   
    .ui-dialog .ui-dialog-titlebar.ui-widget-header.ui-corner-all.ui-helper-clearfix .ui-dialog-title {
        color: #2C2E31;
        font-size: 15px;
    }

    .ui-dialog .ui-dialog-titlebar.ui-widget-header.ui-corner-all.ui-helper-clearfix {
        background-color: #FFFFFF;
        border-color: #FFFFFF;
        background-image: none;
        border-radius: 0px !important;
    }

    body {
        overflow-x: hidden;
    }

    #txt {
        color: #2C2E31;
        font-size: 15px;
        margin-left: 18px;
    }

    td, th {
        color: black;
        color: rgb(0, 0, 0);
    }

    #btnSearch {
        margin: -33px -48px 27px 34px;
        background-color: #004BBB;
        border: none !important;
        outline: none;
        outline-offset: 0px;
    }

    .request_header {
        background: #fff;
        border-bottom: 1px solid #EAECF2;
        position: relative;
        top: 60px;
        margin-bottom: 60px;
    }
</style>
<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Index</title>
</head>
<body>

    <link href="~/Content/dataTables.bootstrap.css" rel="stylesheet">
    <script type="text/javascript" language="javascript" src="https://cdn.datatables.net/1.10.11/js/jquery.dataTables.min.js"></script>
    <script type="text/javascript" language="javascript" src="https://cdn.datatables.net/1.10.11/js/dataTables.bootstrap.min.js"></script> 
    <div> 
        <div>
            <table id="tableBenchEmployees" class="table table-striped table-bordered" cellspacing="0" style="margin-left:-6px; width: 93%;position: relative;bottom:-48px;">
                <thead>
                    <tr id="a" style="background-color:#D3D4D9 !important; color: black; font-size: 12px;">
                        <th>TR Number</th>
                        <th>Profiles</th>
                        <th>L1</th>
                        <th>L2</th>
                        <th>HR</th>
                        <th>Pending Interviews</th>
                        <th>Recruiter Name</th>
                        <th>TA Lead Name</th>
                       
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null)
                    {
                        foreach (var item in Model.ProfilesInfoList)
                        {
                            <tr style="font-size: 12px;">
                                <td id="lblprjctcodeiid">@item.HRRFNumber</td>
                                <td id="lblprjctcodeiid">@item.Profiles</td>
                                <td id="lblprojetname">@item.L1</td>
                                <td id="lblbillingstatus">@item.L2</td>
                                <td id="lblorggroup">@item.HR</td>
                                <td id="lblorgsubgroup">@item.PendingInterviews</td>
                                <td id="lblorggroup">@item.RecruiterName</td>
                                <td id="lblorgsubgroup">@item.TAleadName</td>
                              
                            </tr>
                        }
                    }

                    else
                    {
                        <tr>
                            <td colspan="8">
                                <div class="text-center">No data found</div>
                            </td>
                        </tr>
                    }


                </tbody>
            </table>
        </div>
    </div>
    <script type="text/javascript">       
    </script>
    <script>
        $(document).ready(function () {          
         
        });
    </script>

</body>
</html>

