             // $("#txtempid").hide();

           //   $("#ExpectedEnd").val(date2)
      //  });
            var jsonarray = [];
            $("#GoalSettingLoadingIcon").hide();
        
        //$('#datetimepicker2').datepicker({
        //    keyboardNavigation: false,
        //    forceParse: false,
        //    autoclose: true,
        //    todayHighlight: true,
        //    startDate: date2,
        //    endDate: date2,
        //    format: 'dd-M-yyyy'
        //}).on('changeDate', function (e) {
        //    $(this).datepicker('hide');
