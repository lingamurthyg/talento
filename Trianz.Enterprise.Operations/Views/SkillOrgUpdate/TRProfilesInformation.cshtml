<style>
    label{
       margin:4px;
    }
    .display {
        display: flex;
    }
    .form-control {
        width: 60%;
        margin-left: 2px;
    }

    .ui-dialog .ui-dialog-content {
        position: relative;
        border: 0;
        padding: .5em 1em;
        background: none;
        overflow: auto;
        background-color: #FFFFFF;
    }

    .ui-widget-content {
        margin-left: 20px;
        background: #FFFFFF;
        border: 1px solid #FFF;
    }
    /*.ui-button-text-only .ui-button-text {
        padding: 0.6em 1em;
        background-color: #004BBB;
        color: #FFFFFF;
    }*/
    .ui-dialog .ui-dialog-titlebar.ui-widget-header.ui-corner-all.ui-helper-clearfix .ui-dialog-title {
        color: #2C2E31;
        font-size: 15px;
    }

    .ui-dialog .ui-dialog-titlebar.ui-widget-header.ui-corner-all.ui-helper-clearfix {
        background-color: #FFFFFF;
        border-color: #FFFFFF;
        background-image: none;
        border-radius: 0px !important;
    }

    body {
        overflow-x: hidden;
    }

    #txt {
        color: #2C2E31;
        font-size: 15px;
        margin-left: 18px;
    }

    td, th {
        color: black;
        color: rgb(0, 0, 0);
    }

    #btnSearch {
        margin: -33px -48px 27px 34px;
        background-color: #004BBB;
        border: none !important;
        outline: none;
        outline-offset: 0px;
    }

    .request_header {
        background: #fff;
        border-bottom: 1px solid #EAECF2;
        position: relative;
        top: 60px;
        margin-bottom: 60px;
    }
</style>
<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
