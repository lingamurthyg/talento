            //    startDate: date2,
            //    format: 'dd-M-yyyy'}).on('changeDate', function (e) {
            //    $(this).datepicker('hide');
            //    });

            $("#btnSearch2").click(function () {
                $("#GoalSettingLoadingIcon").show();
                var txttrnumber = $("#SearchTRNumber").val();             
                if (txttrnumber == "")
                {
                    bootbox.alert("Please enter TR Number");
                }
                else
                {
                    window.location = "@Url.Action("GetTRProfilesInfobyHRRFNumber", "SkillOrgUpdate")" + "?HrrfNumber=" + txttrnumber;
                }
            });

            function SaveProfilesData() {
                var trnumber = $("#SearchTRNumber").val();             
                if (trnumber == "") {
                    bootbox.alert("Please enter TR Number");
                }
                var txtpofiles = $("#txtProfiles").val();
                    var l1det = $("#txtL1").val();
                    var l2det = $("#txtL2").val();
                    var hrdet = $("#txtHR").val();
                    var pendInter = $("#txtPendingInterviews").val();
                    var expctedDate = $("#ExpectedEnd").val();
                var profiledata =
                {
                    HRRFNumber: trnumber,
                    Profiles: txtpofiles,
                    L1: l1det,
                    L2: l2det,
                    HR: hrdet,
                    PendingInterviews: pendInter,
                    ProfilesDate: expctedDate
                }
                $.ajax({
                    type: "POST",                   
                    url: '@Url.Action("SaveTRProfilesInformation", "SkillOrgUpdate")',
                    data: JSON.stringify(profiledata),
                    contentType: "application/json; charset=utf-8",
                    dataType: "json",
                    success: function (data) {
                            if (data != null && data != "Sessionexpired")
                            {                             
                                alert('Data Saved Successfully');
                                window.location = "@Url.Action("GetTRProfilesInfobyHRRFNumber", "SkillOrgUpdate")" + "?HrrfNumber=" + trnumber;                            
                            }
                            else if (data == "Sessionexpired")
                            {
                                window.location.href = '@Url.Action("SessionExpire", "Signout")';
                            }
                            else if (data == "Error")
                            {
                               window.location.href = '@Url.Action("Error", "Error")';
                            }
                        },
                        error: function (thrownError) {
                            alert(thrownError);
                        }
                    });
            };
        
                    function chkvalidationforskill()
        {
                    var ischk = true;
                    var expectedenddate = $("#ExpectedEnd").val();
                    var clientorproject = $("#ddlclientorproject").val();
                    var reasonforrelease = $("#txresonforrelease").val();
                    var skillname = $("#txtskills").val();
                    var feedback = $("#txtfeedback").val();
                    var performance = $("#ddlresourceperformance").val();
                    var projectmovement = $("#ddlProjectmovemnt").val();
                    if (expectedenddate == "") {
                    bootbox.alert("Please enter Release Date");
                    ischk = false;
                    }
                    else if (clientorproject == "") {
                    bootbox.alert("Please select Client/Project");
                    ischk = false;
                    }
                    else if (skillname == "") {
                    bootbox.alert("Please enter Skills");
                    ischk = false;
                    }
                    else if (feedback == "") {
                    bootbox.alert("Please enter feedback");
                    ischk = false;
                    }
                    else if (reasonforrelease == "") {
                    bootbox.alert("Please Enter reason for release");
                    ischk = false;
                    }
                    else if (performance == "") {
                    bootbox.alert("Please select Resource Performance");
                    ischk = false;
                    }
                    else if (projectmovement == "") {
                    bootbox.alert("Please select  Is discusion with project movement");
                    ischk = false;
                    }
                    return ischk;
                    }
        
                    function GetEmployeeId(EmpCode) {
                    $("#GoalSettingLoadingIcon").show();
                    window.location = "@Url.Action("GetEmployeeInfoData", "EmployeeAssignment")" + "?EmpCode=" + EmpCode;
                    };      
        
                   

    </script>
