    label {
        color: #2C2E31;
    }

    .HRRF_custom .control-label {
        text-align: right;
        position: relative;
        left: 44px;
    }

    .btn-primary {
        color: #fff;
        background-color: #004BBB;
        border-color: #2e6da4;
    }

    .request_header {
        background: #FFFFFF;
        margin: 30px 0px 0px -22px;
        border-bottom: 1px solid #EAECF2;
