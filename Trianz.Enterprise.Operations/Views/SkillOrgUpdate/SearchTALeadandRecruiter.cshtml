@{
    ViewBag.Title = "SearchTALeadandRecruiter";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    body {
        overflow-x: hidden;
    }

    div.dataTables_wrapper div.dataTables_filter {
        text-align: right;
        margin-left: 350px;
    }

