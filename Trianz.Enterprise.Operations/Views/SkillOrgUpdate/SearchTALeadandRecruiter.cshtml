</style>
@{
    var Recordcount = 0;
    if (Model.RecruiterLedlst != null)
    {
        if (Model.RecruiterLedlst.Count() > 0)
        {

            Recordcount = Model.RecruiterLedlst.Count();
        }

    }
}
<div class="request_header">
    <div id="divbtun" class="row">
        <div class="row" style="padding: 40px;">
            <div class="col-sm-4">
                 <label>Recruiter Name</label>
                @Html.DropDownList("recruiterName", ViewData["_RecruiterName"] as SelectList, "Select Recruiter Name", new { style = "height: 32px;width:200px;margin: 0px 12px;" })
                @if (Session["EmployeeId"].ToString() == "103422" || Session["EmployeeId"].ToString() == "102342"
                || Session["EmployeeId"].ToString() == "102536" || Session["EmployeeId"].ToString() == "103857"
                || Session["EmployeeId"].ToString() == "104209" || Session["EmployeeId"].ToString() == "103212" || Session["EmployeeId"].ToString() == "105009" || Session["EmployeeId"].ToString() == "105977")
                {
                    <script>
                        $('#recruiterName').removeAttr('disabled');
                    </script>
                }
            </div>
            <div class="col-sm-4">
                <span>
                    <label>Lead Name</label>
                    @Html.DropDownList("leadName", ViewData["_LeadName"] as SelectList, "Select lead Name", new { style = "height: 32px;width:200px;margin: 0px 12px;" })
                    @if (Session["EmployeeId"].ToString() == "103422" || Session["EmployeeId"].ToString() == "102342"
                    || Session["EmployeeId"].ToString() == "102536" || Session["EmployeeId"].ToString() == "103857"
                    || Session["EmployeeId"].ToString() == "104209" || Session["EmployeeId"].ToString() == "103212" || Session["EmployeeId"].ToString() == "105009" || Session["EmployeeId"].ToString() == "105977")
                    {
                        <script>
                            $('#leadName').removeAttr('disabled');
                        </script>
                    }
                </span>
            </div>
        </div>
    </div>
    <div id="serchlead">
        <table id="tblSearchtaRecruiter" class="table table-striped table-bordered" cellspacing="0" style="margin-left:28px; width: 95%">
            <thead>
                <tr id="a" style="background-color:#D3D4D9 !important; color: black; font-size: 12px;">
                    <th style="width:15px">TR #</th>
                    <th style="width:30px;">Criticality</th>
                    <th>Account Name</th>
                    <th>Purpose</th>
                    <th>Practice</th>
                    <th>Skill </th>
                    <th>Skill Code</th>
                    <th>Ageing</th>
                    <th>Recruiter Name</th>
                    <th>TA Lead Name</th>
                </tr>
            </thead>

            <tbody>
                @if (Model != null)
                {
                    @*@if (Recordcount > 0)
                {*@
                    foreach (var item in Model.RecruiterLedlst)
                    {
                        <tr style="font-size: 12px;">
                            <td>@item.HRRFNumber</td>
                            <td>@item.Criticality</td>
                            <td>@item.AccountName</td>
                            <td>@item.Purpose</td>
                            <td>@item.Practice</td>
                            <td>@item.Skill</td>
                            <td>@item.SkillCode</td>
                            <td>@item.Ageing</td>
                            <td>@item.RecruiterName</td>
                            <td>@item.TAleadName</td>

                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
<script>

    $(document).ready(function () {

        var table = $('#tblSearchtaRecruiter').DataTable({

            "bPaginate": true,
            "columnDefs": [{
                "targets": 'no-sort',
            "orderable": false,
            }],
            "dom": '<"pull-left"f><"pull-right"l>tip'
        });

            $("#tblSearchtaRecruiter :input").on('keyup', function () {
                table.columns(0).search($(this).val()).draw();
            });
           $("#recruiterName , #leadName").change(function () {
            callChangefunc();
        });
        function callChangefunc() {
            var recruiter = $("#recruiterName").val();
            var tAlead = $("#leadName").val();
            if (recruiter == "" || recruiter == null || recruiter == undefined) {
                recruiter = 0;
            }
            if (tAlead == "" || tAlead == null || tAlead == undefined) {
                tAlead = 0;
            }
            window.location = "@Url.Action("RecruiterLedlst", "SkillOrgUpdate")" + "?recruiter=" + recruiter + '&tAlead=' + tAlead;
        }
         });
</script>
