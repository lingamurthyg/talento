        white-space: nowrap;
        padding: 8px 0 0 30px;
    }

    .table > thead > tr > th {
        white-space: nowrap
    }

    .HRRF_custom table tr th {
        color: black;
    }

    .select2-container .select2-selection--single {
        box-sizing: border-box;
        cursor: pointer;
        display: block;
        height: 33px;
        user-select: none;
        width: 136px;
    }

    .select2-container .select2-selection--single {
        width: 178px;
    }

    .select2-selection select2-selection--single {
        margin-left: -321px;
        margin-top: -2px;
    }

    #btnExportToExcel {
        position: relative;
        background-color: white;
        bottom: 60px;
        border: white;
        float: right;
        color: #004BBB;
        border: 1px solid #004BBB;
        border-radius: 6px;
        padding: 6px 25px;
    }

    table.table-bordered.dataTable tbody th, table.table-bordered.dataTable tbody td {
        border-bottom-width: 0;
        color: rgb(0, 0, 0);
    }

    #heading {
        color: #2C2E31;
        font-size: 15px;
        margin-top: 27px;
