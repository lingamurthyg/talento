            var EmployeeID = tr.find("#lblemppiid").text();
            var projectName = tr.find("#lblprojetname").text();
            var ProjectCode = tr.find("#lblprjctcodeiid").text();
            var startDate = tr.find('#StartDate').text();
            var endDate = tr.find('#EndDate').text();
            var utli = tr.find('#lblutil').text();
            var BillingStatus = tr.find('#lblbillingstatus').text();
            var orgtype = tr.find('#lblorggroup').text();
            var orgsubtype = tr.find('#lblorgsubgroup').text();
