<script>
	     $(document).ready(function () {
        //alert(1)
        $('#MenuApprovals').addClass('active');
    });

    var help = '<span class="glyphicon glyphicon-question-sign" title="Hover to check Expertise Level History"></span>';
    $("#Reporteesgridcontent #employeeskills thead").find("th:eq(5)").append(help);
    $('body').popover({

        selector: '[rel=popoverskill]',
        trigger: 'hover',
        content: function () {
            var skillHistory = $(this).attr("data-skillhistory");
            var content = '';
            if (skillHistory != "") {
                var skillHistoryArry = skillHistory.split(',');
                content += '<table id="tbl" class="table" cellspacing="0" width="100%"';
                content += '<thead><tr><th style="font-size:10px">Expertise Level History</th></thead>';
                content += '<tbody><tr><td>';
                content += '<table id="tbl" class="table table-bordered" cellspacing="0" width="100%"';
                content += '<thead><tr><th style="font-size:10px;">Expertise Level </th><th style="font-size:10px">Approver</th><th style="font-size:10px">Approved Date</th></thead>';
                content += '<tbody>';

                if (skillHistoryArry.length > 0) {
                    for (var i = 0; i < skillHistoryArry.length; i++) {
                        var historyArry = skillHistoryArry[i].split('-');
                        if (historyArry.length > 0) {
                            var approvalDate = historyArry[0];
                            var expertiselevel = historyArry[1];
                            var approver = historyArry[2];
                            content += '<tr>';
                            content += '<td style="font-size:10px">' + expertiselevel + '</td>';
                            content += '<td style="font-size:10px">' + approver + '</td>';
                            content += '<td style="font-size:10px">' + approvalDate + '</td>';
                            content += '</tr>';
                        }

                    }
                }
                content += '</tbody></table>';
                content += '</td></tr></tbody><table>';
            }
                else {
                content += '<span class="text-center">No history</span>';
                }


            return content;
        },
        //template: popoverTemplate,
        placement: "auto",
        html: true
    });

    $("#toggleAllCheckBox").click(function () {
        //debugger
        if($(this).is(":checked")) {
                $(".check-box").prop("checked", true);

            } else {
                $(".check-box").removeProp("checked");

            }
        });





    $("#btnReject").click(function () {
        debugger
        if ($('.check-box:checked').length > 0) {
            //debugger
            var dialog = $("#dialog");
            if ($("#dialog").length == 0) {
                dialog = $('<div id="dialog" style="display:hidden"><div class="row"><div class="col-md-1">&nbsp;&nbsp;&nbsp;</div><textarea id="txtremarks" class="form-control" style="height: 80px;"></textarea></div></div>').appendTo('body');
            }
            var selected = [];
            var Employeeid = $('.check-box:checked').attr("EmpId");
            if ($('.check-box:checked').length == 0)
                alert("Please select atleast one employee.")
            $('.check-box:checked').each(function () {
                selected.push($(this).attr('name'));
            });
            bootbox.dialog({
                title: "Comments",
                message: '<div class="row"> ' +
                            '<div class="col-md-12"> ' +
                                '<form role="form"> ' +
                                    '<div class="form-group">' +
                                        '<label for="email">Please enter your remarks</label>' +
                                        '<textarea class="form-control" rows="5" id="txtRemarks"></textarea>' +
                                        '<span class="text-danger" style="font-size: 13px;">Note: If you enter remarks in above textbox, the "Okay" button will be enabled.</span>' +
                                    '</div>' +
                                '</form>' +
                            '</div>' +
                        '</div>',
                buttons: {
                    success: {
                        label: "Okay",
                        className: "btnOkay btn-primary",
                        callback: function () {
                            var remarks = $('#txtRemarks').val();

                                 $.ajax({
                            type: "POST",
                            data: { SkillIds: selected, IsApprove: false, EmployeeId: Employeeid, Remarks: remarks },
                            url: '@Url.Action("UpdateSkillApproval", "SkillsApproval")',
                            success: function (result) {
                                //debugger;
                                //window.location.reload(true);
                                //$(this).dialog("close");

                                bootbox.alert("Selected skill(s) has/have been rejected successfully.", function () {
                                    window.location.href = '@Url.Action("Mynotifications", "Notifications")';
                                });
                            }
                        });
                        }
                    },
                    danger: {
                        label: "Cancel",
                        className: "btn-default"
                    }
                }
            }).on("shown.bs.modal", function (e) {
                debugger
                $('.btnOkay').attr('disabled', 'disabled');
                if ($('#txtRemarks').length) {
                    //  $('#txtRemarks').click(function () {
                    //    $('.btn-primary').prop('disabled', false);
                    $('#txtRemarks').keyup(function () {
                        if ($(this).val().trim() != 0) {
                            $('.btnOkay').removeAttr('disabled');
                        }
                        else {
                            $('.btnOkay').attr('disabled', 'disabled');
                        }


                    });

                    //  })
                }
            });









