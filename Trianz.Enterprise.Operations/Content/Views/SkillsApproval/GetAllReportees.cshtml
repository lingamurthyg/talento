                }
            });*@
        }
        //  }
        else {
            //alert("Please select atleast one selection")
           // bootbox.alert("Please select atleast one selection");
			 bootbox.alert("Please select at least one skill for rejection.");
        }
    });


    function checkremarks() {
        //debugger
        //alert("Hiiiii");
        var remarks = $('#txtRemarks').val().length;

        if (remarks != 0) {
            $(".btnOkay").removeClass('disabled');
        }
        else {
            $(".btnOkay").addClass('disabled');
        }

    }


    $("#btnApprove").click(function () {
        debugger
        if ($('.check-box:checked').length > 0) {
            var selected = [];
            var Employeeid = $('.check-box:checked').attr("EmpId");
            $('.check-box:checked').each(function () {
                selected.push($(this).attr('name'));
            });

            $.ajax({
                url: '@Url.Action("UpdateSkillApproval", "SkillsApproval")',
                data: { SkillIds: selected, IsApprove: true, EmployeeId: Employeeid },
                type: "POST",
                datatype: "JSON",
                success: function (result) {
                    bootbox.alert("Selected skill(s) has/have been approved successfully.", function () {
                        //window.location.reload(true);
                        window.location.href = '@Url.Action("Mynotifications", "Notifications")';
                    });
                }
            });
        }
        else {
            //alert("Please select atleast one selection")
            bootbox.alert("Please select at least one skill for approval.");
        }
    });


</script>




