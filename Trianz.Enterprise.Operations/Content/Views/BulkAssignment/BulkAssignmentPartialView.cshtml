@model Trianz.Enterprise.Operations.Models.BenchAssignment
<style>
    table.dataTable thead .sorting:after, table.dataTable thead .sorting_asc:after, table.dataTable thead .sorting_desc:after, table.dataTable thead .sorting_asc_disabled:after, table.dataTable thead .sorting_desc_disabled:after {
        position: absolute;
        bottom: 8px;
        right: 8px;
        display: block;
        font-family: 'Glyphicons Halflings';
        opacity: -0.5;
    }
    .sortinnic {
        background: url(../../Content/images/sortup.svg) 0px 3px no-repeat;
        display: block;
        height: 10px;
        width: 10px;
    }

    .overviewmain {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .sortingmain {
        position: absolute;
        right: 4px;
    }

    .sortinnicdown {
        background: url(../../Content/images/sortdown.svg) 0px 3px no-repeat;
        display: block;
        height: 10px;
        width: 10px;
    }

</style>
<table id="tableBenchEmployees" class="table table-striped table-bordered" cellspacing="0" style="margin: 27px; width: 95%;">
    <thead>
        <tr style="background-color: #D3D4D9 !important; color: black; font-size: 12px;">
            <th class="text-center"><input type="checkbox" name="chkHeader" id="chkHeader" value="" /></th>
            <th>
                <div class="overviewmain">
                    Employee Name
                    <div class="sortingmain">
                        <span class="sortinnic"></span>
                        <span class="sortinnicdown"></span>
                    </div>
                </div>
             
            </th>
            <th>
                <div class="overviewmain">
                    Employee Code
                    <div class="sortingmain">
                        <span class="sortinnic"></span>
                        <span class="sortinnicdown"></span>
                    </div>
                </div>
               
            </th>
            <th>
                <div class="overviewmain">
                    Grade
                    <div class="sortingmain">
                        <span class="sortinnic"></span>
                        <span class="sortinnicdown"></span>
                    </div>
                </div>
               
            </th>
            <th>
                <div class="overviewmain">

                    Designation
                    <div class="sortingmain">
                        <span class="sortinnic"></span>
                        <span class="sortinnicdown"></span>
                    </div>
                </div>

            </th>
            <th>
                <div class="overviewmain">
                    Utilization(%)
                    <div class="sortingmain">
                        <span class="sortinnic"></span>
                        <span class="sortinnicdown"></span>
                    </div>
                </div>

               
            </th>
            <th>
                <div class="overviewmain">
                    Manager
                    <div class="sortingmain">
                        <span class="sortinnic"></span>
                        <span class="sortinnicdown"></span>
                    </div>
                </div>
            
            </th>
            <th>
                <div class="overviewmain">
                    Role
                    <div class="sortingmain">
                        <span class="sortinnic"></span>
                        <span class="sortinnicdown"></span>
                    </div>
                </div>
                
            </th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null)
        {
            foreach (var item in Model.BenchEmployees)
            {
                <tr style="font-size: 12px;">
                    <td class="text-center"><input type="checkbox" name="chkRow" id="chkRow" class="chkEmployee" value="@item.EmployeeCode" /></td>
                   
                    <td id="lblassiid1">@item.EmployeeName</td>    @*observation*@
                    <td>@item.EmployeeCode</td>
                    <td><span id="spgrade">@item.Grade</span></td>
                    <td>@item.Designation</td>
                    <td>
                        <span id="lblutil"> @item.Utilization</span>
                        <span id="lblassiid" style="display:none;">@item.Assignment_Id</span>
                    </td>
                    <td>@item.Manager</td>
                    <td>
                        <select class="form-control clsProjects" data-error="Please select project name" name="ddlProjects" required="required">
                            <option value="0">Select Role</option>
                            @if (item.Role != null)
                            {
                                foreach (var role in item.Role)
                                {
                                    <option value="@role.DesignationCode">@role.DesignationName</option>
                                }

                            }
                        </select>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

@*<hr />*@


<script type="text/javascript">
    $(document).ready(function () {
        $('#tableBenchEmployees').DataTable({
            //"aoColumns": [
            //    { "bSortable": false },
            //    null,
            //    null,
            //    null
            //],
            //"order": [
            //    [2, "asc"]
            //]
        });
        // debugger
        $('#chkHeader').change(function () {

            if ($(this).is(":checked")) {
                debugger
                $('.chkEmployee').prop("checked", "checked");

            }
            else {
                debugger
                $('.chkEmployee').removeProp("checked");
            }
        });
    });


</script>



