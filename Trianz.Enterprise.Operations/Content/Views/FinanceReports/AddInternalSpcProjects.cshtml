@model IEnumerable<Trianz.Enterprise.Operations.ViewModel.InternalSpecificCodes>
@{
    ViewBag.Title = "AddInternalSpcProjects";
    Layout = "~/Views/Shared/_Layout.cshtml";

}
<div class="form-group row">
    <div class="col-md-12 col-centered">
        <table cellpadding="4" cellspacing="4">
            <tr>
                <td>
                    <b>Project Code:</b><span style="color:red">*</span>
                </td>

                <td>
                    <div class="col-md-2" style="margin-top:18px;margin-right:1px;text-align:left">

                        <input class="form-control" style="width:180px" placeholder="Search" type="text" id="txtprojects">
                        <label id="hdnprojectcode" style="visibility:hidden"></label>

                    </div>
                </td>
                <td style="width:15%;"></td>
                <td>
                    <b>Project Name:</b><span style="color:red">*</span>
                </td>

                <td>
                    <div class="col-md-2" style="margin-top:18px;margin-right:1px;text-align:left">

                        <input class="form-control" style="width:180px" placeholder="Search" type="text" id="projects">
                        <label id="hdnprojectcode1" style="visibility:hidden"></label>

                    </div>
                </td>
                <td style="width:15%;"></td>
                <td>
                    <input type="button" id="btnsubmit" value="Submit" class="btn btn-primary" />
                </td>
            </tr>
        </table>
    </div>
</div>

<div id="Internalspcodesdiv" class="col-md-12">
    <table id="InternalspcodesReport" class="table table-striped table-bordered" cellspacing="0" style="margin: 0px; width: 100%;">
        <thead>
            <tr style="background-color: #248CC8 !important; color: #fff; font-size: 12px;">
                <th>SNo</th>
                <th>ProjectCode</th>
                <th>ProjectName</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>

            @{
                int slno = 0;
            }
            @foreach (var item in Model)
            {
                //using (@Html.BeginForm("DeleteProjectCode", "FinanceReports", new { id = item.SNo }))
                <tr style="font-size: 12px;">

                    <td>@(slno + 1)</td>
                    <td>@item.ProjectCode</td>
                    <td>@item.ProjectName</td>
                    <td>
                        <input type="button" value="Delete" id="@item.SNo" title="Delete" class="btn btn-primary deleterecord" />
                        <label id="sno" style="display:none;">@item.SNo</label>
                        @*<a href='~/FinanceReports/DeleteProjectCode/@item.SNo' id="deleterecord" title="Delete"><span class='glyphicon glyphicon-trash' style="color:red" title="Delete"></span></a>*@
                        @*<span class='glyphicon glyphicon-trash' value="@item.SNo" id="deleterecord" style="color:red" title="Delete"></span>*@
                    </td>
                </tr>
                slno++;
            }

            @*else
                {
                    <tr>
                        <td colspan="5">
                            <div class="text-center">No data available</div>
                        </td>
                    </tr>
                }*@


        </tbody>
    </table>


</div>





<script>
    $("#txtprojects").autocomplete({
        source: function (request, response) {
            var Projects = new Array();
            $.ajax({
                async: false,
                cache: false,
                type: "POST",
                url: "@(Url.Action("Autocomplete", "FinanceReports"))",
                data: { "term": request.term },
                success: function (data) {

                    for (var i = 0; i < data.length ; i++) {
                        Projects[i] = { label: data[i].Key, Id: data[i].Value };
                    }
                }
            });
            response(Projects);
        },
        select: function (event, ui) {

            //fill selected customer details on form
            hdnprojectcode = ui.item.Id;


        }
    });
    $("#projects").autocomplete({
        source: function (request, response) {
            var Projects = new Array();
            $.ajax({
                async: false,
                cache: false,
                type: "POST",
                url: "@(Url.Action("Autocompletename", "FinanceReports"))",
                data: { "term": request.term },
                success: function (data) {

                    for (var i = 0; i < data.length ; i++) {
                        Projects[i] = { label: data[i].Key, Id: data[i].Value };
                    }
                }
            });
            response(Projects);
        },
        select: function (event, ui) {

            //fill selected customer details on form
            hdnprojectcode1 = ui.item.Id;


        }
    });
    $("#btnsubmit").click(function () {
        debugger
        var ProjectCode = $("#txtprojects").val();
        var ProjectName = $("#projects").val();

        $.ajax({
            url: '@Url.Action("SaveProjectCode", "FinanceReports")',
            data: { ProjectCode: ProjectCode, ProjectName: ProjectName },
            type: 'POST',
            datatype: "html",

            cache: false,
            success: function (data) {
                debugger
                if (data != null || data != "") {
                    alert("Project Code Saved Successfully");
                    $("#txtprojects").val('');
                    $("#projects").val('');

                }

            },
            error: function (data) {

                //alert(JSON.stringify(error));
            }
        });

    });
    $(".deleterecord").click(function () {
        debugger
        var tr = $(this).parents('tr:first');
        var Assid = tr.find("#sno").text();
        $.ajax({
            url: '@Url.Action("DeleteProjectCode", "FinanceReports")',
            data: { SNo: Assid },
            type: 'POST',
            datatype: "html",

            cache: false,
            success: function (data) {
                debugger
                if (data != null || data != "") {
                    alert("Project Code Deleted Successfully");
                    window.location.href = '@Url.Action("AddInternalSpcProjects", "FinanceReports")';
                }

            },
            error: function (data) {

                //alert(JSON.stringify(error));
            }
        });
        @*window.location.href = '@Url.Action("AddInternalSpcProjects", "FinanceReports")';*@
    });
</script>