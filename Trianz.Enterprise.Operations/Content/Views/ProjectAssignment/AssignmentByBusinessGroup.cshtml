    function ValidateUtilization() {
        var projectCode = $("#textProjectCode").html();
        var existingUtilization = $("#textexistingUti").html();
        var empName = $("#textemp").html();
        var utli = $("#textutilization").val();
        var isActve = $("#ddlIsActive").val();

        debugger;
        if (isActve == "false" &&( (parseInt(existingUtilization) ==parseInt(utli))||( parseInt(existingUtilization) > parseInt(utli))))
        {

        }
       else {
            if (utli == 100 || existingUtilization < utli) {
                if (empName != "" && utli != "") {
                    $.ajax({
                        // url: '/ManageKRAs/InsertData/',       // HomeController and InsertData method
                        url: '@Url.Action("VerifyUtilizationByProjectCode", "ProjectAssignment")',
                        data: JSON.stringify({ name: empName, utli: utli, projectCode: projectCode }),
                        type: 'POST',
