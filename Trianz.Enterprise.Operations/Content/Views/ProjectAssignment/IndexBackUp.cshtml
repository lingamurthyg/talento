        else if ($('#ddlbillingStatus').val() == null) {
            DisplayDialogAlert("Select Billing Status");
            returnvalue = false;

        }
        else if ($('#Expectedstart').val() == '') {
            DisplayDialogAlert("Enter Roll on Date");
            returnvalue = false;

        }
        else if ($('#ExpectedEnd').val() == '') {
            DisplayDialogAlert("Enter Roll off Date");
            returnvalue = false;

        }
        else if ($('#lblutlizatn').val() == '') {
            DisplayDialogAlert("Enter Utilization");
            returnvalue = false;

        }
        else if ($('#lblutlizatn').val() == 0) {
            DisplayDialogAlert("utilization should be greater than 0");
            returnvalue = false;
        }

        return returnvalue;
    }
    function isNumericKey(e) {
        if (window.event) { var charCode = window.event.keyCode; }
        else if (e) { var charCode = e.which; }
        else { return true; }
        if (charCode > 31 && (charCode < 48 || charCode > 57)) { alert("Enter Only Numbers"); return false; }
        return true;
    }
