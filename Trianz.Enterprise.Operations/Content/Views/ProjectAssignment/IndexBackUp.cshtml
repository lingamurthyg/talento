<script type="text/javascript">
    nowDate = new Date();
    today = new Date(nowDate.getFullYear(), nowDate.getMonth(), nowDate.getDate(), 0, 0, 0, 0);
    $(document).ready(function () {


        $('#ddlaccunt option').each(function () {
                $(this).attr('title', $(this).text());

            $("#ddlaccunt").select2();
        });
        $('#ddlProject option').each(function () {
            $(this).attr('title', $(this).text());

            $("#ddlProject").select2();
        });

        //$("#btnProcessing").hide();
        $('#btnExportToExcel').show();
        $('#dialog-view-Assignment').hide();
        $('#divGridContent1').show();
        $('#divbtun').show();
        $('#divbtun2').show();
        $('#datetimepicker1').datepicker({

            keyboardNavigation: false,
            forceParse: false,
            autoclose: true,
            todayHighlight: true,
            //startDate: today
            //format: 'dd/mm/yyyy',
        }).on('changeDate', function (e) {
            $(this).datepicker('hide');
        });
        $('#datetimepicker3').datepicker({
            keyboardNavigation: false,
            forceParse: false,
            autoclose: true,
            todayHighlight: true,
            startDate: today
            //format: 'dd/mm/yyyy',
        }).on('changeDate', function (e) {
            $(this).datepicker('hide');
        });


        $('#datetimepicker2').datepicker({
            keyboardNavigation: false,
            forceParse: false,
            autoclose: true,
            todayHighlight: true,
           // startDate: today,
            //format: 'dd/mm/yyyy',
        }).on('changeDate', function (e) {
            $(this).datepicker('hide');
        });

        $('#datetimepickerend').datepicker({
            keyboardNavigation: false,
            forceParse: false,
            autoclose: true,
            todayHighlight: true,
            //startDate: today,
            //format: 'dd/mm/yyyy',
        }).on('changeDate', function (e) {

            $(this).datepicker('hide');
        });

        $("#dlpr").change(function () {

            $("#divLoader").show();
            GetSearchBasedData();
        });
        $("#ddlProject").change(function () {

            $("#divLoader").show();
            GetSearchBasedData();
        });
        $("#ddlaccunt").change(function () {

            $("#divLoader").show();
            GetProjects();
            GetSearchBasedData();
        });
        $("#dlbls").change(function () {
            $("#divLoader").show();
            GetSearchBasedData();
        });
        function GetProjects() {
            var url = '@Url.Content("~/ProjectAssignment/GetProjectSFilterAccount")';
            var ddlaccunt = $("#ddlaccunt").val();
            $('#ddlProject').html('');
            $('#ddlProject').append(('<option value="">Select Project</option>'));
            $.ajax({
                url: url,
                type: 'GET',
                cache: false,
                data: { Account: ddlaccunt },
                success: function (data) {
                    if (data != null && data != "Sessionexpired") {
                        $.each(data, function (i, dt) {

                            $('#ddlProject').append($('<option></option>').val(dt.ProjectCode).html(dt.ProjectName));
                        });
                    }
                         else if  (data== "Sessionexpired") {
                    window.location.href = '@Url.Action("SessionExpire", "Signout")';
                    }
                    else if  (data== "Error") {
                    window.location.href = '@Url.Action("Error", "Error")';
                }
                },
                error: function (thrownError) {
                    alert(thrownError);
                }
            });
        }







        function GetSearchBasedData() {

            var url = '@Url.Content("~/ProjectAssignment/GetAssignementinfobySearch")';
            var ddlproject = $("#ddlProject").val();
            var ddlprac = $("#dlpr").val();
            var ddlbilling = $("#dlbls").val();
            var ddlaccunt = $("#ddlaccunt").val();
            $.ajax({
                url: url,
                type: 'GET',
                cache: false,
                data: { ProjectCode: ddlproject, Practise: ddlprac, BillingStatus: ddlbilling, Account: ddlaccunt },
                success: function (data) {
                    if (data != null && data != "Sessionexpired") {
                        $('#divGridContent1').html(data);
                        $("#divLoader").hide();


                        var rowCount = $('#tableassig tbody tr').length;
                        if (rowCount > 1) {
                            $("#btnExportToExcel").show();
                        }
                        else {
                            $("#btnExportToExcel").hide();
                        }
                    }
                          else if (data == "Sessionexpired") {
                    window.location.href = '@Url.Action("SessionExpire", "Signout")';
                }

                },
                error: function (thrownError) {
                    alert(thrownError);
                }
            });
        }
        $("#txtemployee").autocomplete({
            source: function (request, response) {

                var Projects = new Array();
                $.ajax({
                    async: false,
                    cache: false,
                    type: "POST",
                    url: "@(Url.Action("Autocomplete", "ProjectAssignment"))",
                    data: { "term": request.term },
                    success: function (data) {

                        if (data != null && data != "Sessionexpired"){
                            for (var i = 0; i < data.length; i++) {
                                Projects[i] = { label: data[i].Key, Id: data[i].Value };
                            }
                        }

                        else if (data == "Sessionexpired") {
                            window.location.href = '@Url.Action("SessionExpire", "Signout")';
                        }
                        else if (data == "Error") {
                                window.location.href = '@Url.Action("Error", "Error")';
                            }
                }
                });
                response(Projects);
            },
            select: function (event, ui) {

                //fill selected customer details on form
                //hdnemployeeid = ui.item.Id;
            }
        });

        $("#txtemployee").blur(function () {
            if ($(this).val().length > 0) {
                FunGetEmployeeDetails($(this).val());
            }
        });
        function FunGetEmployeeDetails(Employeeid) {
            $.ajax({
                async: false,
                cache: false,
                type: "POST",
                url: "@(Url.Action("EmployeeInfo", "ProjectAssignment"))",
                data: { EmployeeID: Employeeid },
                success: function (data) {


                    if (data.length == 0) {
                        $("#lblempname").val('');
                        $("#lblempemail").val('');
                        $("#lblpracti").val('');
                        $("#lblassignlocation").val('');
                        // $('#ddlassignmentStatus').val('');
                        bootbox.alert("Please enter or select valid Employee Code, only then valid Employee details will be displayed.")
                    }
                      else if (data == "Sessionexpired") {
                            window.location.href = '@Url.Action("SessionExpire", "Signout")';
                    }
                         else if (data == "Error") {
                            window.location.href = '@Url.Action("Error", "Error")';
                    }

                    else {
                        $("#lblempname").val(data[0].EmployeeName);
                        $("#lblempemail").val(data[0].EmailID);
                        $("#lblpracti").val(data[0].Practice);
                        $("#lblassignlocation").val(data[0].Location);
                        //$('#ddlassignmentStatus').val(data[0].AssignmenStatus);
                    }
                }

            });
        }
        $("#txtproject").autocomplete({
            source: function (request, response) {

                var Projects = new Array();
                $.ajax({
                    async: false,
                    cache: false,
                    type: "POST",
                    url: "@(Url.Action("ProjectAutocomplete", "ProjectAssignment"))",
                    data: { "Project": request.term },
                    success: function (data) {

                        if (data != null && data != "Sessionexpired") {
                        for (var i = 0; i < data.length; i++) {
                            Projects[i] = { label: data[i].Key, Id: data[i].Value };
                        }
                        }

                       else if (data == "Sessionexpired") {
                    window.location.href = '@Url.Action("SessionExpire", "Signout")';
                        }
                         else if (data == "Error") {
                            window.location.href = '@Url.Action("Error", "Error")';
                        }

                    }
                });
                response(Projects);
            },
            select: function (event, ui) {

                //fill selected customer details on form
                // hdnemployeeid = ui.item.Id;
            }
        });

        $("#txtproject").blur(function () {

            if ($(this).val().length > 0) {
                FunGetProjectDetails($(this).val());
            }
        });
        function FunGetProjectDetails(ProjectCode) {

            $.ajax({
                async: false,
                cache: false,
                type: "POST",
                url: "@(Url.Action("ProjectInfo", "ProjectAssignment"))",
                data: { ProjectCode: ProjectCode },
                success: function (data) {


                    if (data.length == 0) {
                        $("#lblprojectname").val('');
                        $("#lblprojectid").val('');
