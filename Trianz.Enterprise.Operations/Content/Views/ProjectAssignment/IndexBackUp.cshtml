    function parseDate(str) {
        var mdy = str.split('/');
        return new Date(mdy[2], mdy[1] - 1, mdy[0]);
    }

    function daydiff(start, end) {
        return Math.round((end - start) / (1000 * 60 * 60 * 24));
    }
