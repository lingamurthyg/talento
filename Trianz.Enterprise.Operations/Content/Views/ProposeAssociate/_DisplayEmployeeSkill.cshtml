

@model Trianz.Enterprise.Operations.Models.ValidationModel

@{
    ViewBag.Title = "_DisplayEmployeeSkill";
    var itemvalues = Model.EmployeeSkillInfo;
}
@if (itemvalues.Count()>0)
{
    <div class="row" style="padding-left:2px;">
        <div class="col-md-8">
            @if (Model != null)
            {
                var Employeeid = "";
                foreach (var modelItems in itemvalues)
                {
                    Employeeid = modelItems.EmployeeId.ToString();
                }
                var text = Employeeid + " Employee Skill Information";
                <label for="a" id="lblhead">@text</label>
            }

        </div>
    </div>
    <div class="row" style="padding-left:2px;">
        <div class="col-md-12">

            <table id="tableassig" class="table table-striped table-bordered" cellspacing="0" style="margin: 0px; width: 100%;">
                <thead>
                    <tr style="background-color: #248CC8 !important; color: #fff; font-size: 12px;">

                        <th>Skill Category</th>
                        <th>Skill set</th>
                        <th>Expertise level</th>
                        <th>TechnologyLastUsed</th>
                        <th>Skill Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null)
                    {
                        foreach (var item in itemvalues)
                        {
                            <tr style="font-size: 12px;">
                                <td>@item.CompetincyName</td>
                                <td><label id="lblskillname">@item.Skillname</label></td>
                                <td>
                                    <label id="lblprjmanager">@item.Expertiselevel</label>
                                </td>
                                <td>
                                @*@item.TechnologyLastUsed*@
                                    <span id="lblastused" class="skillreadonly"> @System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(Convert.ToInt32(item.TechnologyLastUsed.Split(',')[0])),@item.TechnologyLastUsed.Split(',')[1]</span>
                                    <span id="lblastusedid" style="display:none;"> @item.TechnologyLastUsed</span>
                                </td>
                                <td><label id="lblskillst">@item.SkillStatus</label></td>
                            </tr>
                        }
                    }

                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <label>No records to display</label>
}