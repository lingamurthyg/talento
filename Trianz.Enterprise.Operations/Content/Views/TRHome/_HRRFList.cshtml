@model List<Trianz.Enterprise.Operations.Models.sp_GetHRRFListByEmpIdPractice_Result>

@*<script src="/path/to/cdn/jquery.min.js"></script>

    <script src="/path/to/jquery.hovertruncated.js"></script>*@


@*<div ng-show="#tableHRRF" id="myrequestShow">
    </div>
    <div ng-hide="#tableHRRF" id="myrequestHide">
    </div>*@

<link href="~/Content/Talento4.css" rel="stylesheet" />
<style>
    /*.nav navbar-nav left-nav {
        position: relative;
        top: 23px;
    }*/

    /*div.dataTables_wrapper div.dataTables_length label {
        font-weight: normal;
        text-align: left;
        white-space: nowrap;
        margin-left: 8px;
    }*/
    dataTables_info {
        margin: 0px;
        padding: 5px 0 0 15px;
        height: 35px;
    }

    #tableHRRF_info {
        margin-left: 0px;
    }
    table.table-bordered.dataTable tbody th, table.table-bordered.dataTable tbody td {
        border-bottom-width: 0;
        text-align: left;
    }
    /*#tableHRRF_info {
        margin-left: 174px;
    }*/
   
    #requeststatus {
        padding: 4px 10px 4px 10px;
        border-radius: 10px;
    }

    .sortinnic {
        background: url(../../Content/images/sortup.svg) 0px 3px no-repeat;
        display: block;
        height: 10px;
        width: 10px;
    }

    .overviewmain {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .sortingmain {
        position: absolute;
        right: 4px;
    }

    .sortinnicdown {
        background: url(../../Content/images/sortdown.svg) 0px 3px no-repeat;
        display: block;
        height: 10px;
        width: 10px;
    }
</style>

<table id="tableHRRF" class="table table-striped table-bordered" cellspacing="0" style="margin: 0px;width: 100%;  color: #000000;position: relative">
    <thead style="background-color: #D6DCE3 !important; color: #2C2E31">
        <tr>


            <th id="tr" class="sorting" style="width:101px;color: black;">

                <div class="overviewmain">
                    TR #
                    <div class="sortingmain">
                        <span class="sortinnic"></span>
                        <span class="sortinnicdown"></span>
                    </div>
                </div>

            </th>
            <th id="code">

                <div class="overviewmain">
                    Skill Code
                    <div class="sortingmain">
                        <span class="sortinnic"></span>
                        <span class="sortinnicdown"></span>
                    </div>
                </div>
            </th>

            @*<th style="color:#000000">Practice<span class="caret" id="comp3"></span></th>*@
            @*<th id="purpose">PURPOSE</th>*@
            <th id="purpose" style="width:215px;color: black;">
                <span id="comp3"></span>
                <div class="overviewmain">
                    Purpose
                    <div class="sortingmain">
                        <span class="sortinnic"></span>
                        <span class="sortinnicdown"></span>
                    </div>
                </div>
            </th>
            <th id="practice">
                <span id="comp3"></span>
                <div class="overviewmain" style="width: 55px;">
                    Practice
                    <div class="sortingmain">
                        <span class="sortinnic"></span>
                        <span class="sortinnicdown"></span>
                    </div>
                </div>
            </th>

            <th id="grade" style="width: 38px;">
                <div class="overviewmain">
                    Grade
                    <div class="sortingmain">
                        <span class="sortinnic"></span>
                        <span class="sortinnicdown"></span>
                    </div>
                </div>

            </th>
            <th id="location">
                <div class="overviewmain">
                    Location
                    <div class="sortingmain">
                        <span class="sortinnic"></span>
                        <span class="sortinnicdown"></span>
                    </div>
                </div>
            </th>
            <th id="overdue">
                <div class="overviewmain">
                    Overview
                    <div class="sortingmain">
                        <span class="sortinnic"></span>
                        <span class="sortinnicdown"></span>
                    </div>
                </div>
            </th>
            <th id="resource" style="width: 148px;">

                <div class="overviewmain">
                    Resource
                    <div class="sortingmain">
                        <span class="sortinnic"></span>
                        <span class="sortinnicdown"></span>
                    </div>
                </div>
            </th>
            <th id="status" style="width:185px;">
                <span id="comp3"></span>
                <div class="overviewmain">
                    Status
                    <div class="sortingmain">
                        <span class="sortinnic"></span>
                        <span class="sortinnicdown"></span>
                    </div>
                </div>
            </th>




        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            string color = "", bg = "", na;
            if (@item.RequestStatus == "Draft")
            {
                color = "#FFF7A3";
                bg = "#FFF7A3";
            }

            else if (@item.RequestStatus == "Qualified")
            {
                color = "#E4F7E0";
                bg = "#E4F7E0";
            }

            else if (@item.RequestStatus == "Pending For DH Approval")
            {

                color = "#FFF7A3";
                bg = "#FFF7A3";
            }

            else if (@item.RequestStatus == "Submitted")
            {
                color = "#E4F7E0";
                bg = "#E4F7E0";
            }

            else if (@item.RequestStatus == "Fulfilled")
            {

                color = "#E4F7E0";
                bg = "#E4F7E0";
            }

            else if (@item.RequestStatus == "Hold")
            {
                color = "#FFF7A3";
                bg = "#FFF7A3";
            }
            else if (@item.RequestStatus == "Request More Info")
            {
                color = "#EAF8FE";
                bg = "#EAF8FE";
            }
            else if (@item.RequestStatus == "Cancelled")
            {
                color = "#F4D6D6 ";
                bg = "#F4D6D6";
            }
            else if (@item.RequestStatus == "Resume Pending")
            {
                color = "#FFF7A3";
                bg = "#FFF7A3";
            }
            else if (@item.RequestStatus == "Yet to Join")
            {
                color = "#FFF7A3";
                bg = "#FFF7A3";
            }
            else if (@item.RequestStatus == "Awaiting Screening")
            {
                color = "#FFF7A3";
                bg = "#FFF7A3";
            }
            else if (@item.RequestStatus == "Client Interview Pending")
            {
                color = "#00A88E";
                bg = "#00A88E";
            }
            else if (@item.RequestStatus == "First Level Pending")
            {
                color = "#FFF7A3";
                bg = "#FFF7A3";
            }
            else if (@item.RequestStatus == "Feedback Pending")
            {
                color = "#FFF7A3";
                bg = "#FFF7A3";
            }
            else if (@item.RequestStatus == "HR Interview Pending")
            {
                color = "#FFF7A3";
                bg = "#FFF7A3";
            }
            else if (@item.RequestStatus == "Offer to Go")
            {
                color = "#E4F7E0";
                bg = "#E4F7E0";
            }
            else if (@item.RequestStatus == "Second Level Pending")
            {
                color = "#FFF7A3";
                bg = "#FFF7A3";
            }





            <tr class="ng" style="font-size: 12px;">
                @if (Convert.ToBoolean(item.FLAG))
                {

                    <td class="text-right" style="padding-right: 10px;">
                        @if (item.Purpose != null && item.Purpose.ToLower() == "opportunity")
                        {
                            @:<i class="fa fa-star small text-danger" aria-hidden="true"></i>
                        }
                        @if (item.Remarks == "This is an auto generated TR during bulk assignment" || item.Remarks == "This is an auto generated TR during new employee creation")
                        {
                            @:<i class="fa text-danger" style="font:bold;font-size:10pt;"><strong> A</strong> </i>
                        }
                        @if (item.HRRFNumber != "" && item.HRRFNumber != null)
                        {
                            @Html.ActionLink((string)item.HRRFNumber, "ProposeAssociate", "ProposeAssociate", new { id = item.HRRFNumber, hrrfno = item.HRRFNumber }, new { @style = "color: lightcoral;" })
                        }

                        @if (item.RequestType.ToLower() == "external")
                        {
                            @:<span class="text-danger"> - <strong> e  </strong>  </span>
                        }
                        else
                        {
                            @:<span class="text-success"> - <i class="fa fa-info" aria-hidden="true"></i></span>
                        }
                    </td>
                }
                else
                {
                    var over_due = item.OverDue;
                    if (item.RequestStatus.ToLower() != "draft" && item.RequestStatus.ToLower() != "fulfilled"
                        && item.RequestStatus.ToLower() != "terminated" && item.RequestStatus.ToLower() != "cancelled")
                    {
                        if (over_due != null && over_due != string.Empty)
                        {
                            var Splitover_due = over_due.Split(' ');
                            int overdue_value = 0;
                            if (Splitover_due.Count() > -1)
                            {
                                if (!(string.IsNullOrEmpty(Splitover_due[0])))
                                {
                                    overdue_value = Convert.ToInt32(Splitover_due[0]);
                                }
                            }


                            if (overdue_value <= 30)
                            {

                                <td class="text-right" style="padding-right: 10px;">
                                    @if (item.Purpose.ToLower() == "opportunity")
                                    {
                                        @:<i class="fa fa-star small text-danger" aria-hidden="true"></i>
                                    }
                                    @if (item.Remarks == "This is an auto generated TR during bulk assignment" || item.Remarks == "This is an auto generated TR during new employee creation")
                                    {
                                        @:<i class="fa text-danger" style="font:bold;font-size:10pt;"><strong> A</strong> </i>
                                    }
                                    @if (item.HRRFNumber != "" && item.HRRFNumber != null)
                                    {
                                        @Html.ActionLink((string)item.HRRFNumber, "ProposeAssociate", "ProposeAssociate", new { id = item.HRRFNumber, hrrfno = item.HRRFNumber }, new { @style = "color: #FFC200;" })
                                    }


                                    @if (item.RequestType.ToLower() == "external")
                                    {
                                        @:<span class="text-danger"> - <strong> e  </strong>  </span>
                                    }
                                    else
                                    {
                                        @:<span class="text-success"> - <i class="fa fa-info" aria-hidden="true"></i></span>
                                    }
                                </td>
                            }
                            else
                            {
                                <td class="text-right" style="padding-right: 10px;">
                                    @if (item.Purpose.ToLower() == "opportunity")
                                    {
                                        @:<i class="fa fa-star small text-danger" aria-hidden="true"></i>
                                    }
                                    @if (item.Remarks == "This is an auto generated TR during bulk assignment" || item.Remarks == "This is an auto generated TR during new employee creation")
                                    {
                                        @:<i class="fa text-danger" style="font:bold;font-size:10pt;"><strong> A</strong> </i>
                                    }
                                    @if (item.HRRFNumber != null && item.HRRFNumber != "")
                                    {
                                        @Html.ActionLink((string)item.HRRFNumber, "ProposeAssociate", "ProposeAssociate", new { id = item.HRRFNumber, hrrfno = item.HRRFNumber }, null)
                                    }

                                    @if (item.RequestType.ToLower() == "external")
                                    {
                                        @:<span class="text-danger"> - <strong> e  </strong>  </span>
                                    }
                                    else
                                    {
                                        @:<span class="text-success"> - <i class="fa fa-info" aria-hidden="true"></i></span>
                                    }
                                </td>
                            }

                        }
                        else
                        {
                            <td class="text-right" style="padding-right: 10px;">
                                @if (item.Purpose.ToLower() == "opportunity")
                                {
                                    @:<i class="fa fa-star small text-danger" aria-hidden="true"></i>
                                }
                                @if (item.Remarks == "This is an auto generated TR during bulk assignment" || item.Remarks == "This is an auto generated TR during new employee creation")
                                {
                                    @:<i class="fa text-danger" style="font:bold;font-size:10pt;"><strong> A</strong> </i>
                                }
                                @if (item.HRRFNumber != null && item.HRRFNumber != "")
                                {
                                    @Html.ActionLink((string)item.HRRFNumber, "ProposeAssociate", "ProposeAssociate", new { id = item.HRRFNumber, hrrfno = item.HRRFNumber }, null)
                                }

                                @if (item.RequestType.ToLower() == "external")
                                {
                                    @:<span class="text-danger"> - <strong> e  </strong>  </span>
                                }
                                else
                                {
                                    @:<span class="text-success"> - <i class="fa fa-info" aria-hidden="true"></i></span>
                                }
                            </td>
                        }
                    }
                    else
                    {
                        <td class="text-right" style="padding-right: 10px;">
                            @if (item.Purpose.ToLower() == "opportunity")
                            {
                                @:<i class="fa fa-star small text-danger" aria-hidden="true"></i>
                            }
                            @if (item.Remarks == "This is an auto generated TR during bulk assignment" || item.Remarks == "This is an auto generated TR during new employee creation")
                            {
                                @:<i class="fa text-danger" style="font:bold;font-size:10pt;"><strong> A</strong> </i>
                            }
                            @if (item.HRRFNumber != null && item.HRRFNumber != "")
                            {
                                @Html.ActionLink((string)item.HRRFNumber, "ProposeAssociate", "ProposeAssociate", new { id = item.HRRFNumber, hrrfno = item.HRRFNumber }, null)
                            }

                            @if (item.RequestType.ToLower() == "external")
                            {
                                @:<span class="text-danger"> - <strong> e  </strong>  </span>
                            }
                            else
                            {
                                @:<span class="text-success"> - <i class="fa fa-info" aria-hidden="true"></i></span>
                            }
                        </td>
                    }
                }
                @*<td style="display: none;">@item.HRRFID</td>*@
                @*<td id="code">
                    @item.SkillCode
                    </td>*@

                <td>
                    @item.SkillCode
                </td>



                @*<td style="cursor: pointer;" title="Description: @item.CLSTRJD">
                        @((item.CLSTRJD != "" && item.CLSTRJD != null) ? item.CLSTRJD.Length < 30 ? item.CLSTRJD : item.CLSTRJD.Substring(0, 27) + " ..." : string.Empty)
                    </td>*@


                <td style="cursor: pointer;" title="@item.Project">
                    @((item.Project != "" && item.Project != null) ? item.Project.Length < 30 ? item.Project : item.Project.Substring(0, 25) + " ..." : string.Empty)
                </td>

                <td>@item.Practice</td>
                <td>@item.Grade</td>
                <td>@item.LocationName</td>
                <td>@item.OverDue</td>
                @*<td>@(item.HRRFSubmitedDate == null ? "" : @Convert.ToDateTime(item.HRRFSubmitedDate).ToString("dd MMM yyyy"))</td>*@

                <td style="cursor: pointer;" title="@item.ResourceName">
                    @((item.ResourceName != "" && item.ResourceName != null) ? item.ResourceName.Length < 17 ? item.ResourceName : item.ResourceName.Substring(0, 17) + " ..." : string.Empty)

                </td>

                @*<td id="requeststatus" style="background-color:@bg">
                        <span style="">@item.RequestStatus</span>
                    </td>*@
                <td>

                    @if (item.RequestStatus == "Qualified" || item.RequestStatus == "Offer to Go" || item.RequestStatus == "Fulfilled" || item.RequestStatus == "Submitted")
                    {
                        <span id="requeststatus" style="background: #E4F7E0;">@item.RequestStatus</span>
                    }
                    @if (item.RequestStatus == "Draft" || item.RequestStatus == "Hold" || item.RequestStatus == "Resume Pending" || item.RequestStatus == "Yet to Join" || item.RequestStatus == "Awaiting Screening" || item.RequestStatus == "Client Interview Pending" || item.RequestStatus == "First Level Pending" || item.RequestStatus == "Feedback Pending" || item.RequestStatus == "HR Interview Pending" || item.RequestStatus == "Second Level Pending")
                    {
                        <span id="requeststatus" style="background: #FFF7A3;">@item.RequestStatus</span>
                    }
                    @if (item.RequestStatus == "Pending For DH Approval")
                    {
                        <span id="requeststatus" style="background-color:#FFF7A3">Pending DH Approval</span>
                    }
                    @if (item.RequestStatus == "Request More Info")
                    {
                        <span id="requeststatus" style="background: #EAF8FE;">@item.RequestStatus</span>
                    }
                    @if (item.RequestStatus == "Cancelled")
                    {
                        <span id="requeststatus" style="background: #F4D6D6;">@item.RequestStatus</span>
                    }
                </td>
            </tr>


        }
    </tbody>
</table>
<div style="border: 1px solid whitesmoke;">
    @*<div class="row">
            <div class="col-lg-3 text-center text-danger"><span class="oprty_star"> <i class="fa fa-star small" aria-hidden="true"></i> </span><i class="fa fa-hand-o-right fa-fw text-primary" aria-hidden="true"></i>&nbsp;Opportunity TRs</div>
            <div class="col-lg-3 text-center text-danger"><span class="grid_td-A" style="color: #EC0404"> <strong>A </strong></span><i class="fa fa-hand-o-right fa-fw text-primary" aria-hidden="true"></i>&nbsp;Auto TRs</div>
            <div class="col-lg-3 text-center text-danger"><span class="grid_td-i" style="color: #25E402"> <i class="fa fa-info" aria-hidden="true"></i> </span><i class="fa fa-hand-o-right fa-fw text-primary" aria-hidden="true"></i>&nbsp;Internal TRs</div>
            <div class="col-lg-3 text-center text-danger"><span class="grid_td-e" style="color: #EC0404"><strong>e</strong></span> <i class="fa fa-hand-o-right fa-fw text-primary" aria-hidden="true"></i>&nbsp;External TRs</div>
        </div>*@
</div>
<br />





