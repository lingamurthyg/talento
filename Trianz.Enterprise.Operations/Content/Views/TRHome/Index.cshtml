<script type="text/javascript">
    //function fun();

    $('.filter1').click(function () {


        if ($(".filter1").hasClass("active")) {

            $(".filter1").removeClass("active");
            $("#DataHide").hide();

        }
        else {

            $(".filter1").addClass("active");

            $("#DataHide").show();
        }

        $(this).find(".filter1").toggleClass('active');

    });

    $('.newactive').click(function () {

        $(".filter1").removeClass("active");
        $(this).find(".filter1").toggleClass('active');


    });

    $(this).find(".filter1").toggleClass('active');


</script>

