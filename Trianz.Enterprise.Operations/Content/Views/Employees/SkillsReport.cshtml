@model List<Trianz.Enterprise.Operations.Models.EmployeeSkillsReport>
@{
    ViewBag.Title = "Skills Report";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="~/Content/dataTables.bootstrap.css" rel="stylesheet">
<link href="~/Content/LayoutHeader.css" rel="stylesheet" />


<link href="https://cdn.datatables.net/responsive/2.0.2/css/responsive.bootstrap.min.css" rel="stylesheet">

<script type="text/javascript" language="javascript" src="https://cdn.datatables.net/1.10.11/js/jquery.dataTables.min.js"></script>
<script type="text/javascript" language="javascript" src="https://cdn.datatables.net/1.10.11/js/dataTables.bootstrap.min.js"></script>

<script type="text/javascript" language="javascript" src="https://cdn.datatables.net/responsive/2.0.2/js/dataTables.responsive.min.js"></script>
<script type="text/javascript" language="javascript" src="https://cdn.datatables.net/responsive/2.0.2/js/responsive.bootstrap.min.js"></script>

<style>
    body {
        overflow-x: hidden;
    }
    .Empname {
        position: relative;
        top: -40px;
        left: 95px;
    }
    .dataTables_filter {
        position: relative;
        top: 6px;
    }
    #txt1 {
        color: #2C2E31;
        font-size: 16px;
        margin-left: -8px;
        margin-top: 27px;
    }

    #tableEmpSkillsReport_length {
        position: relative;
        top: 4px;
    }
    .col-md-12 {
        width: 96%;
        max-width: 100%;
        /* margin-bottom: 20px; */
        margin-left: 27px;
    }

    .HRRF_custom table.p-resources thead th, .HRRF_custom table.p-resources tbody th, table.dataTable.nowrap th {
        background-color: #D6DCE3 !important;
        color: black;
        font-size: 12px;
       
    }

    #skillsReport {
        background-color: #D6DCE3 !important;
        color: black;
        font-size: 12px;
    }
    .table.table-bordered.dataTable th, table.table-bordered.dataTable td {
        border-left-width: 0;
        color: rgb(0, 0, 0);
        font-size: 12px;
    }
</style>
@*<link href="~/Content/Talento7.css" rel="stylesheet" />*@
<div class="row" style="margin-bottom: 10px;">
    <div class="col-md-12">
        <div class="subpage_header page-header nomargin-top">
            <div class="text-left pull-left myskills_div">
                <p id="txt1">EMPLOYEE SKILLS</p>
            </div>
            @*<div class="pull-right text-right myskills_div">
                    <button id="btnExportToExcel" type="button" class="btn btn-default pull-left" style="margin-top: -8px;">
                        Export to Excel
                    </button>
                </div>*@
            <div>
                @*<button id="btnExportToExcel" type="button" style="border: none;background-color: white;width: 25px; margin-left: 945px;">
            <img src="~/Content/images/xlsimg.png" data-toggle="tooltip" data-placement="left" title="Export to Excel" class="xlms" style="width: 43px;height: 44px;display: inline-block;margin-top: -3px;margin-left: -19px;" alt="xlmsimg">
        </button>*@

                <button id="btnExportToExcel" type="button" style="position: relative; background-color: white; border: white; float: right; color: #004BBB; border: 1px solid #004BBB; border-radius: 6px; padding: 6px 25px;top: 20px;right: -3px;">
                    <img src="~/Content/images/Report_icon.svg" /> Export <span class="caret"></span>
                </button>
            </div>
            <div class="clear-both"></div>
        </div>
    </div>
    <div class="col-md-12" style="overflow-x:scroll;background-color: #ffffff;">
        <table id="tableEmpSkillsReport" class="table table-striped table-bordered dt-responsive nowrap" cellspacing="0" style="margin: 0px; width: 100%;">
            <thead>
                <tr id="skillsReport">
                    <th>Emp ID</th>
                    <th>Employee</th>
                    <th>Parent Organization</th>
                    <th>Project Code</th>
                    <th>Project Name</th>
                    <th>Billing Status</th>
                    <th>Supervisor</th>
                    <th>Skill Status</th>
                    <th>Resume Uploaded</th>
                    <th>Competency</th>
                    <th>Skill Set</th>
                    <th>Expertise level</th>
                    <th>Last Used</th>
                    @*<th>Master Skills</th>
                        <th>Sub Skill1</th>
                        <th>Sub Skill2</th>
                        <th>Sub Skill3</th>
                        <th>Sub Skill4</th>
                        <th>Sub Skill5</th>
                        <th>Status</th>*@
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr style="font-size: 12px;">
                        <td>@item.EmployeeID</td>
                        <td>@item.EmployeeName</td>
                        <td>@item.ParentOrganization</td>
                        <td style="white-space: pre;">@item.ProjectCode</td>
                        <td style="white-space: pre;">@item.ProjectName</td>
                        <td>@item.BillingStatus</td>
                        <td>@item.Supervisor</td>
                        <td>@item.SKillstatus</td>
                        <td>@item.ResumeUploaded</td>
                        <td>@item.Competency</td>
                        <td>@item.Skillset</td>
                        <td>@item.Expertiselevel</td>
                        <td>
                            @if (@item.LastUsed != null)
                            {
                                <span> @System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(Convert.ToInt32(item.LastUsed.Split(',')[0]))-@item.LastUsed.Split(',')[1]</span>
                            }

                        </td>
                        @*<td>@item.MasterSkills</td>
                            <td>@item.SubSkill1</td>
                            <td>@item.SubSkill2</td>
                            <td>@item.SubSkill3</td>
                            <td>@item.SubSkill4</td>
                            <td>@item.SubSkill5</td>
                            <td>@item.Status</td>*@
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<script type="text/javascript">
    $(document).ready(function () {
        $('#tableEmpSkillsReport').DataTable({
            "columnDefs": [
                { "width": "10%", "targets": 4 }
            ]
        });


   $('#btnExportToExcel').click(function () {
            $(this).attr("disabled", "disabled");
            //$(this).text('Downloading ...');

            $.ajax({
                url: "@Url.Action("ExportReport", "Employees")",
                data: "",
                type: "POST",
                datatype: "JSON",
                success: function (response) {
                    if (response == "success") {
                        window.location = "@Url.Action("GenerateEmployeeSkillReport", "Employees")";

                        //setTimeout(function () {
                        //    $("#btnExportToExcel").removeAttr("disabled").text('Export to Excel');
                        //}, 5000);
                    }
                    else if (response== "Sessionexpired") {
                            window.location.href = '@Url.Action("SessionExpire", "Signout")';
                        }
                },
                error: function (error) {
                    alert(error.statusText);
                }
            });
        });
    });

</script>