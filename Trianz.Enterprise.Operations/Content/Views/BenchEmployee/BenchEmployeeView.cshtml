<script type="text/javascript">
    function OtherCustomerDet(customer)
    {
        // debugger;
        if(customer.value.toLowerCase() == "other")
        {
            // var idofdrop = $(customer).attr('id');
            $(customer).closest('tr').find('.OtherCustomer').removeAttr("style");
        }
        else
        {
            $(customer).closest('tr').find('.OtherCustomer').attr("style","display:none");
        }
    }
    function CheckRemark(remarkk,idofemp)
    {
        // debugger;
        var rem = $(remarkk).text();
        var actionrem =  $("#tableBenchEmployees").find("tbody tr").find("#ActionReminder_"+idofemp).val().trim();

        var today = new Date();
        var curr_date = today.getDate();
        var curr_year = today.getFullYear();
        if(curr_date<10){curr_date='0'+curr_date}
        var monthNames = [ "Jan", "Feb", "Mar", "Apr", "May", "June",
                           "July", "Aug", "Sept", "Oct", "Nov", "Dec" ];
        curr_month= monthNames[today.getMonth()];
        var today = curr_date + " " + curr_month + " " + curr_year;

        if(rem.length != 0)
        {
            if(actionrem.length != 0)
            {
                if(actionrem <= today)
                {
                    $("#tableBenchEmployees").find("tbody tr").find("#ActionReminder_"+idofemp).val("");
                }
            }
        }
    }

    function benchstatusvalues(category) {
        /*debugger*/
        var benchStatusID = "#BenchStatus" + $(category).parent().parent().find("#lblassiid").text().trim();
        var clientMappingID="#Customer"+$(category).parent().parent().find("#lblassiid").text().trim();

        $(benchStatusID).empty();
        if(category.value.length != 0)
        {
            $(category).closest('tr').find('.ExpectedBillingDate').val("");
            $(category).closest('tr').find('.MappedDate').val("");
            //$('#ExpectedBillingDate').val("");
            //$('#MappedDate').val("");
        }
        var markup = "<option value=''>Select an option</option>";
        if (category.value.toLowerCase() == "deployable bench") {
            markup += "<option value='Free Pool'>Free Pool</option>";
            markup += "<option value='Partial Bench'>Partial Bench</option>";

           // debugger;
            //(clientMappingID).find('select option:eq(0)').prop('selected', true);
        }
        else if (category.value.toLowerCase() == "nondeployable bench") {
            markup += "<option value='BGV'>BGV</option>";
            markup += "<option value='Freshers'>Freshers</option>";
            markup += "<option value='Long Leave'>Long Leave</option>";
            markup += "<option value='Maternity Leave'>Maternity Leave</option>";
            markup += "<option value='Medical Leave'>Medical Leave</option>";
            markup += "<option value='Resigned'>Resigned</option>";
            markup += "<option value='Intern'>Intern</option>";
        }
        else if (category.value.toLowerCase() == "reserved") {
            markup += "<option value='Mapped'>Mapped</option>";
            markup += "<option value='Sow Pending'>Sow Pending</option>";
        }

        $(benchStatusID).html(markup);
    }
    function Savedetails() {

        var selectedValues = [];
        var empid = "";
        var IsValidate = true;
        $("#tableBenchEmployees").find("tbody tr").each(function () {
            var assi=$("#BenchStatus" + $(this).find("#lblassiid").text().trim()).val();
            /*debugger*/
            var emp4validation = $(this).find("#lblemplyeeid").text();
            var chk = true;
            var otherchk="";
            cat = $("#Category" + $(this).find("#lblassiid").text().trim()).val();
            subcat = $("#BenchStatus" + $(this).find("#lblassiid").text().trim()).val();
            remarks = $(this).find("#Remarks").val();
            expbilldate = $(this).find("#ExpectedBillingDate").val().trim();
            mapdate = $(this).find("#MappedDate").val().trim();
            Cust= $(this).find("#Customer"+ $(this).find("#lblassiid").text().trim()).val();
            if(Cust.toLowerCase() == "other")
            {
                if($("#OtherCustomer_" + $(this).find("#lblemplyeeid").text().trim()).val().length != 0)
                {
                    Cust=  $("#OtherCustomer_" + $(this).find("#lblemplyeeid").text().trim()).val();
                }
                else
                {
                    chk = false;
                    otherchk="Enter other customer name";
                }

            }
            else
            {
                Cust= $(this).find("#Customer"+ $(this).find("#lblassiid").text().trim()).val();
            }

            if(cat == "Reserved" && expbilldate == "" && mapdate == "")
            {
                chk = false;
                if(empid=='')
                {
                    empid = $(this).find("#lblemplyeeid").text()+"- Enter the expected billing date and mapped date for reserved status "+otherchk;
                }
                else
                {
                    empid=empid+","+$(this).find("#lblemplyeeid").text()+"- Enter the expected billing date and mapped date for reserved status "+otherchk;
                }
            }
            if(cat == "Reserved")
            {
                if(subcat == "")
                {
                    IsValidate = false;
                    chk = false;
                    alert('Please enter SubCategory for ' + emp4validation);
                    return false;
                }
                if(Cust == "")
                {
                    IsValidate = false;
                    chk = false;
                    alert('Please enter ClientMapping for ' + emp4validation);
                    return false
                }
                if(remarks == "")
                {
                    IsValidate = false;
                    chk = false;
                    alert('Please enter Remarks for ' + emp4validation);
                    return false;
                }
                if(expbilldate == "")
                {
                    IsValidate = false;
                    chk = false;
                    alert('Please enter BillingDate for ' + emp4validation);
                    return false;
                }
                if(mapdate == "")
                {
                    IsValidate = false;
                    chk = false;
                    alert('Please enter MappedDate for ' + emp4validation);
                    return false;
                }
                if(subcat == "")
                {
                    IsValidate = false;
                    chk = false;
                    alert('Please enter SubCategory for ' + emp4validation);
                    return false;
                }
            }
            if(cat == "Deployable Bench" || cat == "NonDeployable Bench")
            {
                if(subcat == "")
                {
                    IsValidate = false;
                    chk = false;
                    alert('Please enter SubCategory for ' + emp4validation);
                    return false;
                }
                if(remarks == "")
                {
                    IsValidate = false;
                    chk = false;
                    alert('Please enter Remarks for ' + emp4validation);
                    return false;
                }
            }

            else if(otherchk!="")
            {
                chk = false;
                empid =  $(this).find("#lblemplyeeid").text()+" - "+otherchk;
            }
            /*debugger;*/
            if (chk == true && IsValidate == true)
            {
                var resecode=$(this).find("#ReservedProjectCode").val().split(" ").join("");
                /*debugger;*/
                selectedValues.push({
                    EmployeeId: $(this).find("#lblemplyeeid").text()
                    , AssignmentID: $(this).find("#lblassiid").text()
                    , Category: $("#Category" + $(this).find("#lblassiid").text().trim()).val(),
                    BenchStatus: $("#BenchStatus" + $(this).find("#lblassiid").text().trim()).val(),
                    Customer:Cust,
                    Remarks: $(this).find("#Remarks").val(),
                    ExpectedBillingDate: $(this).find("#ExpectedBillingDate").val(),
                    MappedDate: $(this).find("#MappedDate").val(),
                    ActionReminder: $("#ActionReminder_" + $(this).find("#lblemplyeeid").text().trim()).val(),
                    ReservedProjectCode: resecode.trim(),
                    HRRFNumber: $(this).find("#HRRFNumber").val()

                });
            }
        });
        if (selectedValues.length != 0 && IsValidate == true) {
            $.ajax({
                type: "POST",
                data: {
                    "SelectedBenchEmployees": selectedValues
                },
                url: '@Url.Action("Savedetails", "BenchEmployee")',
                success: function (result) {
