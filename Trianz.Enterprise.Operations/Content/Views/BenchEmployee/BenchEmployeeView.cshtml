                        }
                    else
                    {
                        bootbox.alert(empid, function () {
                            window.location.reload();
                        });
                    }
                },
                failure: function (data) {
                    alert(data);
                }
            });
        }
        else {
            if(empid =="")
            {
                //bootbox.alert('Saved successfully!!', function () {window.location.reload();});
            }
            else
            {
                //bootbox.alert(empid, function () {window.location.reload();});
            }
            //bootbox.alert("Please fill the values to the fields");
        }
    }

    $('#btnExportToExcel').click(function () {
        //$(this).hide();
        $("#btnProcessing").show();

        $.ajax({
            url: "@Url.Action("ExportReport", "BenchEmployee")",
            data: "",
            type: "POST",
            datatype: "JSON",
            cache: false,
            success: function (response) {
                if (response == "success") {
                    window.location = "@Url.Action("GenerateProjectInfo", "BenchEmployee")";

                    setTimeout(function () {
                        $("#btnExportToExcel").show();
                        $("#btnProcessing").hide();
                    }, 10000);
                }
                else if (reresponsesult == "Error")
                       {
                        window.location.href = '@Url.Action("Error", "Error")';
                        }
                else if (response== "Sessionexpired") {
                window.location.href = '@Url.Action("SessionExpire", "Signout")';
                    }
            },
            error: function (error) {
                alert(error.statusText);
            }
        });
    });
</script>
