
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@*<link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/font-awesome/4.5.0/css/font-awesome.min.css">
<script src="~/Scripts/validator.js"></script>*@

<style type="text/css">
    .HRRF_custom .control-label {
        text-align: right;
    }

    .HRRF_custom .panel-default > .panel-heading {
        background-color: #f5f5f5;
        border-color: #ddd;
    }

    .HRRF_custom .panel-heading {
        cursor: default;
        font-weight: normal;
    }

    .HRRF_custom .panel-body {
        padding: 15px;
    }

    .error-msg-font-size {
        font-size: 12px;
    }

    .panel-default {
        /*box-shadow: 1px 1px 21px;*/
        box-shadow: 0px 0px 11px 0px rgba(0,0,0,0.75);
    }

    .col-md-4 {
        width: 30%;
    }

    .col-md-offset-4 {
        margin-left: 36%
    }
</style>

<div class="col-md-12 nopadding">
    <div class="subpage_header page-header nomargin-top">
        <p>Role Master - Login</p>
    </div>
</div>

<h4 class="text-center">Please enter your login credentials to view role master page.</h4>

<div class="row" style="margin-top: 25px;">
    <div class="col-md-4 col-md-offset-4">
        <form method="post" id="frmLogin" role="form" data-toggle="validator" action='@Url.Action("", "login")'>
            <div class="panel panel-default">
                <div class="panel-heading text-center" style="padding: 15px 15px;">
                    @*<i class="fa fa-sitemap"></i> Login*@
                    <img src="~/Content/images/Talento-Logo.png" alt="Talento" />
                </div>
                <div class="panel-body">
                    <div class="form-group">
                        <label for="pwd">Username:</label>
                        <div class="input-group">
                            <span class="input-group-addon"><span class="glyphicon glyphicon-user"></span></span>
                            <input name="userName" type="text" id="userName" class="form-control" placeholder="Enter UserName" required data-error="Username should not be blank">
                        </div>
                        <div class="help-block with-errors error-msg-font-size"></div>
                    </div>
                    <div class="form-group">
                        <label for="pwd">Password:</label>
                        <div class="input-group">
                            <span class="input-group-addon"><span class="glyphicon glyphicon-lock"></span></span>
                            <input name="password" type="password" id="password" class="form-control" placeholder="Enter Password" required data-error="Password should not be blank">
                        </div>
                        <div class="help-block with-errors error-msg-font-size"></div>
                    </div>

                    @*<div class="text-right">
                            <input type="submit" name="btnLogin" value="Login" id="btnLogin" class="btn btn-primary" style="padding: 6px 35px;">
                        </div>*@

                </div>
                <div class="panel-footer">
                    <div class="text-right">
                        <input type="submit" name="btnLogin" value="Login" id="btnLogin" class="btn btn-default" style="padding: 6px 35px;">
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@if (Convert.ToBoolean(TempData["IsInvalidCredentials"]))
{
    <script type="text/javascript">

        var strScript = "";

        strScript =  strScript + "<div class='row'>";
        strScript =  strScript + "  <div class='col-md-1' style='margin-top: 20px;'>";
        strScript =  strScript + "      <i class='fa fa-exclamation-triangle fa-2x text-danger'></i>";
        strScript =  strScript + "  </div>";
        strScript =  strScript + "  <div class='col-md-11'>"
        strScript =  strScript + "      You have entered invalid credentials. Please contact your Administrator.<br>Now you will be redirected to home page automatically.";
        strScript =  strScript + "  </div>";
        strScript =  strScript + "</div>";

        bootbox.alert(strScript, function () {
            window.location.href = '@Url.Action("index", "trHome")';
        });

        @*bootbox.alert("<i class='fa fa-exclamation-triangle fa-3x'></i> You have entered invalid credentials. Please contact your Administrator.<br />Now page will be redirected to home automatically.", function () {
            window.location.href = '@Url.Action("index", "trHome")';
        });*@
    </script>
}
