    </text>),
  ExternalResourcesGrid.Column("CancellationReason",
header: "Cancel Reasons",
format: @<text>
            <div class="divCancellation candiv">
                @Html.DropDownList("txtCancellationReason", new SelectList((System.Collections.IEnumerable)ViewData["_Cancelreason"]), "Select an option",
                                                    new { @class = "edit-mode txtCancellationReason", @onchange = "CancellationRemarksChange(this,this.value)", @disabled = "disabled" })

