                     }
    </text>),
ExternalResourcesGrid.Column("DOC",
header: "Cancel Date",
format: @<text>
            <span id="Doc" class="display-mode">@(@item.CancelDate == null ? string.Empty : @item.CancelDate.ToString("dd/MMM/yyyy"))</span>
