<div class="col-md-12 nopadding">
    <div id="gdExternalHire" class="table table-responsive">
        @if (Model.ExternalFulfullmentHireDetails == null)
        {
            <center><p>No Data Found</p></center>
        }
        else
        {
            var ShowHeader = true;
            if (Model.ExternalFulfullmentHireDetails.Count() == 0)
            {
                ShowHeader = false;<center><p>No Data Found</p></center>}

            @ExternalResourcesGrid.GetHtml(
         tableStyle: "table table-bordered table-striped p-resources",
         fillEmptyRows: false,
         //headerStyle: "header",
         alternatingRowStyle: "alt",
         selectedRowStyle: "select",
         displayHeader: ShowHeader,
         mode: WebGridPagerModes.All,
         firstText: "<< First",
         previousText: "< Prev",
         nextText: "Next >",
         lastText: "Last >>",
         htmlAttributes: new { id = "DashboardGrid" },
         columns: ExternalResourcesGrid.Columns
         (
             ExternalResourcesGrid.Column("", format:@<text>
                    @if (item.RequestStatus.ToLower() != "fulfilled" && item.RequestStatus.ToLower() != "cancelled")
                             {
                        @:<a><span class="ui-icon ui-icon-pencil" id="@item.ExternalHireId"></span></a>
                             }
                    <a><span class="ui-icon ui-icon-circle-check" id="@item.ExternalHireId"></span></a>
                    <a><span class="ui-icon ui-icon-closethick" id="@item.ExternalHireId"></span></a>
                    <label id="lblExternalHireId" style="display:none;">@item.ExternalHireId</label>
            </text>),
      ExternalResourcesGrid.Column("TR#",
                          //header: "TR#",
                          format: @<text>
                                        <span id="idHrrfNumber">@item.HrrfNumber</span> @*class="display-mode"*@
                        </text>),
ExternalResourcesGrid.Column("RecruiterName",
                  header: "Recruiter Name",
                  format: @<text>
                                @*@if (item.RecruiterName.Trim() == string.Empty)
                                {

                                    @Html.DropDownList("ddlRecruiterName", new SelectList((System.Collections.IEnumerable)ViewData["_RecruiterName"], "Value", "Text"),
                                  new { @class = "edit-mode ddlRecruiterName" })
                                }
                                else
                                {
                                    @Html.DropDownList("ddlRecruiterName", new SelectList((System.Collections.IEnumerable)ViewData["_RecruiterName"], "Value", "Text"),
                                     new { @class = "edit-mode ddlRecruiterName", @disabled = "disabled" })
                                }*@

                                @Html.DropDownList("ddlRecruiterName", new SelectList((System.Collections.IEnumerable)ViewData["_RecruiterName"], "Value", "Text"),
                                     new { @class = "edit-mode ddlRecruiterName", @disabled = "disabled" })

                                @if (Session["EmployeeId"].ToString() == "106919" || Session["EmployeeId"].ToString() == "106911" || Session["EmployeeId"].ToString() == "103773" ||
                                Session["EmployeeId"].ToString() == "105009" || Session["EmployeeId"].ToString() == "107300" || Session["EmployeeId"].ToString() == "106919"
                                || Session["EmployeeId"].ToString() == "103773" || Session["EmployeeId"].ToString() == "104296"
                                || Session["EmployeeId"].ToString() == "106910" || Session["EmployeeId"].ToString() == "107098" || Session["EmployeeId"].ToString() == "107341")
                                {
                                    <script>
                                        $('.ddlRecruiterName').removeAttr('disabled');
                                    </script>
                                         }

                                <input type="hidden" id="RecruiterName" value="@item.RecruiterId" />
                                <span id="RecruiterName" class="display-mode">@item.RecruiterName</span>

                </text>),
ExternalResourcesGrid.Column("Name",
         header: "Resource Name",
