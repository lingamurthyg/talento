    </text>),
    @*ExternalResourcesGrid.Column("FulfilmentDate",
                            header: "FulfilmentDate",
                            format: @<text>
    <span id="FulfilmentDateid" class="display-mode"></span>
    <input type="text" class="edit-mode date-picker fulfil-date" style="width:100px;" value="@(@item.FulfilmentDate == null ? String.Empty : @item.FulfilmentDate.ToString("MM/dd/yyyy"))" />
                            </text>),*@
ExternalResourcesGrid.Column("FulfilmentDate",
header: "Expected Fulfilment Date",
format: @<text>
            <span id="ExpectedFulfilmentDateid" class="display-mode">@(@item.FulfilmentDate == null ? string.Empty : @item.FulfilmentDate.ToString("dd/MMM/yyyy"))</span>
            @if (@item.FulfilmentDate != null)
                     {
