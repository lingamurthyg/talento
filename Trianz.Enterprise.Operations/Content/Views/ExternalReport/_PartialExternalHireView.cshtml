                        <span id="Name" class="display-mode">@item.Name</span>
                        <input type="text" class="edit-mode" id="txtName" size="10" value="@item.Name" />
        </text>),
ExternalResourcesGrid.Column("EmployeeId",
         header: "Employee Id",
         format: @<text>
                        <span id="EmpId" class="display-mode">@item.EmployeeId</span>
