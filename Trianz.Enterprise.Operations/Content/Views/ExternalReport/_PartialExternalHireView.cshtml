        </text>),
ExternalResourcesGrid.Column("RequestStatus",
 header: "Request Status",
 format: @<text>
                <input type="hidden" id="hfRequestStatus" value="@item.RequestStatus" />
                <span id="RequestStatus" class="display-mode">@item.RequestStatus</span>
                @Html.DropDownList("ddlRequestStatus", new SelectList((System.Collections.IEnumerable)ViewData["_ddlRequestStatus"]), new { @class = "edit-mode ddlRequestStatus" })
    </text>),
ExternalResourcesGrid.Column("FulfilmentRemarks",
header: "Remarks",
format: @<text>
