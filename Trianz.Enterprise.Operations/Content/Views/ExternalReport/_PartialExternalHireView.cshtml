<script type="text/javascript">
    function GetDOJ_EmpId(empid) {
        debugger
        var EmpID1 = empid.value;
        if (EmpID1 != null && EmpID1 != '') {

            $.ajax({
                async: false,
                cache: false,
                type: "GET",
                url: "@(Url.Action("GetEmployeeDateofJoin", "ExternalReport"))",
                data: { EmployeeID: EmpID1 },
                success: function (result) {
                    debugger;
                    if (result.EmployeeID > 0) {
                        var dateString = result.DOJ.substr(6);
                        var currentTime = new Date(parseInt(dateString));
                        var month = currentTime.getMonth() + 1;
                        var day = currentTime.getDate();
                        var year = currentTime.getFullYear();
                        var date = month + "/" + day + "/" + year;
                        $(empid).closest("td").parent().find(".doj-date").val(date);
                    }
                    else {
                        $(empid).closest("td").parent().find(".doj-date").val("");
                        empid.value = "";
                        bootbox.alert(result.Message);
                    }
                },

            })
        }
        else {
            $(empid).closest("td").parent().find(".doj-date").val("");
            empid.value = "";
            bootbox.alert("Enter EmployeeID");

        }
    }
    function CancellationRemarksChange(current, value) {
        if (value == "Duplicate")
            $(current).parent(".divCancellation").find(".clsDuplicateHrrf").show();
        else
            $(current).parent(".divCancellation").find(".clsDuplicateHrrf").css("display", "none");
    }

    $(document).ready(function () {
        debugger

        HidebusyContent()
        //$('#divLoader').modal('hide');
        $(".ddlRequestStatus").on("change", function () {
            debugger
            var chkValue = $(this).val();
            if (chkValue == "Fulfilled") {
                $(this).closest("td").parent().find(".EmpId").attr("disabled", false);
                $(this).closest("td").parent().find(".doj-date").attr("disabled", true);
            } else {
                $(this).closest("td").parent().find(".EmpId").attr("disabled", true);
                $(this).closest("td").parent().find(".doj-date").attr("disabled", false);
                $(this).closest("td").parent().find(".doj-date").val("");
                $(this).closest("td").parent().find(".EmpId").val("");
            }
            if (chkValue == "Cancelled") {
                $(this).closest("td").parent().find(".doc-date").attr("disabled", false);
                $(this).closest("td").parent().find(".txtCancellationReason").attr("disabled", false);
            } else {
                $(this).closest("td").parent().find(".doc-date").attr("disabled", true);
                $(this).closest("td").parent().find(".txtCancellationReason").attr("disabled", true);
                $(this).closest("td").parent().find(".doc-date").val("");
                $(this).closest("td").parent().find(".txtCancellationReason").val("");
            }
        });
    });

</script>


