    function DeleteRecords() {
        debugger
        var chekedValues = "";
        $("#tableTrainingData td").find("input[name='chkRow']:checked").each(function () {
            if(this.disabled==false)
            {
                chekedValues += $(this).val() + ',';
            }
            else
            {

            }
        });

        if (chekedValues != "") {
            chekedValues = chekedValues.slice(0, -1);
        }
        if (chekedValues != "") {
            $.ajax({
                url: '@Url.Action("DeleteAll", "Training")',
                data: JSON.stringify({ TrainingID: chekedValues }),
                type: 'POST',
                datatype: "html",
                contentType: 'application/json; charset=utf-8',
                cache: false,
                success: function (result) {
                    alert("Deleted Records Successfully ");
                    if (result != null) {
                        $("#divLoader").hide();
                        $("#divReportGrid").html(result);
                        window.location.reload();
                        
                    }
                    
                },
                error: function (result) {

                    alert(JSON.stringify(error));
                }
            });
        }

           
        

    }
    function GetReportByParameter() {

        var ProgramName = $("#ddlprogram option:selected").val();
        var Location = $("#ddllocation option:selected").val();
        var Practice = $("#ddlpractice option:selected").val();
        var AttendanceStatus = $("#ddlattendence option:selected").val();
        var Source = $("#ddlsource option:selected").val();
        var Category = $("#ddlcategory option:selected").val();
        var Mode = $("#ddlmode option:selected").val();
        var StartDate = $("#txtchktartdate").val();
        var EndDate = $("#txtchkenddate").val();
        var dt = new Date().toISOString().slice(0, 10)

        if (Date.parse(StartDate) > Date.parse(dt)) {

            alert("start date can not be greater than  current date ");
            return false;
        }
        if (Date.parse(StartDate) > Date.parse(EndDate)) {

            alert("end date can not be less than  start date ");
            return false;
        }

        if (Date.parse(EndDate) > Date.parse(dt)) {

            alert("end date can not be greater than  current date ");
            return false;
        }
        $("#divLoader").show();
        $.ajax({
            url: '@Url.Action("GenerateReport", "Training")',
            data: JSON.stringify({ ProgramName: ProgramName, Location: Location, Practice: Practice, AttendanceStatus: AttendanceStatus, Source: Source, Category: Category, Mode: Mode, StartDate: StartDate, EndDate: EndDate }),
            type: 'POST',
            datatype: "html",
            contentType: 'application/json; charset=utf-8',
            cache: false,
            success: function (result) {

                if (result != null) {
                    $("#divLoader").hide();
                    $("#divReportGrid").html(result);

                }

            },
            error: function (result) {

                alert(JSON.stringify(error));
            }
        });
    };



    function Downloadreport() {

        var ProgramName = $("#ddlprogram option:selected").val();
        var Location = $("#ddllocation option:selected").val();
        var Practice = encodeURIComponent($("#ddlpractice option:selected").val());
        var AttendanceStatus = $("#ddlattendence option:selected").val();
        var Source = $("#ddlsource option:selected").val();
        var Category = $("#ddlcategory option:selected").val();
        var Mode = $("#ddlmode option:selected").val();
        var StartDate = $("#txtchktartdate").val();
        var EndDate = $("#txtchkenddate").val();
        var dt = new Date().toISOString().slice(0, 10)

        if (Date.parse(StartDate) > Date.parse(dt)) {

            alert("start date can not be greater than  current date ");
            return false;
        }
        if (Date.parse(StartDate) > Date.parse(EndDate)) {

            alert("end date can not be less than  start date ");
            return false;
        }

        if (Date.parse(EndDate) > Date.parse(dt)) {

            alert("end date can not be greater than  current date ");
            return false;
        }

        window.location.href = '@Url.Action("DownloadReport", "Training")' + '?ProgramName=' + ProgramName + '&Location=' + Location + '&Practice=' + Practice + '&AttendanceStatus=' + AttendanceStatus + '&Source=' + Source + '&Category=' + Category + '&Mode=' + Mode + '&StartDate=' + StartDate + '&EndDate=' + EndDate;

    };
    $("#btnDownloadReport").click(function () {
        Downloadreport();

    });
    $("#btnViewReport").click(function () {
        GetReportByParameter();

    });
    $("#btnDeleteAll").click(function () {
        debugger
        DeleteRecords();

    });
    

</script>


<script type="text/javascript">
  
    function Clean(e) {

        $(e).val('');
    }
</script>