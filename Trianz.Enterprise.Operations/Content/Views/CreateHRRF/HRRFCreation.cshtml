    function UpdateSecondarySkills() {
        var values = [];
        var selectedSecOpts = $('#SecondarySkills option:selected');
        var count = 1;
        var dropdownSecondary = $("#ddlSProficiency").clone().removeAttr("style");
        var SecondaryRate = 30;
        for (var x in selectedSecOpts) {
            if (count <= selectedSecOpts.length) {
                var id = '#tr_' + $(selectedSecOpts[x]).val();
                if ($("#SecondarySkillsgrid").find(id).length > 0) {

                }
                else if ($("#PrimarySkillsGrid").length > 0 && $("#PrimarySkillsGrid").find(id).length > 0) {
                    var skilltext = $("#PrimarySkillsGrid").find(id).find('td:nth-child(2)').text();
                    alert(skilltext + " is already selected as PrimarySkill");
                }
                else {
                    var NoRecords = $(".secchk").length + 1;
                    if (NoRecords == 1) {
                        var NOR = $(".primarychk").length;
                        if (NOR == 0)
                            var NOR = $(".primarychk").length + 1;
                        var Proficiency = 70 / NOR;
                        $(".primary").html(Proficiency.toFixed(0));
                        $(".primary").attr('text', Proficiency.toFixed(0));
                    }
                    var SecProficiency = SecondaryRate / NoRecords;
                    $("#SecondarySkillsgrid").append("<tr id=tr_" + $(selectedSecOpts[x]).val() + "><td>" +

