for (var x = 0; x < data.length; x++) { markup += "<option value='" + data[x].Account + "'>" + data[x].Account + "</option>"; }
$("#AccountName").html(markup).show();
}
},
error: function (thrownError) {
alert(thrownError);
}
});
}
var _Grade = $('#Grade').val()
GetRoles(Practice, _Grade, costcentervalue)
