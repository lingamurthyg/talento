    function GetPrimSecondSkills() {
        //  debugger;
        var PrimarySkills = '';
        var SecondarySkills = '';

        $("#PrimarySkillsGrid tr").each(function () {
            var x = $(this).attr('id');
            if (x != undefined) {
                var pID = x.split('_')[1] + ":" + $(this).find(".primary").attr('text');
                PrimarySkills = PrimarySkills + pID + ';';
            }

        });
        $("#SecondarySkillsgrid tr").each(function () {
            var x = $(this).attr('id');
            if (x != undefined) {
                var SID = x.split('_')[1] + ":" + $(this).find(".secondary").attr('text');
                SecondarySkills = SecondarySkills + SID + ';';
            }

        });

        var NewSkills = [];
        $("#tabledisplaySkills").find("tbody tr").each(function () {

            PrimarySkills = $(this).find(".skill").text() + ":" + $(this).find(".compid").text() + ":" + $(this).find(".expertisetext").text() + ":" + $(this).find(".mandatory").text() + ';'
            NewSkills.push(PrimarySkills);
        });


        $('input[type=hidden][name="hiddenPrimarySkills"]').val(NewSkills);

    }

</script>
