<script>
    $(document).ready(function () {

        $("button").click(function () {
            $(".container").toggleClass("verticalTab");
        });


        $("nav").find("a").click(function () {
            $("nav").find("a").removeClass("activeTab");
            $(this).addClass("activeTab");
        });
    })


</script>



<script>
    var counter = 0;
    $("#AccountName").change(function () {

        //$("#divLoader").show();
        GetProjects();
    });
    function nospaces(t) {
        if (t.value.match(/\s/g)) {
            t.value = t.value.replace(/\s/g, '');
        }
    }
    function GetProjects() {

        var url = '@Url.Content("~/CreateHRRF/GetProjectSFilterAccount")';
        var ddlaccunt = $("#AccountName").val();
        var Practice = $('#Practice').val()
        var costcenter = $('#CostCenter').val()
        var Purpose = $('#Purpose').val()
        $('#Projects').html('');
        $('#Projects').append(('<option value="">Select an option</option>'));
        $.ajax({
            url: url,
            type: 'GET',
            cache: false,
            data: { Account: ddlaccunt, Practice_value: Practice, cost: costcenter, Pur_pose: Purpose },
            success: function (data) {
                if (data != "null" && data != "Error") {
                    $.each(data, function (i, dt) {
                        $('#Projects').append($('<option></option>').val(dt.ProjectCode).html(dt.ProjectName));
                    });
                }
                else if (data == "Error") {
                    window.location.href = '@Url.Action("Error","Error")';

                }

            },
            error: function (thrownError) {
                alert(thrownError);
            }
        });
    }
    $("#ReplacementEmpId").autocomplete({
        source: function (request, response) {

            var Empnameids = new Array();
            $.ajax({
                async: false,
                cache: false,
                type: "POST",
                url: "@(Url.Action("Autocomplete", "CreateHRRF"))",
                data: { "term": request.term },
                success: function (data) {
                    if (data != "null" && data != "Error") {

                        for (var i = 0; i < data.length; i++) {
                            Empnameids[i] = { label: data[i].Key, Id: data[i].Value };
                        }
                    }
                     else if (data == "Error") {
                    window.location.href = '@Url.Action("Error","Error")';

                }

                }
            });
            // response(Empnameids);
            response(Empnameids.slice(0, 50));

        },
        select: function (event, ui) {
            //    debugger;
            //fill selected customer details on form
            ReplacementEmpId = ui.item.Id;

        }
    });
    $('#ReplacementEmpId').blur(function () {
        //   debugger;
        var replacedid = $('#ReplacementEmpId').val();
        var replacedemp = replacedid.split("-");
        if (replacedemp.length == 2) {
            $('#ReplacementEmpId').val(replacedemp[0]);
        }
        else {
            bootbox.alert("Please select the valid Employee Id from the list");
            $('#ReplacementEmpId').val("");
        }
    });


function autoPopulatedAccount(costcentervalue) { var Practice = $('#Practice').val()
var Purpose = $('#Purpose').val()
if ($.trim($('#Purpose').val()).length == 0) {
bootbox.alert("Please select the Purpose");
