<script type="text/javascript">
    $(function () {

     $(":radio[name='IsIndustryDomainSkill'][value='false']").attr('checked', 'checked');
        $(":radio[name='IsSpecialClient'][value='false']").attr('checked', 'checked');
        $('input[type=radio][name="IsSpecialClient"]').on('change', function () {
            if ($(this).val() == "true") {
                $("#divSpecialClient").show();
            } else {
                $("#divSpecialClient").hide();
            }

        });
        $('input[type=radio][name="IsIndustryDomainSkill"]').on('change', function () {
            if ($(this).val() == "true") {
                $("#divIndustryDomainSkill").show();
            } else {
                $("#divIndustryDomainSkill").hide();
            }

        });
           var platformSelect = $("#SpecificPlatform");
        platformSelect.empty();
                $.ajax({
                    url: '@Url.Action("GetSpecificPlatForms", "CreateHRRF")',
                    type: "GET",
                    dataType: "JSON",
                    success: function (data) {
                        if (data != "null" && data != "Error"){
                            var markup = "<option value=''>Select an option</option>";
                            for (var x = 0; x < data.length; x++) {
                                markup += "<option value='" + data[x].SpecificPlatFormName + "'>" + data[x].SpecificPlatFormName + "</option>";
                            }
                            markup += "<option value='NA'>NA</option>";
                            $("#SpecificPlatform").html(markup).show();
                        }
                         else if (data == "Error") {
                    window.location.href = '@Url.Action("Error","Error")';

                }

            },
            error: function (error) {
                alert(error);
            }
        });
        var certificationSelect = $("#Certifications");
        certificationSelect.empty();
                $.ajax({
            url: '@Url.Action("GetCertifications", "CreateHRRF")',
            cache: false,
                    type: "GET",
                    dataType: "JSON",
                    success: function (data) {
                        if (data != "null" && data != "Error") {
                            var markup = "<option value=''>Select an option</option>";
                            for (var x = 0; x < data.length; x++) {
                                markup += "<option value='" + data[x].CertificationName + "'>" + data[x].CertificationName + "</option>";
                            }
                            markup += "<option value='NA'>NA</option>";
                            $("#Certifications").html(markup).show();
                        }
                        else if (data == "Error") {
                    window.location.href = '@Url.Action("Error","Error")';

                }
            },
            error: function (error) {
                alert(error);
            }
        });

        var nowDate = new Date();
        var today = new Date(nowDate.getFullYear(), nowDate.getMonth(), nowDate.getDate(), 0, 0, 0, 0);

        $('#datetimepicker1').datepicker({

            keyboardNavigation: false,
            forceParse: false,
            autoclose: true,
            todayHighlight: true,
            startDate: today
            //format: 'dd/mm/yyyy',
        }).on('changeDate', function (e) {
            $(this).datepicker('hide');
            /*$('#BillingDate').val($("#ExpectedStart").val());*/

        });

        $('#datetimepicker2').datepicker({
            keyboardNavigation: false,
            forceParse: false,
            autoclose: true,
            todayHighlight: true,
            startDate: today
            //format: 'dd/mm/yyyy',
        }).on('changeDate', function (e) {
            $(this).datepicker('hide');
        });

        $('#datetimepicker3').datepicker({
            keyboardNavigation: false,
            forceParse: false,
            autoclose: true,
            todayHighlight: true,
            startDate: today
            //format: 'dd/mm/yyyy',
        }).on('changeDate', function (e) {
            $(this).datepicker('hide');
        });
    });
    function toggleChevron(e) {
        $(e.target)
            .prev('.panel-heading')
            .find("i.indicator")
            .toggleClass('glyphicon-chevron-down glyphicon-chevron-up');
    }

    $(function () {
        $('#accordion').on('hidden.bs.collapse', toggleChevron);
        $('#accordion').on('shown.bs.collapse', toggleChevron);
    });

    $(function () {
        var PmRole = $('#PMRole').val()
        if (PmRole == "PM") {
            $.ajax({
                url: '@Url.Action("GetProjectForPM", "CreateHRRF")',
                // data: { CategoryId: _CategoryId },
                cache: false,
                type: "GET",
                dataType: "JSON",
                success: function (objskills) {
                    if (objskills != "Error") {
                        document.getElementById("Projects").value = objskills;
                    }
                    else if (data == "Error") {
                    window.location.href = '@Url.Action("Error","Error")';

                }

                },
                error: function (objskills) {

                }
            });
        }
    });






</script>


