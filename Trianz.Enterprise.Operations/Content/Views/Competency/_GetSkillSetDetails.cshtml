</script>

<script>
    function HideLastAnchor() {
        if ($("#ajaxgrid1 tfoot tr td").find("a").length > 0) {
            $("#ajaxgrid1 tfoot tr td").find("a").each(function () {
                if ($(this).text() == ">") {
                    $(this).css("display", "none");
                }

            });
        }
    }

    function CreateFooter(PageCount, recardsCount) {
        PageCount = parseInt(PageCount, 10);
        var footer = "<tfoot>";
        footer += "<tr>";
        footer += "<td colspan='5'>";
        var links = "";
        for (var i = 1; i <= (PageCount + 1); i++) {
            links = links + "<a  href='#'>" + i + "</a>&nbsp;";
        }
        footer += links;
        footer += "</td>";
        footer += "<tr>";
        footer = footer + "</tfoot>";

        $("#ajaxgrid1 tbody").after(footer);
    }
</script>