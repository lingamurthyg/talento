                    {
                        <button type="button" id="btnExport" name="btnExport" href="#" onclick="location.href='@Url.Action("GetExcel", "Home")'" title="Export to Excel" class="btn btn-default btn-sm btn-excel">
                            <i class="glyphicon glyphicon-export"></i>
                            Export To Excel
                        </button>
                    }
                </div>
                <div class="col-md-3 col-sm-12 pull-right nopadding-right">
                    @if ((Session["Role"].ToString() == "OM" || Session["Role"].ToString() == "PM" || Session["Role"].ToString() == "DH" || Session["Role"].ToString() == "SM" || Session["Role"].ToString() == "RL" || Session["Role"].ToString() == "LDAdmin" || Session["Role"].ToString() == "CompetencyAdmin"))
                    {
                        if (Session["Role"].ToString() == "OM" || Convert.ToInt32(Session["Grade"])>=4 || Session["Role"].ToString() == "RL")
                        {
                        @Html.DropDownList("ddlMyRequest", myRequest, new { @class = "form-control", onchange = "submit();" })
                        }
                        else if (Convert.ToInt32(Session["Grade"]) < 4)
                        {
                            @Html.DropDownList("ddlMyRequest", myRequestOnly, new { @class = "form-control", onchange = "submit();" })
                        }
                    }
                </div>
                @*<div class="col-md-3">
                        @Html.TextBox("Location", "", new { @class = "form-control", @placeholder = "---Location---" })
                    </div>*@
                <div class="col-md-3 col-sm-12 pull-right nopadding-right">

                    @if (Session["Role"].ToString() == "OM" || Session["Role"].ToString() == "RL")
                    {
                        @Html.DropDownList("ddlPractise", new SelectList((System.Collections.IEnumerable)ViewData["ServiceLine"], "LookupName", "LookupName"),
