            new SelectListItem { Text = "ALL TRs", Value="ALL" },
            new SelectListItem { Text = "Open TRs", Value="Open" },
        };

        //another selectlist
        var myRequestOnly = new List<SelectListItem>
        {
              new SelectListItem { Text = "My Request", Value="MyRequest" ,Selected=true }
        };
    }
   
   @using (Html.BeginForm("Index", "Home", FormMethod.Get, new { @class = "form-horizontal" }))
   {
