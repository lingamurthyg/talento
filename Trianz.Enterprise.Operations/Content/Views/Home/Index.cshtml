            <div class="col-md-6 col-sm-12 nopadding-left">
                <div class="col-md-2 col-sm-12 nopadding-left">
                    @*@if ((Session["Role"].ToString() == "OM" || Session["Role"].ToString() == "PM") || Convert.ToInt32(Session["Grade"]) >= 3)*@

                    @if ((Session["Role"].ToString() == "RL"))
                    {
                        List<string> lstEmpIDs = System.Configuration.ConfigurationManager.AppSettings["CreateTR-RL"].Split(',').ToList();

                        bool IsValid = lstEmpIDs.Where(e => Session["EmployeeId"].ToString().Contains(e)).Any();
                        if (IsValid)
                        {
                            @:<button id="btnCreate" type="button" onclick="location.href='@Url.Action("HRRFCreation", "CreateHRRF")'" class="btn btn-primary pull-left" style="margin-right: 10px;">Create TR</button>
                        }
                    }
                    else
                    {
                        if (Convert.ToInt32(Session["Grade"]) >= 1)
                        {
                            <button id="btnCreate" type="button" onclick="location.href='@Url.Action("HRRFCreation", "CreateHRRF")'" class="btn btn-primary pull-left">Create TR</button>
                        }
                    }
                </div>
                <div class="col-md-10 col-sm-12 text-right nopadding-right">
                    @*@Html.TextBox("Location", "", new { @class = "form-control", @placeholder = "---Location---" })*@
                    @if ((Session["Role"].ToString() == "OM" || Session["Role"].ToString() == "PM" || Session["Role"].ToString() == "DH" || Session["Role"].ToString() == "SM" || Session["Role"].ToString() == "RL" || Session["Role"].ToString() == "LDAdmin" || Session["Role"].ToString() == "CompetencyAdmin"))
                    {
                                    @Html.TextBox("SearchString", ViewBag.CurrentFilter as string, new { @class = "input-sm ", @placeholder = "Enter TR" })
                                    <input class="btn btn-primary" type="submit" value="Search" />
                    }
                </div>

            </div>
            <div class="col-md-6 col-sm-12 pull-right text-right nopadding-right">
