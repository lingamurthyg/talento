@model IEnumerable<Trianz.Enterprise.Operations.Models.ValidationModel>
@*@model IEnumerable<Trianz.Enterprise.Operations.Models.HRRF>*@
@{
    ViewBag.Title = "Index";
    var grid = new WebGrid(Model, canPage: true, canSort: true, rowsPerPage: 20,
    selectionFieldName: "SelectedRow");

    grid.Pager(WebGridPagerModes.All);
}
<style>
    #gridT, #gridT tr {
        border: 1px solid #0D857B;
    }

    #nestedT, #nestedT tr {
        border: 1px solid #f3f3f3;
    }

    #nestedT {
        margin: 0px 0px 0px 10px;
        padding: 5px;
        width: 95%;
    }

        #nestedT th {
            font-size: 12px;
        }

    .recordHoverEffect {
        cursor: pointer;
    }

        .recordHoverEffect:hover {
            background-color: rgb(248, 242, 242);
            /*background-color: #7c7c7c;*/
        }

    .glyphicon-minus-sign, .glyphicon-plus-sign {
        border: none;
    }
    .grayedOut {
        cursor: text;

    }
</style>

<script>
    $(document).ready(function () {
        //debugger;
        var size = $("#LoadGrid #gridT > thead > tr >th").size(); // get total column
        //alert(size)
        $("#LoadGrid #gridT > thead > tr >th").last().remove(); // remove last column
        $("#LoadGrid #gridT > thead > tr").prepend("<th></th>"); // add one column at first for collapsible column
        
        $("#LoadGrid #gridT > tbody > tr").each(function (i, el) {
            var xys = $(this).find("#nestedT tbody tr td").size();
            if (xys > 0) {
                $(this).prepend(
                $("<td></td>")
                    .addClass("glyphicon")
                .addClass("glyphicon-minus-sign")
                .addClass("recordHoverEffect")
                 //.addClass("recordHoverEffect:hover")
                .attr('title', "click for show/hide")
                );
            }
            else {
                $(this).prepend(
               $("<td></td>")
                   .addClass("glyphicon")
               .addClass("glyphicon-minus-sign")
               .addClass("grayedOut")
               //.addClass("recordHoverEffect")
               //.attr('title', "click for show/hide")
               );
            }
           
            //Now get sub table from last column and add this to the next new added row
            var table = $("table", this).parent().html();
            //add new row with this subtable
            $(this).after("<tr><td></td><td style='padding:5px; margin:0px;' colspan='" + (size - 1) + "'>" + table + "</td></tr>");
            $("table", this).parent().remove();
            // ADD CLICK EVENT FOR MAKE COLLAPSIBLE
            if (xys > 0) {
                $(".recordHoverEffect", this).on("click", function () {
                    $(this).parent().closest("tr").next().slideToggle(100);
                    $(this).toggleClass("glyphicon-plus-sign glyphicon-minus-sign");
                });}
            else {

                $(".recordHoverEffect", this).off("click", function () {
                                     
                    //$("td.glyphicon recordHoverEffect glyphicon-plus-sign").addClass("grayedOut");
                    $(this).parent().closest("tr td").css("cursor" , "not-allowed");
                    $(this).parent().closest("tr").next().hide();
                  
                });
            }
        });

        //by default make all subgrid in collapse mode
        $("#LoadGrid #gridT > tbody > tr td.glyphicon-minus-sign").each(function (i, el) {
            $(this).toggleClass("glyphicon-plus-sign glyphicon-minus-sign");
            $(this).parent().closest("tr").next().slideToggle(100);
        });
    });
</script>
<style>
    .ui-autocomplete {
        max-height: 100px;
        overflow-y: auto;
        /* prevent horizontal scrollbar */
        overflow-x: hidden;
    }
    /* IE 6 doesn't support max-height
    * we use height instead, but this forces the menu to always be this tall
    */
    * html .ui-autocomplete {
        height: 100px;
    }
</style>
<script language="javascript">
    //TR Search Field Suggestions
    $(function () {
        $("#SearchString").autocomplete({
            source: function (request, response) {
                $.ajax({
                    // url: "../Home/GetAllHrrfNum",
                    url: '@Url.Action("GetAllHrrfNum", "Home")',
                    data: "{ 'name': '" + request.term + "' }",
                    dataType: "json",
                    type: "POST",
                    contentType: "application/json; charset=utf-8",
                    dataFilter: function (data) { return data; },
                    success: function (data) {
                        if (data != '') {
                            response($.map(data, function (item) {
                                return {
                                    value: item.HRRFNumber,
                                    text: item.HRRFNumber
                                };
                            }));
                        }
                        else {
                            response('');
                        }

                    },
                    error: function (XMLHttpRequest, textStatus, errorThrown) {

                    }
                });
            },
            select: function (event, ui) {

                $(':hidden[id=hdnmedicineid]').val(ui.item.text.toString());
                $(':hidden[id=hdnmedicinenm]').val(ui.item.value.toString());

            },

            minLength: 1,
            autoFocus: true
        });

    });

</script>

<script type="text/javascript">

    $(function () {
        $(document).tooltip();
    });
   
</script>



<div id="LoadGrid">
    @{
