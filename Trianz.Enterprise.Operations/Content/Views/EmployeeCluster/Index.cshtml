    <div style="overflow-x:auto;    background-color: #ffffff;
    margin: 21px;
    position: relative;
    left: -9px;width: 98%;">
        <div id="divGridContent1" class="table table-responsive" style="margin-bottom: -98px;">
            <table id="tablePractice" class="table table-striped table-bordered dt-responsive nowrap" cellspacing="0" style="margin:0px; width: 100%;">
                <thead id="thead">
                    <tr style="background-color: #E1F3FF !important; color: black; ">
                        <th>Team Member Name</th>
                        <th>Practice</th>
                        <th>Cluster Name</th>
                        <th>Cluster Lead Name</th>
                        <th>Account Name</th>
                        <th>Project Code</th>
                        <th>Manager</th>
                        <th>Skills</th>
                        <th></th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.ClusterLeadlst)
                    {

                        <tr>
                            <td style="@item.Style"><a style="@item.Style" href="mailto:@item.TeamMemberEmailID">@item.TeamMemberName</td>
                            @if (item.PrimaryCluster == "N")
                            {
                                <td style="@item.Style">@item.PracticeName</td>
                            }
                            else
                            {
                                <td style="@item.Style">@item.PracticeName</td>
                            }
                            <td style="@item.Style">@item.ClusterName</td>
                            <td style="@item.Style"><a style="@item.Style" href="mailto:@item.ClusterLeadEmailId">@item.ClusterLeadName</td>

                            <td style="@item.Style">@item.AccountName</td>
                            <td style="@item.Style">
                                <span data-toggle="tooltip" data-placement="top" title="@item.ProjectName">@item.ProjectCode</span>
                            </td>
                            <td style="@item.Style">@item.SupervisorName</td>
                            <td style="cursor: pointer;" title="@item.SkillSet">
                                @((item.SkillSet != "" && item.SkillSet != null) ? item.SkillSet.Length < 30 ? item.SkillSet : item.SkillSet.Substring(0, 25) + " ..." : string.Empty)
                                <span id="hdnSkillId" style="display:none;">@item.SkillIds</span>
                            </td>
                            <td>
                                @if (item.ReviewFlag == 1 && item.IsResume == 1)
                                {
                                    <img src="~/Content/images/rightmark1.png" style="height: 24px;" />
                                }
                                @if (item.ReviewFlag == 1 && item.IsResume == 0)
                                {
                                    <img src="~/Content/images/icon-checkmark.png" style="height: 14px;" />
                                }
                                else if (item.IsResume == 1 && item.ReviewFlag == 0)
                                {
                                    @*<img src="~/Content/images/icon-checkmark.png" style="height: 14px; margin-left: 5px;" />*@
                                    <img src="~/Content/images/icons8-done-64.png" style="height: 14px; margin-left: 5px;" />

                                }
                                <span id="lblIsreview" style="display:none;">@item.ReviewFlag</span>
                            </td>
                            <td>
                                <a href="#" class="clsReview" type="hidden" id="hdnMemberId" data-docId="@item.TeamMemberID" title="Review">
                                    Review
                                </a>
                                <span id="lblemppiid" style="display:none;">@item.TeamMemberID</span>
                                <input type="hidden" value="@item.EmployeeId" id="lblleadid" />
                                <span id="lblempname" style="display:none;">@item.TeamMemberName</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>
    @if (ViewBag.Role == "OM")
