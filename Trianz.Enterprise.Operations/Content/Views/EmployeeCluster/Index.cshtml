            @*<input type="checkbox" name="chkRowre" id="chkReview" class="chkReview">*@

            @if (isInactiveRecord == true)
            {
                <input type="checkbox" name="chkRowre" id="chkReview" class="chkReview" value="true" checked style="height: 12px;width: 16px;">
            }
            @if (isInactiveRecord == false)
            {
                <input type="checkbox" name="chkRowre" id="chkReview" class="chkReview" value="False" style="height: 12px;width: 16px;">
            }
        </div>
        <div style="float: right; position: relative; right: 37px;">
            <label>Resume Uploaded </label>

            @*<input type="checkbox" name="chkRowr" id="chkResume" class="chkResume">*@

            @if (isResume == true)
            {
                <input type="checkbox" name="chkRowr" id="chkResume" class="chkResume" value="true" checked style="margin-top: -2px;height: 12px;width: 16px;">
            }
            @if (isResume == false)
            {
                <input type="checkbox" name="chkRowr" id="chkResume" class="chkResume" value="False" style="margin-top: -2px;height: 12px;width: 16px;">
            }

        </div>
