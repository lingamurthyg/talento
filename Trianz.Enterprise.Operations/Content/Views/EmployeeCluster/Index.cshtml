    function callChangefunc() {
        var ddlprac = $("#Practice").val();
        var ddlclus = $("#Cluster").val();
        var ddlleadaname = $("#LeadName").val();
        if (ddlclus == "A") {
            ddlclus = 1000;
        }
        if (ddlclus == "P") {
            ddlclus = 1001;
        }
        if ($('#chckClsterLead').is(":checked")) {
            var chckClsterLead = $("#chckClsterLead").val();
        }
        else
        {
            var chckClsterLead = "";
        }
        if (ddlprac == "" || ddlprac == null || ddlprac == undefined) {
            ddlprac = 0;
        }
        if (ddlclus == "" || ddlclus == null || ddlclus == undefined) {
            ddlclus = 0;
        }
        if (ddlleadaname == "" || ddlleadaname == null || ddlleadaname == undefined) {
            ddlleadaname = 0;
        }
        if (ddlprac != 0 && ddlclus == 0) {
