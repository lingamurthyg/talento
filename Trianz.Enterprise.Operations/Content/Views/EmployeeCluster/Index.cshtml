                                <table class="table table-striped table-bordered dt-responsive nowrap" cellspacing="0" style="margin: 0px; width: 100%;">
                                    <thead id="thead">
                                        <tr style="background-color: #D6DCE3 !important; color: black; font-size: 12px;">
                                            @*<th>Cluster</th>*@
                                            <th style="text-align:right">Practice Total</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var ld in ViewBag.praticeLeadlst)
                                        {
                                            int display = 0;

                                            foreach (var m in ViewBag.praticeMemberlst)
                                            {
                                                if (ld.PracticeName == m.PracticeName)
                                                {
                                                    long subtotal = m.PracticeMemberCount + ld.PracticeLeadCount;
                                                    ptotal += subtotal;
                                                    <tr style="font-size: 12px;">
                                                        @*<td>@m.ClusterName</td>*@
                                                        <td style="text-align:right; color: black;">@subtotal</td>

                                                    </tr>
                                                    display = 1;
                                                    continue;

                                                }

                                            }
                                            if (display == 0)
                                            {
                                                ptotal += ld.PracticeLeadCount;
                                                <tr style="font-size: 12px;">
                                                    @*<td>@m.ClusterName</td>*@
                                                    <td style="text-align:right; color: black;">@ld.PracticeLeadCount</td>
                                                </tr>
                                            }

                                        }

                                    </tbody>
                                    <thead id="thead">
                                        <tr style="background-color: #D6DCE3 !important; color: black; font-size: 12px;">
                                            @*<th>Total</th>*@
                                            <th style="text-align:right">@ptotal</th>

                                        </tr>
                                    </thead>
                                </table>
                            </td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>
    }
</body>
