                                <thead id="thead">
                                    <tr style="background-color: #D6DCE3 !important; color: black; font-size: 12px;">
                                        @*<th>Cluster</th>*@
                                        <th style="text-align:right">Cluster Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var ld in ViewBag.leadList)
                                    {
                                        int display = 0;

                                        foreach (var m in ViewBag.groupdmemberList)
                                        {
                                            if (ld.ClusterName == m.ClusterName)
                                            {
                                                long subtotal = m.ClusterMemberCount + ld.ClusterLeadCount;
                                                cumltotal += subtotal;
                                                <tr style="font-size: 12px;">
                                                    @*<td>@m.ClusterName</td>*@
                                                    <td style="text-align:right; color: black;">@subtotal</td>

                                                </tr>
                                                display = 1;
                                                continue;

                                            }

                                        }
                                        if (display == 0)
                                        {
                                            cumltotal += ld.ClusterLeadCount;
