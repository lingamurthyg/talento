@model  Trianz.Enterprise.Operations.Models.ValidationModel
@{
    ViewBag.Title = "EmployeeDashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="~/Content/dataTables.bootstrap.css" rel="stylesheet">
<link href="~/Content/dataTables.bootstrap.css" rel="stylesheet">
<script type="text/javascript" language="javascript" src="https://cdn.datatables.net/1.10.11/js/jquery.dataTables.min.js"></script>
<script type="text/javascript" language="javascript" src="https://cdn.datatables.net/1.10.11/js/dataTables.bootstrap.min.js"></script>
<style>
    HRRF_custom table.p-resources thead th, .HRRF_custom table.p-resources tbody th, table.dataTable.nowrap th {
        background-color: #E1F3FF !important;
        color: black;
    }
    .HRRF_custom table tr th {
        color: black;
    }

    body {
        overflow-x: hidden;
    }

    div.dataTables_wrapper div.dataTables_filter label {
        font-weight: normal;
        white-space: nowrap;
        text-align: left;
        margin-right: 8px;
    }

    body {
        overflow-x: hidden;
    }

    .questionlogo1 {
        margin-left: 592px;
        margin-top: -9px;
    }

    .onlinebtn {
        margin-left: 548px;
        position: relative;
        top: 1px;
    }

    .myskills_div {
        display: block;
    }
    .HRRF_custom table tr th {
        color: black;
    }

    .row {
        margin-left: -5px;
        margin-right: -5px;
    }

    .column {
        float: left;
        width: 50%;
        padding: 5px;
        left: 27px;
        position: relative;
    }

    .row::after {
        content: "";
        clear: both;
        display: table;
    }

    #divGridContent1 {
        margin: 35px;
        width: 98%;
        position: relative;
        bottom: 15px;
        left: -20px;
        background-color: #ffffff;
    }
    .table-bordered > thead > tr > td, .table-bordered > thead > tr > th {
        border-bottom-width: 2px;
        background-color: #D6DCE3 !important;
    }
    #txt {
        color: #2C2E31;
        font-size: 16px;
        margin-left: 15px;
        /* margin-top: 53px; */
        position: relative;
        top: 9px;
    }
    .body-content {
        background-color: #ffffff;
        margin: 27px;
    }

    .nomargin-top, .HRRF_custom .nomargin-top {
        margin-top: -38px !important;
    }
</style>
<body>
    <div class="subpage_header page-header nomargin-top" style="border-bottom: 1px solid #248CC8; width: 1287px;background: #F3F4F9;">

        <p id="txt"><b>EMPLOYEE DASHBOARD</b></p>    @*observation*@
        @*<div>*@
        @*<input type="button" class="btn btn-primary pull-right search" id="btnSearch" value="Search" style="position: relative;left: 337px;top:87px;">*@
        <!--<div>
            <button id="btnExportToExcel" type="button" style="border: none;background-color: white;width: 21px;left: 1162px;top: -10px;height: 29px;position: relative;"> <img src="~/Content/images/xlsimg.png" data-toggle="tooltip" data-placement="left" title="Export to Excel" class="xlms" style="width: 46px;height: 44px;display: inline-block;position: relative;" alt="xlmsimg"></button>-->
        @*<button id="popup" onclick="div_showAssignment();" style="position: relative;top: -11px;background-color: #0070C1;color:white;width: 232px;margin-left: 957px;border-radius: 3px;border: 5px solid transparent;">Add New Cluster Lead Mapping</button>*@
        <!--</div>-->
        @*</div>*@

    </div>
    @{
        int intRowTotal = 0;
        int intGrandTotal = 0;
        int zeroTotal = 0, oneTotal = 0, twoTotal = 0, threeTotal = 0, fourTotal = 0, fiveTotal = 0, sixTotal = 0;
        int sevenTotal = 0, eightTotal = 0, nineTotal = 0, tentotal = 0;
        int elevenTotal = 0, twelveTotal = 0, aTotal = 0, cTotal = 0, hTotal = 0;
     }
    <table id="divGridContent1" class="table table-striped table-bordered dt-responsive nowrap" cellspacing="0" style="">
        <thead>
            <tr style="background-color: #D6DCE3 !important; color: black; font-size: 12px;">
                <th>Location</th>
                <th style="color:black; text-align:right">Grade 0</th>
                <th style="color:black; text-align:right">Grade A</th>
                <th style="color:black; text-align:right">Grade C</th>
                <th style="color:black; text-align:right">Grade H</th>
                <th style="color:black; text-align:right">Grade 1</th>
                <th style="color:black; text-align:right">Grade 2</th>
                <th style="color:black; text-align:right">Grade 3</th>
                <th style="color:black; text-align:right">Grade 4</th>
                <th style="color:black; text-align:right">Grade 5</th>
                <th style="color:black; text-align:right">Grade 6</th>
                <th style="color:black; text-align:right">Grade 7</th>
                <th style="color:black; text-align:right">Grade 8</th>
                <th style="color:black; text-align:right">Grade 9</th>
                <th style="color:black; text-align:right">Grade 10</th>
                <th style="color:black; text-align:right">Grade 11</th>
                <th style="color:black; text-align:right">Grade 12</th>
                <th style="color:black; text-align:right">Total</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null)
            {
                foreach (var item in Model.EmployeeLocationlst)
                {
                    intRowTotal = item.sA + item.sC + item.sH + item.sZero + item.sOne + item.sTwo + item.sthree + item.sFour + item.sFive + item.sSix + item.sSeven + item.sEight + item.sNine + item.sTen + item.sEleven + item.sTwelve;
                    intGrandTotal += intRowTotal;
                    zeroTotal += item.sZero;
                    oneTotal += item.sOne;
                    twoTotal += item.sTwo;
                    threeTotal += item.sthree;
                    fourTotal += item.sFour;
                    fiveTotal += item.sFive;
                    sixTotal += item.sSix;
                    sevenTotal += item.sSeven;
                    eightTotal += item.sEight;
                    nineTotal += item.sNine;
                    tentotal += item.sTen;
                    elevenTotal += item.sEleven;
                    twelveTotal += item.sTwelve;
                    aTotal += item.sA;
                    cTotal += item.sC;
                    hTotal += item.sH;

                    <tr style="font-size: 12px;">
                        <td style="color:black; text-align:left">@item.location</td>
                        <td style="color:black; text-align:right">@item.sZero</td>
                        <td style="color:black; text-align:right">@item.sA</td>
                        <td style="color:black; text-align:right">@item.sC</td>
                        <td style="color:black; text-align:right">@item.sH</td>
                        <td style="color:black; text-align:right">@item.sOne</td>
                        <td style="color:black; text-align:right">@item.sTwo</td>
                        <td style="color:black; text-align:right">@item.sthree</td>
                        <td style="color:black; text-align:right">@item.sFour</td>
                        <td style="color:black; text-align:right">@item.sFive</td>
                        <td style="color:black; text-align:right">@item.sSix</td>
                        <td style="color:black; text-align:right">@item.sSeven</td>
                        <td style="color:black; text-align:right">@item.sEight</td>
                        <td style="color:black; text-align:right">@item.sNine</td>
                        <td style="color:black; text-align:right">@item.sTen</td>
                        <td style="color:black; text-align:right">@item.sEleven</td>
                        <td style="color:black; text-align:right">@item.sTwelve</td>
                        <td style="color:black; text-align:right">@intRowTotal</td>
                    </tr>
                }
            }
        </tbody>
        <thead>
            <tr style="background-color: #E1F3FF !important; color: black; font-size: 12px;">
                @*<th colspan="14" style="text-align:right">Grand Total</th>*@
                <td style="color:black; text-align:left">Grand Total</td>
                <td style="color:black; text-align:right">@zeroTotal</td>
                <td style="color:black; text-align:right">@aTotal</td>
                <td style="color:black; text-align:right">@cTotal</td>
                <td style="color:black; text-align:right">@hTotal</td>
                <td style="color:black; text-align:right">@oneTotal</td>
                <td style="color:black; text-align:right">@twoTotal</td>
                <td style="color:black; text-align:right">@threeTotal</td>
                <td style="color:black; text-align:right">@fourTotal</td>
                <td style="color:black; text-align:right">@fiveTotal</td>
                <td style="color:black; text-align:right">@sixTotal</td>
                <td style="color:black; text-align:right">@sevenTotal</td>
                <td style="color:black; text-align:right">@eightTotal</td>
                <td style="color:black; text-align:right">@nineTotal</td>
                <td style="color:black; text-align:right">@tentotal</td>
                <td style="color:black; text-align:right">@elevenTotal</td>
                <td style="color:black; text-align:right">@twelveTotal</td>
                <th style="color:black; text-align:right">@intGrandTotal</th>
            </tr>
        </thead>
        @*<thead>
            <tr style="background-color: #E1F3FF !important; color: black; font-size: 12px;">
                <th colspan="17" style="text-align:right">Grand Total</th>
                <th style="color:black; text-align:right">@intGrandTotal</th>
        </thead>*@
    </table>
</body>


<script type="text/javascript">
    $(document).ready(function () {
        var url = '@Url.Content("~/EmployeeDashBoard/GetEmpDashBoardDetails")';
        $.ajax({
            url: url,
            type: 'GET',
            cache: false,
        });



</script>
