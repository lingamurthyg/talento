@model List<Trianz.Enterprise.Operations.Models.EmployeeTrainingDetails>

<link href="~/Content/dataTables.bootstrap.css" rel="stylesheet">
<script type="text/javascript" language="javascript" src="https://cdn.datatables.net/1.10.11/js/jquery.dataTables.min.js"></script>
<script type="text/javascript" language="javascript" src="https://cdn.datatables.net/1.10.11/js/dataTables.bootstrap.min.js"></script>

<style>
    table.table-bordered.dataTable tbody th, table.table-bordered.dataTable tbody td {
        border-bottom-width: 0;
        text-align: left;
    }
    body {
        overflow-x: hidden;
    }
</style>
    <table id="tableBenchEmployees" class="table table-striped table-bordered" cellspacing="0" style="margin: 0px;
    width: 98%;
    margin-left: 12px;">
        <thead>
            <tr style="background-color: #E1F3FF !important; color: black; font-size: 12px;">
                <th>Program Name</th>
                <th>Start Date</th>
                <th>End Date</th>
                <th>Attendance Status</th>
                <th>Total Hours</th>
                <th>Source</th>
                <th>Category</th>
                <th>Mode</th>
            </tr>
        </thead>
        <tbody>
            
                @if (Model.Count > 0)
                {
                    foreach (var item in Model)
                    {
                    <tr style="font-size: 12px;">
                        <td>@item.ProgramName</td>
                        <td>@(item.StartDate == null ? "" : @Convert.ToDateTime(item.StartDate).ToString("dd MMM yyyy"))</td>
                        <td>@(item.EndDate == null ? "" : @Convert.ToDateTime(item.EndDate).ToString("dd MMM yyyy"))</td>
                        @*<td>@(item.SOWStartDate == null ? "" : @Convert.ToDateTime(item.SOWStartDate).ToString("dd MMM yyyy"))</td>
                        <td>@(item.SOWEndDate == null ? "" : @Convert.ToDateTime(item.SOWEndDate).ToString("dd MMM yyyy"))</td>*@
                        <td>@item.AttendanceStatus</td>
                        <td>@item.TotalHours</td>
                        <td>@item.Source</td>
                        <td>@item.Category</td>
                        <td>@item.Mode</td>
                    </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8">
                            <div class="text-center">No data available</div>
                        </td>
                    </tr>
                }
              
            
            
                
        </tbody>
        </table>

