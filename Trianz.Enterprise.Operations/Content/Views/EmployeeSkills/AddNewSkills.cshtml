                                                        "<input type='checkbox' name='primarychk' class='primarychk' onclick='SkillChkcheck(this);' id=" + $(selectedOpts[x]).val() + "></td> <td>" +
                                                        "<span text='" + $(selectedOpts[x]).text() + "'  id='" + $(selectedOpts[x]).val() + "'>" + $(selectedOpts[x]).text() + "</span></td> <td>" +
                                                        "<span class='primary' text=" + Proficiency.toFixed(0) + " id='sp_" + x + "'>" + Proficiency.toFixed(0) + "</span></td> </tr>");



                }
                count = count + 1;
            }
        }
        $(".primary").attr('text', Proficiency.toFixed(0));
        $(".primary").html(Proficiency.toFixed(0));
        //$(".primary").html(dropdownPrimary);

    }

