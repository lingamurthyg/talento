    function RemoveSecondarySkill() {
        $('input[name="secchk"]:checked').each(function () {

            if (this.checked) {
                var NosecR = $(".secchk").length - $('input[name="secchk"]:checked').length;
                var SecProficiency = 30 / NosecR;
                var id = '#tr_' + $(this).attr('id');
                if ($("#SecondarySkillsgrid").find(id) != undefined) {
                    $("#SecondarySkillsgrid").find(id).remove();
                    $(".secondary").html(SecProficiency.toFixed(0));
                    $(".secondary").attr('text', SecProficiency.toFixed(0));

                    var PrimaryRate = 100;
                    var Primaryrows = $(".primarychk").length;
                    if (Primaryrows == 0)
                        Primaryrows = 1;
                    if ($(".secchk").length > 0) {
                        PrimaryRate = 70;
                    }
                    var ProficiencyPrimaryRate = PrimaryRate / Primaryrows;
                    $(".primary").html(ProficiencyPrimaryRate.toFixed(0));
                    $(".primary").attr('text', ProficiencyPrimaryRate.toFixed(0));
                }
            }
        });
    }

    function RemovePrimarySkill() {
        var PrimaryRate = 100;

        if ($("#SecondarySkillsgrid td").length > 0) {
            PrimaryRate = 70;
        }
        $('input[name="primarychk"]:checked').each(function () {
            if (this.checked) {
                var NOR = $(".primarychk").length - $('input[name="primarychk"]:checked').length;
                var Proficiency = PrimaryRate / NOR;
                var id = '#tr_' + $(this).attr('id');
                if ($("#PrimarySkillsGrid").find(id) != undefined) {
                    $("#PrimarySkillsGrid").find(id).remove();
                    $(".primary").html(Proficiency);
                    $(".primary").attr('text', Proficiency.toFixed(0));
                }
            }
        });
    }

    function SubmitData() {
        var PrimarySkills = '';
        var SecondarySkills = '';


        $("#PrimarySkillsGrid tr").each(function () {
            var x = $(this).attr('id');
            if (x != undefined) {
                var pID = x.split('_')[1] + ":" + $(this).find(".primary").attr('text');
                PrimarySkills = PrimarySkills + pID + ';';
            }

        });
        $("#SecondarySkillsgrid tr").each(function () {
            var x = $(this).attr('id');
            if (x != undefined) {
                var SID = x.split('_')[1] + ":" + $(this).find(".secondary").attr('text');
                SecondarySkills = SecondarySkills + SID + ';';
            }
        });


        $.ajax({
            url: '@Url.Action("SubmitEmployeeDetails", "EmployeeSkills")',
            data: { PrimarySkills: PrimarySkills, SecondarySkills: SecondarySkills },
            cache: false,
            type: "POST",
            dataType: "JSON",
            success: function (data) {
               if (data == "Success") {
                    //alert('Ok to refresh page');
                        window.location.href = '@Url.Action("AddNewSkills", "EmployeeSkills")'; //"/employeeskills/addnewskills";
                    }
                    else if (data== "Sessionexpired") {
                window.location.href = '@Url.Action("SessionExpire", "Signout")';
                }
                else if (data == "Error")
                    {
                        window.location.href = '@Url.Action("Error","Error")';
                    }

            },
            error: function (e) {
                alert(e.responseText);
            }
        });
    }

