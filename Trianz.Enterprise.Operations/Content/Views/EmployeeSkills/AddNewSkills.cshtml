                var skillHistory = $(this).attr("data-skillhistory");
                var content = '';
                if (skillHistory != "") {
                    var skillHistoryArry = skillHistory.split(',');
                    content += '<table id="tbl" class="table" cellspacing="0" width="100%"';
                    content += '<thead><tr><th style="font-size:10px">Expertise Level History</th></thead>';
                    content += '<tbody><tr><td>';
                    content += '<table id="tbl" class="table table-bordered" cellspacing="0" width="100%"';
                    content += '<thead><tr><th style="font-size:10px;">Expertise Level </th><th style="font-size:10px">Approver</th><th style="font-size:10px">Approved Date</th></thead>';
                    content += '<tbody>';

                    if (skillHistoryArry.length > 0) {
                        for (var i = 0; i < skillHistoryArry.length; i++) {
                            var historyArry = skillHistoryArry[i].split('-');
                            if (historyArry.length > 0) {
                                var approvalDate = historyArry[0];
                                var expertiselevel = historyArry[1];
                                var approver = historyArry[2];
                                content += '<tr>';
                                content += '<td style="font-size:10px">' + expertiselevel + '</td>';
                                content += '<td style="font-size:10px">' + approver + '</td>';
                                content += '<td style="font-size:10px">' + approvalDate + '</td>';
                                content += '</tr>';
                            }

                        }
                    }
                    content += '</tbody></table>';
                    content += '</td></tr></tbody><table>';
                }
                else {
                    content += '<span class="text-center">No history</span>';
                }


                return content;
            },
            //template: popoverTemplate,
            placement: "auto",
            html: true
        });



