    function FillCompen(SkillID, comptencyControl, skilname, onselect) {
        var Skillname = "";
        if (comptencyControl != undefined)
            Skillname = skilname;
        else
            Skillname = $("#ddlskill").val();
   
        $.ajax({
            url: "@(Url.Action("GetCompetencyList", "EmployeeSkills"))",
