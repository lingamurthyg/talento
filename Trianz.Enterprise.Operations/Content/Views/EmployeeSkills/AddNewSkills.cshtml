        $("#btnUploadResume").on("change", function () {

            debugger;
            var ischk = true;
            var mess = "";
            myfile = $(this).val();
            var ext = myfile.split('.').pop();
            //var fileType = "";
            //$(".filetype").find("input[type='radio']").each((function () {
            //    if ($(this).is(":checked")) {
            //        fileType = $(this).val();
            //    }
