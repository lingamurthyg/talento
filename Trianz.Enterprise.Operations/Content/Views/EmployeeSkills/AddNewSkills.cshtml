    function DomainData() {
        var select = $("#Domain");
        select.empty();
        $.ajax({
            url: '@Url.Action("GetEmployeeDomains", "EmployeeSkills")',
            cache: false,
            type: "GET",
            dataType: "JSON",
            success: function (objdomain) {
                if (objdomain != null && objdomain != "Sessionexpired" && objdomain != "Error") {
                    $('#Domaingrid').empty();
                    $("#Domaingrid").append("<tr><th>Domain</th><th>Action</th></tr>");
                    $.each($(objdomain), function (Text, Value) {
                    debugger;
                    $('#Domaingrid').append("<tr><td><option Text='" + Value.DomainName + "' value='" +
                    Value.DomainId + "'>" + Value.DomainName + "</option></td><td><a class='dom' id='"
                    + Value.DomainId + "' href='#' onclick='clickDelete(this);'><i class='fa fa-times fa-lg' title='Delete Domain' aria-hidden='true' id='"
                    + Value.DomainId + "'></i></a></td></tr>");
                        });
                    }
                        else if (objdomain== "Sessionexpired") {
                            window.location.href = '@Url.Action("SessionExpire", "Signout")';
