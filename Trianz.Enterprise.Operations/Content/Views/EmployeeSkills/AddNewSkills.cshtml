                    var skilltext = $("#PrimarySkillsGrid").find(id).find('td:nth-child(2)').text();
                    alert(skilltext + " is already selected as PrimarySkill");
                }
                else {
                    var NoRecords = $(".secchk").length + 1;
                    if (NoRecords == 1) {
