                                        $('.DownloadPpt').show();
                                        var ppfFile = "@ViewBag.PptFileName";
                                        $('.clsppt').html(ppfFile);
                                    }

                                    bootbox.alert("Resume Uploaded Successfully");

                                }
                                else if (dataResult== "Sessionexpired") {
                                    window.location.href = '@Url.Action("SessionExpire", "Signout")';
                                }
                                                      else if (dataResult == "Error")
                    {
                        window.location.href = '@Url.Action("Error","Error")';
                    }
                                else { bootbox.alert(dataResult); }

                            }
                        },
                        error: function (error) {
