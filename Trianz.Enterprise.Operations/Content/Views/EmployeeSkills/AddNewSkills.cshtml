        function GetSelectSkills() {
            var Skillslist = [];
            $("#tableEmpSkills").find("tbody tr").each(function () {
                if ($(this).find("td:first").find(".chkEmployee").prop("checked")) {
                    var EmployeeSkillId = $(this).find("td:first").find(".chkEmployee").val().trim();
                    var SkillStatus = "Submitted";
                    var Skillsubmtion = { EmployeeSkillId: EmployeeSkillId, SkillStatus: SkillStatus };
                    Skillslist.push(Skillsubmtion);
                }
            });
            return Skillslist;
        }

        function ValidateSkills() {
            var isValid = false;
            $("#tableEmpSkills").find("tbody tr").each(function () {
                if ($(this).find("td:first").find(".chkEmployee").prop("checked")) {
                    isValid = true;
                    return;
                }
            });
            return isValid;
        }

        //validations
        function chkvalidationforskill() {
            var ischk = true;
            var explev = $("#ddlExpertiseLevel").val();
            var compename = $("#ddlComp").val();
            var skillname = $("#ddlskill").val();
            var motn = $("#ddlMonth").val();
            var year = $("#ddlYear").val();
            var currentYear = (new Date).getFullYear();
            var currentMonth = (new Date).getMonth() + 1;

            if (explev == "") {
                bootbox.alert("please select Expertise Level");
                ischk = false;

            }
            else if (compename == "") {
                bootbox.alert("please select Competency");
