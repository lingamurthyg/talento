    function CheckApprovedSkill(skillHistory) {
        var isApproved = false;
        var skillHistoryArry = skillHistory.split(',');

        if (skillHistoryArry.length > 0) {

            for (var i = 0; i < skillHistoryArry.length; i++) {
                var historyArry = skillHistoryArry[i].split('-');
                if (historyArry.length > 0) {
                    var previousStatus = historyArry[3];
                    //var currentstatus = historyArry[1];
                    if (previousStatus == "Approved") {
                        isApproved = true;
                        return isApproved;
                    }
                    //else if (currentstatus == "Approved") {
                    //    isApproved = true;
                    //    return isApproved;
                    //}

                }

            }

        }

    }
