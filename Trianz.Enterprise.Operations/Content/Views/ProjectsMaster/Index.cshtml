<script type="text/javascript" language="javascript" src="https://cdn.datatables.net/1.10.11/js/jquery.dataTables.min.js"></script>
<script type="text/javascript" language="javascript" src="https://cdn.datatables.net/1.10.11/js/dataTables.bootstrap.min.js"></script>
<div class="request_header">
    <div id="divGridContent1" class="table table-responsive" style="overflow-x:hidden;">
        <table id="tableBenchEmployees" class="table table-striped table-bordered" cellspacing="0" style="margin: 7px 0px 0px 25px; width: 96%;">
            <thead>
                <tr id="theadcolour">
                    <th style="width:164px;height: 38px;font-size:12px;">
                        <div class="overviewmain">
                            Account Name
                            <div class="sorting">
                                <span class="sortinnic"></span>
                                <span class="sortinnicdown"></span>
                            </div>
                        </div>
                    </th>
                    <th style="width:100px;font-size:12px;">
                        <div class="overviewmain">
                            Project Code
                            <div class="sorting" style="position: relative;left: 7px;">
                                <span class="sortinnic"></span>
                                <span class="sortinnicdown"></span>
                            </div>
                        </div>

                    </th>
                    <th style="width:181px;font-size:12px;">
                        <div class="overviewmain">
                            Project Name
                            <div class="sorting">
                                <span class="sortinnic"></span>
                                <span class="sortinnicdown"></span>
                            </div>
                        </div>

                    </th>
                    <th style="width:110px;font-size:12px;">
                        <div class="overviewmain">
                            SOW Start Date
                            <div class="sorting">
                                <span class="sortinnic"></span>
                                <span class="sortinnicdown"></span>
                            </div>
                        </div>

                    </th>
                    <th style="width:103px;font-size:12px;">

                        <div class="overviewmain">
                            SOW End Date
                            <div class="sorting">
                                <span class="sortinnic"></span>
                                <span class="sortinnicdown"></span>
                            </div>
                        </div>
                    </th>
                    <th style="width:164px;font-size:12px;">
                        <div class="overviewmain">
                            Project Manager
                            <div class="sorting">
                                <span class="sortinnic"></span>
                                <span class="sortinnicdown"></span>
                            </div>
                        </div>

                    </th>
                    <th style="width:90px;font-size:12px;">

                        <div class="overviewmain">
                            Billing Type
                            <div class="sorting">
                                <span class="sortinnic"></span>
                                <span class="sortinnicdown"></span>
                            </div>
                        </div>
                    </th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null)
                {
                    foreach (var item in Model)
                    {
                        <tr style="font-size: 12px;">
                            <td>@item.AccountName</td>
                            <td>@item.ProjectCode</td>
                            <td>@item.ProjectName</td>
                            <td>@(item.SOWStartDate == null ? "" : @Convert.ToDateTime(item.SOWStartDate).ToString("dd-MMM-yyyy"))</td>
                            <td>@(item.SOWEndDate == null ? "" : @Convert.ToDateTime(item.SOWEndDate).ToString("dd-MMM-yyyy"))</td>
                            <td>@item.ProjectManager</td>
                            <td>@item.BillingType</td>
                        </tr>
                    }
                }
            </tbody>

        </table>

    </div>

</div>

<script type="text/javascript">
    $(document).ready(function () {
        $("#btnProcessing").hide();
        $('#tableBenchEmployees').DataTable({});
    });

        $('#btnExportToExcel').click(function () {
                //$(this).hide();
                $("#btnProcessing").show();

                $.ajax({
                    url: "@Url.Action("ExportReport", "ProjectsMaster")",
                    data: "",
                    type: "POST",
                    datatype: "JSON",
                    cache: false,
                    success: function (response) {
                        if (response == "success") {
                            window.location = "@Url.Action("GenerateProjectInfo", "ProjectsMaster")";

                            setTimeout(function () {
                                $("#btnExportToExcel").show();
                                $("#btnProcessing").hide();
                            }, 10000);
                        }
                        else if (response == "Sessionexpired") {
                                window.location.href = '@Url.Action("SessionExpire", "Signout")';
                        }
                        else if (response == "Error") {
                                window.location.href = '@Url.Action("Error", "Error")';
                            }
                    },
                    error: function (error) {
                        alert(error.statusText);
                    }
                });
            });
</script>





