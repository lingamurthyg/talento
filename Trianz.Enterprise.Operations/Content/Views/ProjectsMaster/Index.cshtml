            <p id="txt">PROJECT MASTER</p>
        </div>
        <div class="pull-right text-right myskills_div">
            @*<button id="btnExportToExcel" type="button" class="btn btn-default pull-left" style="margin-top: -8px;">
            Export to Excel
        </button>*@

            @if ((Session["Role"].ToString() == "OM" || Session["Role"].ToString() == "PM" || Session["Role"].ToString() == "DH" || Session["Role"].ToString() == "SM" || Session["Role"].ToString() == "RL"))
            {
                @*@:<button id="btnExportToExcel" type="button" class="btn btn-default pull-right" style="margin-top: -8px;"><i class="glyphicon glyphicon-download-alt" aria-hidden="true"></i> Export to Excel</button>
            @:<button id="btnProcessing" type="button" class="btn btn-default pull-right" style="margin-top: -8px;" disabled><i class="fa fa-cog fa-spin fa-1x fa-fw" aria-hidden="true"></i> Downloading...</button>*@
               
            <div>
                @*<button id="btnExportToExcel" type="button" style="border: none;background-color: white;height: 50px;"> <img src="~/Content/images/xlsimg.png" data-toggle="tooltip" data-placement="left" title="Export to Excel" class="xlms" style="width: 43px;height: 44px;display:inline-block;margin-top: 2px;" alt="xlmsimg"></button>*@
                <button id="btnExportToExcel" type="button">
                    <img src="~/Content/images/Report_icon.svg" /> Export <span class="caret"></span>
                    @*<img src="~/Content/images/xlsimg.png" data-toggle="tooltip" data-placement="left" title="Export to Excel" class="xlms" style="width: 43px;height: 44px;display:inline-block;margin-top: 11px;left: 17px;position:relative;" alt="xlmsimg">*@
                </button>
            </div>
