@model List<Trianz.Enterprise.Operations.Models.Project>
<link href="~/Content/Talento.css" rel="stylesheet" />
@{
    ViewBag.Title = "Index";

}
<link href="~/Content/Talento1.css" rel="stylesheet" />
<link href="~/Content/LayoutHeader.css" rel="stylesheet" />
<link href="~/pagination.css" rel="stylesheet" />
<style>
    .sortinnic {
        background: url(../../Content/images/sortup.svg) 0px 3px no-repeat;
        display: block;
        height: 10px;
        width: 10px;
    }
    .pagination > .active > a,
    .pagination > .active > span,
    .pagination > .active > a:hover,
    .pagination > .active > span:hover,
    .pagination > .active > a:focus,
    .pagination > .active > span:focus {
        background-color: #004BBB;
    }

        .pagination > .active > a, .pagination > .active > a:focus, .pagination > .active > a:hover, .pagination > .active > span, .pagination > .active > span:focus, .pagination > .active > span:hover {
            z-index: 0;
            color: #fff;
            cursor: default;
            background-color: #004BBB;
            border-color: #337ab7;
        }
    .overviewmain {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .sortingmain {
        position: absolute;
        right: 975px;
    }
    .sorting {
        position: relative;
        left: 0px;
    }
    .sortinnicdown {
        background: url(../../Content/images/sortdown.svg) 0px 3px no-repeat;
        display: block;
        height: 10px;
        width: 10px;
    }
    
    table.dataTable thead .sorting:after, table.dataTable thead .sorting_asc:after, table.dataTable thead .sorting_desc:after, table.dataTable thead .sorting_asc_disabled:after, table.dataTable thead .sorting_desc_disabled:after {
        position: absolute;
        bottom: 8px;
        right: 8px;
        display: block;
        font-family: 'Glyphicons Halflings';
        opacity: -0.5;
    }
    body {
        overflow-x: hidden;
    }

    .Empname {
     position: relative;
     bottom: 20px;
     left: 21px;
               
    }
    div.dataTables_wrapper div.dataTables_paginate {
        margin: 0px;
        /* margin-left: 288px; */
        text-align: end;
        padding: 0px 20px 0 0;
    }
    table.table-bordered.dataTable tbody th, table.table-bordered.dataTable tbody td {
        border-bottom-width: 0;
        color: rgb(0, 0, 0);
      
    }
    #tableBenchEmployees_info {
        margin: 20px;
    }
    #tableBenchEmployees {
        width: 100%;
        height: 100%;
        overflow-x: hidden;
        margin: 0px;
    }

    div.dataTables_wrapper div.dataTables_filter label {
        font-weight: normal;
        white-space: nowrap;
        text-align: left;
        position: relative;
        right: 581px;
        top: 43px;
    }
    #btnExportToExcel {
        position: relative;
        background-color: white;
       
        top: 20px;
        border: white;
        float: right;
        color: #004BBB;
        border: 1px solid #004BBB;
        border-radius: 6px;
        padding: 6px 25px;
    }

    .HRRF_custom table tr th {
        background-color: #D6DCE3 !important;
        color: black;
    }
    #txt {
        color: #2C2E31;
        font-size: 15px;
        margin-top: 17px;
        margin-left:5px;
             
        /*margin-left: 60px;*/
                 
    }
    #tableBenchEmployees_length {
        position: relative;
        left: 26px;
    }
    #tableBenchEmployees_filter {
        position: relative;
        right: 25px;
    }
    .request_header {
        margin: 72px 0px 0px;
        background-color: #FFFFFF;
    }
</style>
@*<div class="subpage_header page-header nomargin-top">
        <p>Projects Summary</p>
    </div>*@
